  "events": [ {
    "tStartMs": 1067,
    "dDurationMs": 1201,
    "segs": [ {
      "utf8": "-You all know how\nto play charades."
    } ],
    "wpWinPosId": 1,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 2268,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "Each player gets a turn\ngiving silent clues"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 4103,
    "dDurationMs": 2703,
    "segs": [ {
      "utf8": "to their teammate. 30 seconds\non the clock per turn."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 6806,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "We'll do four rounds,\nthen the fifth round"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 8508,
    "dDurationMs": 1634,
    "segs": [ {
      "utf8": "is a charades showdown."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 10142,
    "dDurationMs": 1235,
    "segs": [ {
      "utf8": "-Ow, ow!\n-We got this."
    } ],
    "wpWinPosId": 6,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 11377,
    "dDurationMs": 3237,
    "segs": [ {
      "utf8": "-Both teams give the same clue\nat the same time."
    } ],
    "wpWinPosId": 7,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 14614,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "Gal, why don't you\nstart us off tonight"
    } ],
    "wpWinPosId": 8,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 16416,
    "dDurationMs": 1067,
    "segs": [ {
      "utf8": "since you're our guest."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 17483,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "-You got it. Okay. Phew!"
    } ],
    "wpWinPosId": 9,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 19085,
    "dDurationMs": 2736,
    "segs": [ {
      "utf8": "Just so you know, I've never --\nI never played this before."
    } ],
    "wpWinPosId": 10,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 21821,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "Now I do it? I start?\nOkay."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 23656,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "-Yes. okay, yeah."
    } ],
    "wpWinPosId": 11,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 25057,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "I don't know how\nto answer that."
    } ],
    "wpWinPosId": 12,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 26959,
    "dDurationMs": 2536,
    "segs": [ {
      "utf8": "Now I do it, but yeah.\n-How do you do a song?"
    } ],
    "wpWinPosId": 13,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 29495,
    "dDurationMs": 2736,
    "segs": [ {
      "utf8": "How do you film? TV?\n-Film, TV. Yeah."
    } ],
    "wpWinPosId": 8,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 32231,
    "dDurationMs": 1202,
    "segs": [ {
      "utf8": "-Songs? Songs."
    } ],
    "wpWinPosId": 14,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 33433,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "-Yeah, but that's\nnot the hard part."
    } ],
    "wpWinPosId": 15,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 34834,
    "dDurationMs": 1134,
    "segs": [ {
      "utf8": "That's not the hard part.\n-Okay."
    } ],
    "wpWinPosId": 16,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 35968,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "-You'll have to have me guess...\n-Okay, okay."
    } ],
    "wpWinPosId": 17,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 37336,
    "dDurationMs": 4037,
    "segs": [ {
      "utf8": "-Oh, no. Oh, no. Oh, no.\n-No, no, no, no, no, no."
    } ],
    "wpWinPosId": 18,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 41373,
    "dDurationMs": 2703,
    "segs": [ {
      "utf8": "-Listen, it's going to be okay.\nWe're going to do great."
    } ],
    "wpWinPosId": 10,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 44076,
    "dDurationMs": 1402,
    "segs": [ {
      "utf8": "We're going to do great.\n-Oh my God. I hate losing."
    } ],
    "wpWinPosId": 19,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 45478,
    "dDurationMs": 1601,
    "segs": [ {
      "utf8": "-Have faith in me right now.\n-I hate losing."
    } ],
    "wpWinPosId": 20,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 47079,
    "dDurationMs": 1369,
    "segs": [ {
      "utf8": "-We got you guys.\nAll right. Go, go, go, go, go."
    } ],
    "wpWinPosId": 7,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 48448,
    "dDurationMs": 1768,
    "segs": [ {
      "utf8": "Pick a number. Pick a number.\n-Okay."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 50216,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ],
    "wpWinPosId": 21,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 51684,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "-We can do this.\ncome on, buddy."
    } ],
    "wpWinPosId": 12,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 54187,
    "dDurationMs": 3870,
    "segs": [ {
      "utf8": "-Okay, now I just start?\n-Well, you do one."
    } ],
    "wpWinPosId": 22,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 58057,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "You can't talk.\n-Shh! Okay."
    } ],
    "wpWinPosId": 23,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 59525,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "-Don't tell me to shush."
    } ],
    "wpWinPosId": 24,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 61327,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "I'm the one guessing.\nI have to talk."
    } ],
    "wpWinPosId": 25,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 63229,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "-Ready?\n-Yes. Sorry, yes."
    } ],
    "wpWinPosId": 26,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 65498,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "-Hmm."
    } ],
    "wpWinPosId": 27,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 67500,
    "dDurationMs": 1101,
    "segs": [ {
      "utf8": "-Song.\n-Mm-hmm."
    } ],
    "wpWinPosId": 28,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 68601,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "-Yeah, cool.\nthree words."
    } ],
    "wpWinPosId": 29,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 70136,
    "dDurationMs": 2403,
    "segs": [ {
      "utf8": "-Yeah.\n-Oh."
    } ],
    "wpWinPosId": 30,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 72539,
    "dDurationMs": 1301,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ],
    "wpWinPosId": 31,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 73840,
    "dDurationMs": 2869,
    "segs": [ {
      "utf8": "Uh..."
    } ],
    "wpWinPosId": 27,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 76709,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "-Jimmy\n\"Birth of a Nation?\""
    } ],
    "wpWinPosId": 32,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 79512,
    "dDurationMs": 2703,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ],
    "wpWinPosId": 31,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 82215,
    "dDurationMs": 2202,
    "segs": [ {
      "utf8": "\"Baby Got Back?\""
    } ],
    "wpWinPosId": 33,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 84417,
    "dDurationMs": 3036,
    "segs": [ {
      "utf8": "Push? \"Push It!\""
    } ],
    "wpWinPosId": 33,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 87453,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "Yes, second word."
    } ],
    "wpWinPosId": 34,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 89255,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "Two. Yeah. Okay."
    } ],
    "wpWinPosId": 33,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 92258,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "Okay. Three words."
    } ],
    "wpWinPosId": 35,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 95828,
    "dDurationMs": 3937,
    "segs": [ {
      "utf8": "Third word, running?\nBirth, okay, run."
    } ],
    "wpWinPosId": 32,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 99765,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "-Ahh! It was that bad?\nI thought..."
    } ],
    "wpWinPosId": 36,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 102268,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "-No, no, no, no.\nWhat was it. I got it."
    } ],
    "wpWinPosId": 36,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 103769,
    "dDurationMs": 2236,
    "segs": [ {
      "utf8": "-\"Born To Run.\"\n-Oh, \"Born To Run\" of course."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 106005,
    "dDurationMs": 3270,
    "segs": [ {
      "utf8": "-The song.\nI'm so mad."
    } ],
    "wpWinPosId": 37,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 109275,
    "dDurationMs": 1101,
    "segs": [ {
      "utf8": "That was fantastic."
    } ],
    "wpWinPosId": 38,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 110376,
    "dDurationMs": 1602,
