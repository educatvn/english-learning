  }, {
    "tStartMs": 662103,
    "dDurationMs": 975,
    "segs": [ {
      "utf8": "Allie."
    } ]
  }, {
    "tStartMs": 663386,
    "dDurationMs": 555,
    "segs": [ {
      "utf8": "Yes?"
    } ]
  }, {
    "tStartMs": 667629,
    "dDurationMs": 858,
    "segs": [ {
      "utf8": "Go on, Mark."
    } ]
  }, {
    "tStartMs": 669281,
    "dDurationMs": 576,
    "segs": [ {
      "utf8": "Um..."
    } ]
  }, {
    "tStartMs": 671013,
    "dDurationMs": 7069,
    "segs": [ {
      "utf8": "Well, tomorrow's my last day and I think we...\nI mean...I..., I really like meeting you."
    } ]
  }, {
    "tStartMs": 678230,
    "dDurationMs": 645,
    "segs": [ {
      "utf8": "And..."
    } ]
  }, {
    "tStartMs": 679197,
    "dDurationMs": 821,
    "segs": [ {
      "utf8": "Here you are."
    } ]
  }, {
    "tStartMs": 680138,
    "dDurationMs": 936,
    "segs": [ {
      "utf8": "Fruit salad."
    } ]
  }, {
    "tStartMs": 681074,
    "dDurationMs": 930,
    "segs": [ {
      "utf8": "Would you like any coffee?"
    } ]
  }, {
    "tStartMs": 682004,
    "dDurationMs": 1675,
    "segs": [ {
      "utf8": "Yes, an espresso, please."
    } ]
  }, {
    "tStartMs": 684129,
    "dDurationMs": 1285,
    "segs": [ {
      "utf8": "The same for me, please."
    } ]
  }, {
    "tStartMs": 690407,
    "dDurationMs": 716,
    "segs": [ {
      "utf8": "Sorry, Mark."
    } ]
  }, {
    "tStartMs": 694101,
    "dDurationMs": 1996,
    "segs": [ {
      "utf8": "Do you want to come to California next month?"
    } ]
  }, {
    "tStartMs": 696683,
    "dDurationMs": 2238,
    "segs": [ {
      "utf8": "There's a big conference.\nI'm gonna be there."
    } ]
  }, {
    "tStartMs": 699478,
    "dDurationMs": 1207,
    "segs": [ {
      "utf8": "Why don't you come?"
    } ]
  }, {
    "tStartMs": 701350,
    "dDurationMs": 923,
    "segs": [ {
      "utf8": "What do you think?"
    } ]
  }, {
    "tStartMs": 702661,
    "dDurationMs": 786,
    "segs": [ {
      "utf8": "To espressos."
    } ]
  }, {
    "tStartMs": 705459,
    "dDurationMs": 1023,
    "segs": [ {
      "utf8": "Anything else?"
    } ]
  }, {
    "tStartMs": 706482,
    "dDurationMs": 1315,
    "segs": [ {
      "utf8": "A little brandy? A grappa?"
    } ]
  }, {
    "tStartMs": 707797,
    "dDurationMs": 405,
    "segs": [ {
      "utf8": "No."
    } ]
  }, {
    "tStartMs": 708709,
    "dDurationMs": 607,
    "segs": [ {
      "utf8": "Thank you."
    } ]
  }, {
    "tStartMs": 712230,
    "dDurationMs": 1282,
    "segs": [ {
      "utf8": "What do you say, Allie?"
    } ]
  }, {
    "tStartMs": 713841,
    "dDurationMs": 1734,
    "segs": [ {
      "utf8": "I'm not sure, Mark."
    } ]
  }, {
    "tStartMs": 716949,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "I need some time to think about it, Ok?"
    } ]
  }, {
    "tStartMs": 719159,
    "dDurationMs": 2184,
    "segs": [ {
      "utf8": "All right. But please tell me before I go."
    } ]
  }, {
    "tStartMs": 721350,
    "dDurationMs": 721,
    "segs": [ {
      "utf8": "Ok."
    } ]
  }, {
    "tStartMs": 722865,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Can we have a check, please?"
    } ]
  }, {
    "tStartMs": 723985,
    "dDurationMs": 1285,
    "segs": [ {
      "utf8": "Sorry? The check?"
    } ]
  }, {
    "tStartMs": 725920,
    "dDurationMs": 2279,
    "segs": [ {
      "utf8": "The bill, Mark. We're in Britain, remember?"
    } ]
  }, {
    "tStartMs": 728199,
    "dDurationMs": 2215,
    "segs": [ {
      "utf8": "Sorry. Could we have the bill, please?"
    } ]
  }, {
    "tStartMs": 730414,
    "dDurationMs": 557,
    "segs": [ {
      "utf8": "Yes, sir."
    } ]
  }, {
    "tStartMs": 735387,
    "dDurationMs": 1079,
    "segs": [ {
      "utf8": "Good morning, sir."
    } ]
  }, {
    "tStartMs": 736466,
    "dDurationMs": 2726,
    "segs": [ {
      "utf8": "Good morning. Can I have my bill, please?\nI'm checking out."
    } ]
  }, {
    "tStartMs": 739192,
    "dDurationMs": 926,
    "segs": [ {
      "utf8": "Which room is it?"
    } ]
  }, {
    "tStartMs": 740118,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "Room 425."
    } ]
  }, {
    "tStartMs": 743671,
    "dDurationMs": 2318,
    "segs": [ {
      "utf8": "Did you have anything from the minibar last night?"
    } ]
  }, {
    "tStartMs": 745989,
    "dDurationMs": 1386,
    "segs": [ {
      "utf8": "Yes, a mineral water."
    } ]
  }, {
    "tStartMs": 751912,
    "dDurationMs": 1224,
    "segs": [ {
      "utf8": "Here you are."
    } ]
  }, {
    "tStartMs": 753136,
    "dDurationMs": 1678,
    "segs": [ {
      "utf8": "How would you like to pay?"
    } ]
  }, {
    "tStartMs": 754814,
    "dDurationMs": 1459,
    "segs": [ {
      "utf8": "American Express."
    } ]
  }, {
    "tStartMs": 758117,
    "dDurationMs": 1821,
    "segs": [ {
      "utf8": "Thank you."
    } ]
  }, {
    "tStartMs": 765359,
    "dDurationMs": 2451,
    "segs": [ {
      "utf8": "Ok. Can you sign here, please?"
    } ]
  }, {
    "tStartMs": 770861,
    "dDurationMs": 756,
    "segs": [ {
      "utf8": "Thank you."
    } ]
  }, {
    "tStartMs": 774702,
    "dDurationMs": 1854,
    "segs": [ {
      "utf8": "Would you like me to call a taxi for you?"
    } ]
  }, {
    "tStartMs": 776556,
    "dDurationMs": 1127,
    "segs": [ {
      "utf8": "No, thanks."
    } ]
  }, {
    "tStartMs": 780837,
    "dDurationMs": 1766,
    "segs": [ {
      "utf8": "Do you need any help with your luggage?"
    } ]
  }, {
    "tStartMs": 782918,
    "dDurationMs": 1707,
    "segs": [ {
      "utf8": "No, I'm fine. Thanks."
    } ]
  }, {
    "tStartMs": 784637,
    "dDurationMs": 1411,
    "segs": [ {
      "utf8": "Have a good trip, Mr. Ryder."
    } ]
  }, {
    "tStartMs": 786048,
    "dDurationMs": 503,
    "segs": [ {
      "utf8": "Thank you."
    } ]
  }, {
    "tStartMs": 786551,
    "dDurationMs": 544,
    "segs": [ {
      "utf8": "Goodbye!"
    } ]
  }, {
    "tStartMs": 787095,
    "dDurationMs": 689,
    "segs": [ {
      "utf8": "Goodbye!"
    } ]
  }, {
    "tStartMs": 791716,
    "dDurationMs": 846,
    "segs": [ {
      "utf8": "Hello?"
    } ]
  }, {
    "tStartMs": 792862,
    "dDurationMs": 1517,
    "segs": [ {
      "utf8": "Hi Mark.\nIt's Allie."
    } ]
  }, {
    "tStartMs": 794791,
    "dDurationMs": 2442,
    "segs": [ {
      "utf8": "I'm really sorry but the traffic\nthis morning is terrible."
    } ]
  }, {
    "tStartMs": 797653,
    "dDurationMs": 1079,
    "segs": [ {
      "utf8": "I'm going to be very late."
    } ]
  }, {
    "tStartMs": 799572,
    "dDurationMs": 649,
    "segs": [ {
      "utf8": "Ok."
    } ]
  }, {
    "tStartMs": 800891,
    "dDurationMs": 4834,
    "segs": [ {
      "utf8": "I think the best thing is for you to take a taxi to\nthe station... and then get the train to the airport."
    } ]
  }, {
    "tStartMs": 805725,
    "dDurationMs": 606,
    "segs": [ {
      "utf8": "No problem."
    } ]
  }, {
    "tStartMs": 806973,
    "dDurationMs": 1146,
    "segs": [ {
      "utf8": "I'll call a taxi."
    } ]
  }, {
    "tStartMs": 809774,
    "dDurationMs": 2539,
    "segs": [ {
      "utf8": "Well, thanks for everything."
    } ]
  }, {
    "tStartMs": 812825,
    "dDurationMs": 2366,
    "segs": [ {
      "utf8": "No, listen. I'll meet you at the airport."
    } ]
  }, {
    "tStartMs": 815191,
    "dDurationMs": 1395,
    "segs": [ {
      "utf8": "We can say goodbye there."
    } ]
  }, {
    "tStartMs": 816586,
    "dDurationMs": 475,
    "segs": [ {
      "utf8": "All right."
    } ]
  }, {
    "tStartMs": 817591,
    "dDurationMs": 994,
    "segs": [ {
      "utf8": "Where can we meet?"
    } ]
  }, {
    "tStartMs": 819061,
    "dDurationMs": 1579,
    "segs": [ {
      "utf8": "At the information desk."
    } ]
  }, {
    "tStartMs": 821061,
    "dDurationMs": 1685,
    "segs": [ {
      "utf8": "Ok. See you there."
    } ]
  }, {
    "tStartMs": 822746,
    "dDurationMs": 925,
    "segs": [ {
      "utf8": "Bye."
    } ]
  }, {
    "tStartMs": 824311,
    "dDurationMs": 1796,
    "segs": [ {
      "utf8": "Excuse me! Change of plan."
    } ]
  }, {
    "tStartMs": 826107,
    "dDurationMs": 2588,
    "segs": [ {
      "utf8": "Could you call me a taxi please to the station?"
    } ]
  }, {
    "tStartMs": 837679,
    "dDurationMs": 4565,
    "segs": [ {
      "utf8": "Hello. Sorry I can't take your call.\nPlease leave a message after the tone."
    } ]
  }, {
    "tStartMs": 842244,
    "dDurationMs": 1898,
    "segs": [ {
      "utf8": "Hi, Allie. This is Mark."
    } ]
  }, {
    "tStartMs": 844523,
    "dDurationMs": 1034,
    "segs": [ {
      "utf8": "Where are you?"
    } ]
  }, {
    "tStartMs": 846372,
    "dDurationMs": 4457,
    "segs": [ {
      "utf8": "I'm at the information desk.\nMy flight leaves in 40 minutes."
    } ]
  }, {
    "tStartMs": 851202,
    "dDurationMs": 1035,
    "segs": [ {
      "utf8": "Mark! Mark!"
    } ]
  }, {
    "tStartMs": 852719,
    "dDurationMs": 1036,
    "segs": [ {
      "utf8": "Sorry I'm late!"
    } ]
  }, {
    "tStartMs": 853755,
    "dDurationMs": 2084,
    "segs": [ {
      "utf8": "Don't worry. I'm just happy you got here."
    } ]
  }, {
    "tStartMs": 856159,
    "dDurationMs": 1856,
    "segs": [ {
      "utf8": "Come on. You're gonna miss your flight."
    } ]
  }, {
    "tStartMs": 858015,
    "dDurationMs": 815,
    "segs": [ {
      "utf8": "Wait a minute."
    } ]
  }, {
    "tStartMs": 859421,
    "dDurationMs": 1945,
    "segs": [ {
      "utf8": "Are you going to come to the\nconference in California?"
    } ]
  }, {
    "tStartMs": 861366,
    "dDurationMs": 1195,
    "segs": [ {
      "utf8": "Am I going to see you, again?"
    } ]
  }, {
    "tStartMs": 862926,
    "dDurationMs": 1576,
    "segs": [ {
      "utf8": "The plane's going to leave without you."
    } ]
  }, {
    "tStartMs": 864502,
    "dDurationMs": 577,
    "segs": [ {
      "utf8": "Allie?"
    } ]
  }, {
    "tStartMs": 865189,
    "dDurationMs": 3231,
    "segs": [ {
      "utf8": "I asked my boss this morning and he said yes. I can go!"
    } ]
  }, {
    "tStartMs": 868420,
    "dDurationMs": 645,
    "segs": [ {
      "utf8": "Great!"
    } ]
  }, {
    "tStartMs": 869378,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "I don't have your home phone number."
    } ]
  }, {
    "tStartMs": 871047,
    "dDurationMs": 1949,
    "segs": [ {
      "utf8": "Don't worry. I'll email it to you tomorrow."
    } ]
  }, {
    "tStartMs": 873998,
    "dDurationMs": 4677,
    "segs": [ {
      "utf8": "This is the final call for all passengers\non flight BA287 to San Francisco."
    } ]
  }, {
    "tStartMs": 878675,
    "dDurationMs": 2533,
    "segs": [ {
      "utf8": "Please proceed immediately to Gate 12."
    } ]
  }, {
    "tStartMs": 882695,
    "dDurationMs": 909,
    "segs": [ {
      "utf8": "Goodbye, Allie."
    } ]
  }, {
    "tStartMs": 883604,
    "dDurationMs": 820,
    "segs": [ {
      "utf8": "And..."
    } ]
  }, {
    "tStartMs": 885942,
    "dDurationMs": 1129,
    "segs": [ {
      "utf8": "...thanks for everything."
    } ]
  }, {
    "tStartMs": 887447,
    "dDurationMs": 996,
    "segs": [ {
      "utf8": "Goodbye, Mark."
    } ]
  }, {
    "tStartMs": 890903,
    "dDurationMs": 988,
    "segs": [ {
      "utf8": "Have a safe trip!"
    } ]
  }, {
    "tStartMs": 892854,
    "dDurationMs": 1044,
    "segs": [ {
      "utf8": "See you in California."
    } ]
  }, {
    "tStartMs": 897074,
    "dDurationMs": 1384,
    "segs": [ {
      "utf8": "Bye."
    } ]
  } ]
}
