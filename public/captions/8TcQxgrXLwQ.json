  }, {
    "tStartMs": 295829,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "Told you -- classic rom-com."
    } ]
  }, {
    "tStartMs": 297431,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "Before you get married, you\nhave to sing to your fiancée."
    } ]
  }, {
    "tStartMs": 299533,
    "dDurationMs": 2536,
    "segs": [ {
      "utf8": "And after you serenade them,\nall wrongs are forgiven."
    } ]
  }, {
    "tStartMs": 302069,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "So you know those times\nthat you didn't notice a haircut"
    } ]
  }, {
    "tStartMs": 304238,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "or take out the trash\nfor three weeks,"
    } ]
  }, {
    "tStartMs": 305939,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "now that I've sung to you\nso beautifully,"
    } ]
  }, {
    "tStartMs": 307641,
    "dDurationMs": 2236,
    "segs": [ {
      "utf8": "you have to forget all\nof my nonsense and forgive me."
    } ]
  }, {
    "tStartMs": 309877,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "-And just forgive\nand just love, yeah."
    } ]
  }, {
    "tStartMs": 311345,
    "dDurationMs": 2302,
    "segs": [ {
      "utf8": "-Lads, serenade your ladies.\n-I think --"
    } ]
  }, {
    "tStartMs": 313647,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "Yeah.\n-Can't lose."
    } ]
  }, {
    "tStartMs": 315215,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "-But between this film\nand \"Bridgerton,\""
    } ]
  }, {
    "tStartMs": 316950,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "you've had a lot\nof experience with romance."
    } ]
  }, {
    "tStartMs": 319620,
    "dDurationMs": 2402,
    "segs": [ {
      "utf8": "I mean, you're pretty --\n[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 324258,
    "dDurationMs": 1901,
    "segs": [ {
      "utf8": "I was thinking\nthat anything that you --"
