  }, {
    "tStartMs": 483250,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "♪ I will get you for that ♪"
    } ]
  }, {
    "tStartMs": 484718,
    "dDurationMs": 1935,
    "segs": [ {
      "utf8": "-That's how you do it.\n[ Laughs ]"
