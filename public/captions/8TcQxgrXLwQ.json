    "tStartMs": 509309,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "-This place is really cool, man."
    } ]
  }, {
    "tStartMs": 512145,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "-Well, I run it\nthe old-fashioned way."
    } ]
  }, {
    "tStartMs": 514648,
    "dDurationMs": 2135,
    "segs": [ {
      "utf8": "These barrels have been here\nsince the 18th century."
