  }, {
    "tStartMs": 490324,
    "dDurationMs": 2702,
    "segs": [ {
      "utf8": "in \"You, Me \u0026 Tuscany.\"\nTake a look."
    } ]
  }, {
    "tStartMs": 493026,
    "dDurationMs": 2670,
    "segs": [ {
      "utf8": "-I took a sommelier class\nin culinary school."
    } ]
  }, {
    "tStartMs": 495696,
    "dDurationMs": 1868,
    "segs": [ {
      "utf8": "-Okay.\nSo you're a chef?"
