  }, {
    "tStartMs": 397531,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "Do we have this one\nwritten down?"
    } ]
  }, {
    "tStartMs": 398966,
    "dDurationMs": 3303,
    "segs": [ {
      "utf8": "Do you know \"On Top --\"\n\"On Top of Old Smoky\"?"
    } ]
  }, {
    "tStartMs": 402269,
    "dDurationMs": 3904,
    "segs": [ {
      "utf8": "-Yeah. Kinda.\n-Okay. Give it your best."
    } ]
  }, {
    "tStartMs": 406173,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "\"On Top of Old Smoky.\""
    } ]
  }, {
    "tStartMs": 407674,
    "dDurationMs": 1836,
    "segs": [ {
      "utf8": "♪♪"
    } ]
  }, {
    "tStartMs": 409510,
    "dDurationMs": 7173,
    "segs": [ {
      "utf8": "-♪ On top of Old Smoky ♪"
    } ]
  }, {
    "tStartMs": 416683,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 418852,
    "dDurationMs": 4071,
    "segs": [ {
      "utf8": "♪ Baby girl,\nI want you all covered in snow ♪"
    } ]
  }, {
    "tStartMs": 422923,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "-Oh, my God!"
    } ]
  }, {
    "tStartMs": 424558,
