  "events": [ {
    "tStartMs": 1368,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "-Welcome back."
    } ]
  }, {
    "tStartMs": 2536,
    "dDurationMs": 1268,
    "segs": [ {
      "utf8": "Man, we have\na good-looking show tonight."
    } ]
  }, {
    "tStartMs": 3804,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "Oh, my gosh.\n-Oww!"
    } ]
  }, {
    "tStartMs": 5873,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "-Yeah, oww!\n[ Cheering ]"
    } ]
  }, {
    "tStartMs": 7708,
    "dDurationMs": 3236,
    "segs": [ {
      "utf8": "I'm sorry. Sorry!\nHad to get a couple..."
    } ]
  }, {
    "tStartMs": 10944,
    "dDurationMs": 2570,
    "segs": [ {
      "utf8": "Had to get a couple of \"owws\"\nout there. Sorry."
    } ]
  }, {
    "tStartMs": 13514,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "-It's good-looking\n'cause all of y'all are here."
    } ]
  }, {
    "tStartMs": 14882,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "That's why it's so good-looking.\n-Exactly."
    } ]
  }, {
    "tStartMs": 16717,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "-Incredibly good-looking crowd."
    } ]
  }, {
    "tStartMs": 18418,
    "dDurationMs": 1936,
    "segs": [ {
      "utf8": "-No. I want to get into\nso many things."
    } ]
  }, {
    "tStartMs": 20354,
    "dDurationMs": 1868,
    "segs": [ {
      "utf8": "I want to get into\n\"You, Me \u0026 Tuscany.\""
    } ]
  }, {
    "tStartMs": 22222,
    "dDurationMs": 3037,
    "segs": [ {
      "utf8": "I want to talk about you\ngoing back to the West End."
    } ]
  }, {
    "tStartMs": 25259,
    "dDurationMs": 1534,
    "segs": [ {
      "utf8": "You're gonna do theater.\n-Yep, yep."
    } ]
  }, {
    "tStartMs": 26793,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "I'm going back to theater.\nWe're doing \"Gatsby.\""
    } ]
  }, {
    "tStartMs": 28795,
    "dDurationMs": 1268,
    "segs": [ {
      "utf8": "-\"The Great Gatsby.\"\n[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 30063,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "-But of \"Gatsby,\" yeah.\nIt should be a lot of fun."
    } ]
  }, {
    "tStartMs": 32065,
    "dDurationMs": 1569,
    "segs": [ {
      "utf8": "-You started in theater."
    } ]
  }, {
    "tStartMs": 33634,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "Why do you like theater?\nDo you like..."
    } ]
  }, {
    "tStartMs": 35536,
    "dDurationMs": 1267,
    "segs": [ {
      "utf8": "-I like that anything\ncan happen."
    } ]
  }, {
    "tStartMs": 36803,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "You need that adrenaline shock."
    } ]
  }, {
    "tStartMs": 38238,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "You need that moment\nwith the crowd."
    } ]
  }, {
    "tStartMs": 39673,
    "dDurationMs": 1235,
    "segs": [ {
      "utf8": "You know what I mean?\n-Yeah. There's nothing like it."
    } ]
  }, {
    "tStartMs": 40908,
    "dDurationMs": 2235,
    "segs": [ {
      "utf8": "One of the first jobs\nI ever did,"
    } ]
  }, {
    "tStartMs": 43143,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "I was on The Globe,\nin the West End, in London."
    } ]
  }, {
    "tStartMs": 44711,
    "dDurationMs": 1135,
    "segs": [ {
      "utf8": "We're doing\n\"The Merchant of Venice.\""
    } ]
  }, {
    "tStartMs": 45846,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "-The Globe Theatre.\nThe Globe Theatre."
    } ]
  }, {
    "tStartMs": 47214,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "Thousand people every night."
    } ]
  }, {
    "tStartMs": 48949,
    "dDurationMs": 1134,
    "segs": [ {
      "utf8": "-Shakespeare.\n-Shakespeare."
    } ]
  }, {
    "tStartMs": 50083,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "-Oh, yeah."
    } ]
  }, {
    "tStartMs": 51451,
    "dDurationMs": 1302,
    "segs": [ {
      "utf8": "-Feels like a rock concert\nin that venue, by the way,"
    } ]
  }, {
    "tStartMs": 52753,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "'cause you got, like,\na standing crowd down below,"
    } ]
  }, {
    "tStartMs": 54154,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "you got, like,\nall the posh seats up top."
    } ]
  }, {
    "tStartMs": 55622,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "And so, you know,\nall you got to do"
    } ]
  }, {
    "tStartMs": 57157,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "is not mess up in Shakespearean,\nright?"
    } ]
  }, {
    "tStartMs": 59059,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "I definitely wasn't --\nIt was a work-experience job."
    } ]
  }, {
    "tStartMs": 61061,
    "dDurationMs": 2402,
    "segs": [ {
      "utf8": "So, like, I have like one\nspeech, deliver a letter, FO."
    } ]
  }, {
    "tStartMs": 63463,
    "dDurationMs": 1469,
    "segs": [ {
      "utf8": "Easy.\n-Okay."
    } ]
  }, {
    "tStartMs": 64932,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "-I deliver my speech,\nI walk out, proud as punch,"
    } ]
  }, {
    "tStartMs": 67601,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "It's a long old walk,\nput my hand into my pouch,"
    } ]
  }, {
    "tStartMs": 70437,
    "dDurationMs": 1969,
    "segs": [ {
      "utf8": "there's no letter.\nNo letter whatsoever."
    } ]
  }, {
    "tStartMs": 72406,
    "dDurationMs": 1868,
    "segs": [ {
      "utf8": "-That's your only job is\nto deliver the letter."
    } ]
  }, {
    "tStartMs": 74274,
    "dDurationMs": 2903,
    "segs": [ {
      "utf8": "-My only -- one and only job.\nI go completely gray."
    } ]
  }, {
    "tStartMs": 77177,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "And the dude that\nI had to give the letter to,"
    } ]
  }, {
    "tStartMs": 78879,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "by the way,\ndoes not know his lines."
    } ]
  }, {
    "tStartMs": 80380,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "They are written in the letter."
    } ]
  }, {
    "tStartMs": 82015,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ]
  }, {
    "tStartMs": 83817,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "And so now you got -- you\ngot to improv in Shakespearean."
    } ]
  }, {
    "tStartMs": 85986,
    "dDurationMs": 4404,
    "segs": [ {
      "utf8": "It's like, \"Thine letter,\nwhich I doth not have...\""
    } ]
  }, {
    "tStartMs": 90390,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "[ Laughter ]\n-Oh, my God!"
    } ]
  }, {
    "tStartMs": 91892,
    "dDurationMs": 1134,
    "segs": [ {
      "utf8": "You have to improvise --"
    } ]
  }, {
    "tStartMs": 93026,
    "dDurationMs": 1969,
    "segs": [ {
      "utf8": "-\"...is in yonder carriage.\"\n[ Laughter ]"
    } ]
  }, {
    "tStartMs": 94995,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "\"Someone shall fetch it\nforthwith for this dude.\""
    } ]
  }, {
    "tStartMs": 98665,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "-Oh, my God.\n-He was like, \"What does"
    } ]
  }, {
    "tStartMs": 100100,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "thou mean thou\ndost not have my letter?"
    } ]
  }, {
    "tStartMs": 101602,
    "dDurationMs": 1801,
    "segs": [ {
      "utf8": "I do not know --\ndoth not know mine lines.\""
    } ]
  }, {
    "tStartMs": 103403,
    "dDurationMs": 2103,
    "segs": [ {
      "utf8": "I'm like, \"Dude, I don't know\nwhat you wanteth me to say."
    } ]
  }, {
    "tStartMs": 105506,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "It ain't here.\"\n[ Laughter ]"
    } ]
  }, {
    "tStartMs": 106874,
    "dDurationMs": 3236,
    "segs": [ {
      "utf8": "-\"Sorry, dudeth.\nI must go off stageth"
    } ]
  }, {
    "tStartMs": 110110,
    "dDurationMs": 3070,
    "segs": [ {
      "utf8": "and cometh back with letter.\"\n-\"Goodeth luck.\""
    } ]
  }, {
    "tStartMs": 113180,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "[ Laughter ]\n-Yeah."
    } ]
  }, {
    "tStartMs": 114515,
    "dDurationMs": 1768,
    "segs": [ {
      "utf8": "Is kind of how that went.\n-What ended up happening?"
    } ]
  }, {
    "tStartMs": 116283,
    "dDurationMs": 2369,
    "segs": [ {
      "utf8": "-Uh, he made it --\nI think someone"
    } ]
  }, {
    "tStartMs": 118652,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "heard my pleas from off stage."
    } ]
  }, {
    "tStartMs": 120387,
    "dDurationMs": 2769,
    "segs": [ {
      "utf8": "Someone else turned up with,\n\"Thine letter is here, my lord.\""
    } ]
  }, {
    "tStartMs": 123156,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "-Oh, my God.\n[ Laughter ]"
    } ]
  }, {
    "tStartMs": 124791,
    "dDurationMs": 1469,
    "segs": [ {
      "utf8": "-He's like,\n\"Get the...out of here.\""
    } ]
  }, {
    "tStartMs": 126260,
    "dDurationMs": 1134,
    "segs": [ {
      "utf8": "-Yes. Oh.\n-\"You.\""
    } ]
  }, {
    "tStartMs": 127394,
    "dDurationMs": 1935,
    "segs": [ {
      "utf8": "-That's a baptism\nby fire right there."
    } ]
  }, {
    "tStartMs": 129329,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "-Yeah, but you get\nthat adrenaline kick."
    } ]
  }, {
    "tStartMs": 131231,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "And, also, the fact that we\nhad to work that out together,"
    } ]
  }, {
    "tStartMs": 133300,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "that's -- when people\ntalk about chemistry on screen"
    } ]
  }, {
    "tStartMs": 135636,
    "dDurationMs": 2168,
    "segs": [ {
      "utf8": "and on stage,\nthose unexpected moments,"
    } ]
  }, {
    "tStartMs": 137804,
    "dDurationMs": 1135,
    "segs": [ {
      "utf8": "that's chemistry,\n'cause that's the reaction."
    } ]
  }, {
    "tStartMs": 138939,
    "dDurationMs": 2402,
    "segs": [ {
      "utf8": "-I know you were great on \"SNL.\""
    } ]
  }, {
    "tStartMs": 141341,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "You were great on \"SNL UK,\"\nby the way."
    } ]
  }, {
    "tStartMs": 142976,
    "dDurationMs": 2903,
    "segs": [ {
      "utf8": "-Yes, we did \"SNL UK\" last week.\n-What was it like?"
    } ]
  }, {
    "tStartMs": 145879,
    "dDurationMs": 1669,
    "segs": [ {
      "utf8": "-It was amazing.\nYeah, you could cheer the Brits."
    } ]
  }, {
    "tStartMs": 147548,
    "dDurationMs": 1801,
    "segs": [ {
      "utf8": "[ Cheers and applause ]\nYou can cheer the Brits."
    } ]
  }, {
    "tStartMs": 149349,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "-That's fantastic.\nIt was a big hit."
    } ]
  }, {
    "tStartMs": 151218,
    "dDurationMs": 1234,
    "segs": [ {
      "utf8": "-Tina Fey was hosting,"
    } ]
  }, {
    "tStartMs": 152452,
    "dDurationMs": 1202,
    "segs": [ {
      "utf8": "so we had a little bit\nof American help."
    } ]
  }, {
    "tStartMs": 153654,
    "dDurationMs": 1234,
    "segs": [ {
      "utf8": "Do you feel better\nabout cheering that?"
    } ]
  }, {
    "tStartMs": 154888,
    "dDurationMs": 1302,
    "segs": [ {
      "utf8": "-Yeah. There you go.\nWe love Tina Fey."
    } ]
  }, {
    "tStartMs": 156190,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "Yeah, yeah, yeah.\n-She was fantastic."
    } ]
  }, {
    "tStartMs": 158025,
    "dDurationMs": 1134,
    "segs": [ {
      "utf8": "It was a lifetime moment\nfor me, working with Tina,"
    } ]
  }, {
    "tStartMs": 159159,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "which is lovely.\nWe got to share a skit."
    } ]
  }, {
    "tStartMs": 161228,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "And it feels like coming home,\n'cause it is live."
    } ]
  }, {
    "tStartMs": 163230,
    "dDurationMs": 2469,
    "segs": [ {
      "utf8": "Folks forget that\nthe L in \"SNL\" is \"live.\""
    } ]
  }, {
    "tStartMs": 165699,
    "dDurationMs": 1101,
    "segs": [ {
      "utf8": "-Yeah, of course.\nBut you've done"
    } ]
  }, {
    "tStartMs": 166800,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "\"Saturday Night Live\"\nin the States."
    } ]
  }, {
    "tStartMs": 168235,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "-Yeah, did it here first.\n-I remember that."
    } ]
  }, {
    "tStartMs": 169703,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "Back in February 2021."
    } ]
  }, {
    "tStartMs": 171405,
    "dDurationMs": 1301,
    "segs": [ {
      "utf8": "-Did it feel\nlike the same magic?"
    } ]
  }, {
    "tStartMs": 172706,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "-Incredible. Well, also\nbecause we were deep in COVID,"
    } ]
  }, {
    "tStartMs": 174508,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "so I was desperate for\nhuman connection at that point."
    } ]
  }, {
    "tStartMs": 176677,
    "dDurationMs": 2435,
    "segs": [ {
      "utf8": "I hadn't seen a person,\nnever mind a live audience."
    } ]
  }, {
    "tStartMs": 179112,
    "dDurationMs": 1836,
    "segs": [ {
      "utf8": "So I started -- I started\nmessing around a little bit."
    } ]
  }, {
    "tStartMs": 180948,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "You know when you\nget in front of an audience"
    } ]
  }, {
    "tStartMs": 182416,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "and the devil gets you\na little bit?"
    } ]
  }, {
    "tStartMs": 184151,
    "dDurationMs": 2302,
    "segs": [ {
      "utf8": "-No. No, I don't know\nwhat that means at all."
    } ]
  }, {
    "tStartMs": 186453,
    "dDurationMs": 2035,
    "segs": [ {
      "utf8": "No.\n-Devil in your eyes right now."
    } ]
  }, {
    "tStartMs": 188488,
    "dDurationMs": 1736,
    "segs": [ {
      "utf8": "-I'm like, \"How could\nI mess this interview up?\""
    } ]
  }, {
    "tStartMs": 190224,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "Yeah, I know, I know."
    } ]
  }, {
    "tStartMs": 191892,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "-That's what I love\nabout theater."
    } ]
  }, {
    "tStartMs": 193427,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "So, like, I started riffing\nwith the crowd between takes."
    } ]
  }, {
    "tStartMs": 195128,
    "dDurationMs": 1569,
    "segs": [ {
      "utf8": "And I remember Kenan\nkind of turned to me --"
    } ]
  }, {
    "tStartMs": 196697,
    "dDurationMs": 1601,
    "segs": [ {
      "utf8": "Because they were exhausted."
    } ]
  }, {
    "tStartMs": 198298,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "They were in like week six\nin the middle of the pandemic."
    } ]
  }, {
    "tStartMs": 199800,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "He was like, \"Okay, kid.\""
    } ]
  }, {
    "tStartMs": 201468,
    "dDurationMs": 1402,
    "segs": [ {
      "utf8": "-Yes, \"Let's go.\nWe're having fun.\""
    } ]
  }, {
    "tStartMs": 202870,
    "dDurationMs": 1101,
    "segs": [ {
      "utf8": "-You keep folks warm. This is --"
    } ]
  }, {
    "tStartMs": 203971,
    "dDurationMs": 1301,
    "segs": [ {
      "utf8": "It reminded me of being\nin a band."
    } ]
  }, {
    "tStartMs": 205272,
    "dDurationMs": 1301,
    "segs": [ {
      "utf8": "Like, when your guitarist\nis tuning up,"
    } ]
  }, {
    "tStartMs": 206573,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "you tell some jokes\nto the crowd."
    } ]
  }, {
    "tStartMs": 208175,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "Try not to annoy\nKenan Thompson too much."
    } ]
  }, {
    "tStartMs": 210244,
    "dDurationMs": 2235,
    "segs": [ {
      "utf8": "-No, yeah, you won't.\nLet's talk about your film,"
    } ]
  }, {
    "tStartMs": 212479,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "\"You, Me \u0026 Tuscany.\""
    } ]
  }, {
    "tStartMs": 214081,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "How do we set up\nwhat it's about?"
    } ]
  }, {
    "tStartMs": 216083,
    "dDurationMs": 4471,
    "segs": [ {
      "utf8": "-Ah, it is a classic feel-good,\nuncynical, joyous rom-com."
    } ]
  }, {
    "tStartMs": 220554,
    "dDurationMs": 1601,
    "segs": [ {
      "utf8": "-Yes! That's what we want!"
    } ]
  }, {
    "tStartMs": 222155,
    "dDurationMs": 2103,
    "segs": [ {
      "utf8": "[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 224258,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "-You know,\nit knows exactly what it is."
    } ]
  }, {
    "tStartMs": 226527,
    "dDurationMs": 2068,
    "segs": [ {
      "utf8": "We're here to give you\na good time in the theater."
    } ]
  }, {
    "tStartMs": 228595,
    "dDurationMs": 2569,
    "segs": [ {
      "utf8": "-The romantic comedy is having\na great comeback, which I love."
    } ]
  }, {
    "tStartMs": 231164,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "\"People We Meet on Vacation\"\nwas great."
    } ]
  }, {
    "tStartMs": 232866,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "I know the Sydney Sweeney,\nGlen Powell was a big hit."
    } ]
  }, {
    "tStartMs": 235135,
    "dDurationMs": 1969,
    "segs": [ {
      "utf8": "And now you.\nThis is good."
    } ]
  }, {
    "tStartMs": 237104,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "It's you.\nYou're in Italy."
    } ]
  }, {
    "tStartMs": 238438,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "-I'm in Italy with Halle Bailey,\none of the greatest..."
    } ]
  }, {
    "tStartMs": 240240,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "-Halle Bailey.\n-Thank you."
    } ]
  }, {
    "tStartMs": 242309,
    "dDurationMs": 2870,
    "segs": [ {
      "utf8": "-By the way, she's...\n-The People's Mermaid."
    } ]
  }, {
    "tStartMs": 245179,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "-That's right.\nBy the way, she can sing, too."
    } ]
  }, {
    "tStartMs": 247014,
    "dDurationMs": 1234,
    "segs": [ {
      "utf8": "-She's incredible."
    } ]
  }, {
    "tStartMs": 248248,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "She's one of the best singers\non the planet."
    } ]
  }, {
    "tStartMs": 249683,
    "dDurationMs": 3770,
    "segs": [ {
      "utf8": "I maintain that, genuinely.\nHer technique is untouchable."
    } ]
  }, {
    "tStartMs": 253453,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "-Yeah.\n-Have you ever met her?"
    } ]
  }, {
    "tStartMs": 255088,
    "dDurationMs": 1235,
    "segs": [ {
      "utf8": "-Yeah, absolutely."
    } ]
  }, {
    "tStartMs": 256323,
    "dDurationMs": 1268,
    "segs": [ {
      "utf8": "-Genuine, real-life\nDisney princess, right?"
    } ]
  }, {
    "tStartMs": 257591,
    "dDurationMs": 2703,
    "segs": [ {
      "utf8": "-She actually is.\n-She walks by and flowers bloom,"
    } ]
  }, {
    "tStartMs": 260294,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "the sun rises.\n-Yes. It's a cartoon."
    } ]
  }, {
    "tStartMs": 262296,
    "dDurationMs": 2235,
    "segs": [ {
      "utf8": "-Ridiculous. Birds land\non her finger, you know?"
    } ]
  }, {
    "tStartMs": 264531,
    "dDurationMs": 2903,
    "segs": [ {
      "utf8": "-Yeah. But you have\nto serenade her in front of her."
    } ]
  }, {
    "tStartMs": 267434,
    "dDurationMs": 1402,
    "segs": [ {
      "utf8": "-I do.\n-That's pressure right there."
    } ]
  }, {
    "tStartMs": 268836,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "-Little bit of pressure."
    } ]
  }, {
    "tStartMs": 270404,
    "dDurationMs": 1201,
    "segs": [ {
      "utf8": "There's a moment in the script,\nyou open it up, and it's like,"
    } ]
  }, {
    "tStartMs": 271605,
    "dDurationMs": 1068,
    "segs": [ {
      "utf8": "\"We need you to sing in front of"
    } ]
  }, {
    "tStartMs": 272673,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "one of the world's\ngreatest singers."
    } ]
  }, {
    "tStartMs": 274074,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "No accompaniment,\nno notes, no nothing."
    } ]
  }, {
    "tStartMs": 276076,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "Just charm this woman\nwith a smile"
