    "segs": [ {
      "utf8": "[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 427261,
    "dDurationMs": 2869,
    "segs": [ {
      "utf8": "Last one, last one,\nlast one, last one, last one."
