  }, {
    "tStartMs": 326159,
    "dDurationMs": 2269,
    "segs": [ {
      "utf8": "you could say anything\nand make it sound romantic,"
    } ]
  }, {
    "tStartMs": 328428,
    "dDurationMs": 2770,
    "segs": [ {
      "utf8": "and I thought it'd be\nkind of fun"
