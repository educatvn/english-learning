    "segs": [ {
      "utf8": "♪ Take me out with that crowd ♪"
    } ]
  }, {
    "tStartMs": 387621,
    "dDurationMs": 3303,
    "segs": [ {
      "utf8": "[ Cheering ]"
    } ]
  }, {
    "tStartMs": 390924,
    "dDurationMs": 3203,
    "segs": [ {
      "utf8": "-Stop, stop. That's good.\nThat's good."
    } ]
  }, {
    "tStartMs": 394127,
    "dDurationMs": 1569,
    "segs": [ {
      "utf8": "But let's up it.\nLet's up it one now."
    } ]
  }, {
    "tStartMs": 395696,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "Step it up.\nHow about -- do we have --"
