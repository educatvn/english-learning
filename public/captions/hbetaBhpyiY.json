    },
    {
      "tStartMs": 513740,
      "dDurationMs": 4260,
      "segs": [
        {
          "utf8": "the gender identity of young people\nin the school, in the university."
        }
      ]
    },
    {
      "tStartMs": 518000,
      "dDurationMs": 2380,
      "segs": [
        {
          "utf8": "So for me,\nI would say the married law"
        }
      ]
    },
    {
      "tStartMs": 520380,
      "dDurationMs": 3780,
      "segs": [
        {
          "utf8": "just simply directly support\nthe right of the same sex couple,"
