  "events": [
    {
      "tStartMs": 120,
      "dDurationMs": 3100,
      "segs": [
        {
          "utf8": "Thailand has become the first country\nin Southeast Asia"
        }
      ]
    },
    {
      "tStartMs": 3220,
      "dDurationMs": 2060,
      "segs": [
        {
          "utf8": "to legalize same sex marriage."
        }
      ]
    },
    {
      "tStartMs": 5280,
      "dDurationMs": 3480,
      "segs": [
        {
          "utf8": "This new law means that same\nsex couples will have the same rights"
        }
      ]
    },
    {
      "tStartMs": 8760,
      "dDurationMs": 2880,
      "segs": [
        {
          "utf8": "as other couples when it comes\nto things like adoption,"
        }
      ]
    },
    {
      "tStartMs": 11640,
      "dDurationMs": 2080,
      "segs": [
        {
          "utf8": "inheritance, and medical decisions."
        }
      ]
    },
    {
      "tStartMs": 13720,
      "dDurationMs": 3900,
      "segs": [
        {
          "utf8": "And it's taken activists years\nof campaigning to get to this point."
        }
      ]
    },
    {
      "tStartMs": 17620,
      "dDurationMs": 3540,
      "segs": [
        {
          "utf8": "In September, Thailand's King\nfinally signed it into law."
        }
      ]
    },
    {
      "tStartMs": 21160,
      "dDurationMs": 3860,
      "segs": [
        {
          "utf8": "So today, you are going to hear\nfrom an activist who campaigns"
