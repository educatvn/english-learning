      ]
    },
    {
      "tStartMs": 550480,
      "dDurationMs": 3620,
      "segs": [
        {
          "utf8": "between religion and LGBTQ+ groups\nin Thailand?"
        }
      ]
    },
    {
      "tStartMs": 554100,
      "dDurationMs": 4440,
      "segs": [
        {
          "utf8": "Buddhism is actually one\nof the aspect that allowed\nThailand to be where we are today."
        }
      ]
    },
    {
      "tStartMs": 558540,
      "dDurationMs": 2460,
      "segs": [
        {
          "utf8": "That being quite an inclusivity,"
        }
      ]
    },
