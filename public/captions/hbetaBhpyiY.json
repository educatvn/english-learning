    {
      "tStartMs": 633300,
      "dDurationMs": 4200,
      "segs": [
        {
          "utf8": "Nepal registered its first\nsame sex union in November last year,"
        }
      ]
    },
    {
      "tStartMs": 637500,
      "dDurationMs": 3920,
      "segs": [
        {
          "utf8": "and that was five months after the\nSupreme Court ruled in favour of it."
        }
      ]
    },
    {
      "tStartMs": 641420,
      "dDurationMs": 3680,
      "segs": [
        {
          "utf8": "Do you think,\nfollowing Thailand's new law,"
