    },
    {
      "tStartMs": 586560,
      "dDurationMs": 2160,
      "segs": [
        {
          "utf8": "or being non-binary.\nBut that's the only thing."
        }
      ]
    },
    {
      "tStartMs": 588720,
      "dDurationMs": 3040,
      "segs": [
        {
          "utf8": "If you're going to live\nyour normal life, that is okay."
        }
      ]
    },
    {
      "tStartMs": 591760,
      "dDurationMs": 5160,
      "segs": [
        {
          "utf8": "So in this sense, being Buddhism\nand Thailand being Buddhism, allow"
