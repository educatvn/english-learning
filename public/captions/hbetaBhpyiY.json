    },
    {
      "tStartMs": 530720,
      "dDurationMs": 5040,
      "segs": [
        {
          "utf8": "And this highlight that we need other\ncomprehensive law and, you know,"
        }
      ]
    },
    {
      "tStartMs": 535760,
      "dDurationMs": 3700,
      "segs": [
        {
          "utf8": "protection in terms of policy,\neducational policy"
