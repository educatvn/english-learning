    {
      "tStartMs": 25020,
      "dDurationMs": 2560,
      "segs": [
        {
          "utf8": "for LGBTQ+ rights in Thailand"
        }
      ]
    },
    {
      "tStartMs": 27580,
      "dDurationMs": 4160,
      "segs": [
        {
          "utf8": "and find out what this new law is\ngoing to mean for same sex couples."
        }
      ]
    },
    {
      "tStartMs": 31740,
      "dDurationMs": 5100,
      "segs": [
        {
          "utf8": "I'm Hannah Gelbart, and this is What\nin the World from the BBC World Service."
        }
      ]
    },
    {
      "tStartMs": 39580,
      "dDurationMs": 2340,
      "segs": [
        {
          "utf8": "To explain\nThailand's marriage equality bill,"
