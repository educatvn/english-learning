    {
      "tStartMs": 482740,
      "dDurationMs": 3160,
      "segs": [
        {
          "utf8": "But as I say,\nyou know, there are still some"
        }
      ]
    },
    {
      "tStartMs": 485900,
      "dDurationMs": 5520,
      "segs": [
        {
          "utf8": "of the people who are not really\nsupport, our cause, for example,"
        }
      ]
    },
