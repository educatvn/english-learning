    },
    {
      "tStartMs": 543000,
      "dDurationMs": 3140,
      "segs": [
        {
          "utf8": "Now, Thailand is mostly Buddhist,\nand I'm curious,"
        }
      ]
    },
    {
      "tStartMs": 546140,
      "dDurationMs": 4340,
      "segs": [
        {
          "utf8": "what does Buddhism say about being gay\nand what is that relationship like"
