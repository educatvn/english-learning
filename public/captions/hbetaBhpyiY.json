      "tStartMs": 403700,
      "dDurationMs": 4620,
      "segs": [
        {
          "utf8": "we don't see any people gonna go\non the street to protest on the bill."
        }
      ]
    },
    {
      "tStartMs": 408320,
      "dDurationMs": 1620,
      "segs": [
        {
          "utf8": "Panisa,\njust stay on the line for a minute."
