    },
    {
      "tStartMs": 41920,
      "dDurationMs": 3680,
      "segs": [
        {
          "utf8": "I'm speaking to Panisa Aemocha\na BBC reporter in Bangkok."
        }
      ]
    },
    {
      "tStartMs": 45600,
      "dDurationMs": 5700,
      "segs": [
        {
          "utf8": "Let me just get my headphones on.\nHi, Panisa."
