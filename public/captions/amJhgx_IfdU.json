  "events": [ {
    "tStartMs": 0,
    "dDurationMs": 7000,
    "segs": [ {
      "utf8": "Transcriber: Zigy Ale Pulache\nReviewer: Nguyen Thanh Thien DHCT"
    } ],
    "wpWinPosId": 1,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 6672,
    "dDurationMs": 2886,
    "segs": [ {
      "utf8": "Here's a concerning statistic for you all."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 10158,
    "dDurationMs": 6323,
    "segs": [ {
      "utf8": "50%. That's the percent of US\nemployees who are actively looking for"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 16515,
    "dDurationMs": 3687,
    "segs": [ {
      "utf8": "or interested in having\nnew jobs this year."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 21003,
    "dDurationMs": 3753,
    "segs": [ {
      "utf8": "Companies are struggling\nto retain top talent,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 25123,
    "dDurationMs": 1469,
    "segs": [ {
      "utf8": "and nearly two thirds"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 26592,
    "dDurationMs": 5055,
    "segs": [ {
      "utf8": "of HR leaders say that retention\nis a critical issue this year."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 32598,
    "dDurationMs": 5555,
    "segs": [ {
      "utf8": "But what if I told you that there’s a \nmassive workforce of incredibly skilled,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 38153,
    "dDurationMs": 4605,
    "segs": [ {
      "utf8": "loyal employees that most\ncompanies are undervaluing,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 43592,
    "dDurationMs": 5639,
    "segs": [ {
      "utf8": "causing them to mentally disengage\nor even physically leave the workplace?"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 50115,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "Well, who are they?"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 52200,
    "dDurationMs": 2353,
    "segs": [ {
      "utf8": "I want to introduce you all to Chelley."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 55320,
    "dDurationMs": 1885,
    "segs": [ {
      "utf8": "Chelley is 50 years old."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 57322,
    "dDurationMs": 2036,
    "segs": [ {
      "utf8": "She manages a team of 12"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 59358,
    "dDurationMs": 2986,
    "segs": [ {
      "utf8": "and she's been with her company\nfor over 20 years"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 62344,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "with consistently\ngreat performance reviews."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 66265,
    "dDurationMs": 4170,
    "segs": [ {
      "utf8": "But what Chelley’s boss doesn’t\nknow is that she also helps care"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 70435,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "for her 80 year old mother."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 72821,
    "dDurationMs": 3370,
    "segs": [ {
      "utf8": "Chelley takes her mom to her weekly\ndoctor’s appointment,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 76875,
    "dDurationMs": 2519,
    "segs": [ {
      "utf8": "shops for groceries a few times a week,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 80112,
    "dDurationMs": 3053,
    "segs": [ {
      "utf8": "and keeps her mother company\nas much as she's able to."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 84383,
    "dDurationMs": 2519,
    "segs": [ {
      "utf8": "And Chelley’s story isn’t unique."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 87953,
    "dDurationMs": 4554,
    "segs": [ {
      "utf8": "Chelley represents a massive shift\nhappening in the workforce right now,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 93141,
    "dDurationMs": 3687,
    "segs": [ {
      "utf8": "where women are remaining\nemployed and working longer,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 97462,
    "dDurationMs": 2686,
    "segs": [ {
      "utf8": "longer than they ever have in the past,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 100148,
    "dDurationMs": 5523,
    "segs": [ {
      "utf8": "which means that women are increasingly\nmanaging peak career responsibilities"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 106788,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "while also managing aging parents needs."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 110509,
    "dDurationMs": 5872,
    "segs": [ {
      "utf8": "Chelley is busy, but she’s just\none of 29 million Americans"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 116381,
    "dDurationMs": 3020,
    "segs": [ {
      "utf8": "who are balancing both paid employment"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 119401,
    "dDurationMs": 2519,
    "segs": [ {
      "utf8": "and caregiving for an older family member,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 122287,
    "dDurationMs": 2369,
    "segs": [ {
      "utf8": "and the majority of these folks are women."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 126241,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "As many of you likely\nknow from experience,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 130212,
    "dDurationMs": 5038,
    "segs": [ {
      "utf8": "combining work and caregiving\ncan be physically demanding,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 135684,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "financially draining,\nand emotionally challenging."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 140372,
    "dDurationMs": 3954,
    "segs": [ {
      "utf8": "Some women are forced to leave\nthe workforce entirely"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 144643,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "because their workplace simply can't\naccommodate their caregiving needs."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 149331,
    "dDurationMs": 5922,
    "segs": [ {
      "utf8": "This forced “opting out” of work\nsignificantly reduces a woman’s income"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 155604,
    "dDurationMs": 1885,
    "segs": [ {
      "utf8": "at a point when she needs it most."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 158690,
    "dDurationMs": 2603,
    "segs": [ {
      "utf8": "And for those who stay employed,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 161326,
    "dDurationMs": 3570,
    "segs": [ {
      "utf8": "many of these women will experience\nlower salary growth"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 164896,
    "dDurationMs": 4155,
    "segs": [ {
      "utf8": "and fewer advancement opportunities\nthan those who are not caregiving."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 170001,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "So either way you slice it,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 172204,
    "dDurationMs": 4638,
    "segs": [ {
      "utf8": "caregiving will threaten a women's\nfinancial security at a critical point"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 176842,
    "dDurationMs": 2869,
    "segs": [ {
      "utf8": "in their careers and with their families."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 181713,
    "dDurationMs": 6573,
    "segs": [ {
      "utf8": "But what most employers don’t realize is\nthat Chelley and the 29 million like her"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 188553,
    "dDurationMs": 3804,
    "segs": [ {
      "utf8": "bring exceptional skills\nthat companies desperately need."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 193275,
    "dDurationMs": 2436,
    "segs": [ {
      "utf8": "Managing a demanding career"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 195877,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "while also coordinating a family\nmember's complex care schedule"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 200365,
    "dDurationMs": 5589,
    "segs": [ {
      "utf8": "develops master multitaskers who are able\nto prioritize under pressure,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 206438,
    "dDurationMs": 6039,
    "segs": [ {
      "utf8": "coordinate across multiple stakeholders,\nand handle the unexpected with grace."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 213361,
    "dDurationMs": 5272,
    "segs": [ {
      "utf8": "And the numbers back this up.\nAccording to a recent report by AARP,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 219234,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "if caregivers received\ngreater workplace supports,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 222804,
    "dDurationMs": 5122,
    "segs": [ {
      "utf8": "GDP could increase by up to $1.7 trillion."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 228677,
    "dDurationMs": 2636,
    "segs": [ {
      "utf8": "That's the untapped value of caregivers."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 232481,
    "dDurationMs": 5221,
    "segs": [ {
      "utf8": "So what can workplaces do\nto make work work for women like Chelley."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 239254,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "Well, one solution that the majority"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 242224,
    "dDurationMs": 2752,
    "segs": [ {
      "utf8": "of employees support is\nworkplace flexibility,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 245460,
    "dDurationMs": 2753,
    "segs": [ {
      "utf8": "particularly the ability\nto work from home."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 248980,
    "dDurationMs": 3070,
    "segs": [ {
      "utf8": "When Chelley can take that important\ncall from her mother’s"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 252050,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "doctor from her home office,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 254503,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "or handle an emergency\nwithout scrambling out of work"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 258023,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "and worrying about traffic,\nshe's not distracted."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 261827,
    "dDurationMs": 4387,
    "segs": [ {
      "utf8": "She's focused. Now,\nyou're probably thinking, well,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 266214,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "this is great because\nthere's lots of jobs that allow you"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 269017,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "to work from home these days, right?"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 272220,
    "dDurationMs": 4121,
    "segs": [ {
      "utf8": "But here’s the thing. Simply\noffering work from home options"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 276341,
    "dDurationMs": 2519,
    "segs": [ {
      "utf8": "and flexibility isn't enough."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 280061,
    "dDurationMs": 4205,
    "segs": [ {
      "utf8": "In order for workplaces\nto be truly flexibility friendly,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 284266,
    "dDurationMs": 3553,
    "segs": [ {
      "utf8": "requires a more deliberate\nand holistic approach."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 289054,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "Recent research, including my own work\non workplace flexibility,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 292891,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "identifies three key\nactions employers can take"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 296845,
    "dDurationMs": 5806,
    "segs": [ {
      "utf8": "to develop truly flexibility friendly\nworkplace cultures that can complement"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 302651,
    "dDurationMs": 2435,
    "segs": [ {
      "utf8": "work from home policies for caregivers."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 306688,
    "dDurationMs": 5355,
    "segs": [ {
      "utf8": "So the first is to reevaluate\noutdated stereotypes."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 313094,
    "dDurationMs": 5072,
    "segs": [ {
      "utf8": "Even in workplaces or organizations\nthat offer work from home options,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 318366,
    "dDurationMs": 3237,
    "segs": [ {
      "utf8": "old stereotypes and stigma still exist."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 322370,
    "dDurationMs": 4038,
    "segs": [ {
      "utf8": "Managers still equate\nphysical presence with productivity"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 326975,
    "dDurationMs": 2236,
    "segs": [ {
      "utf8": "and remote work with laziness."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 330295,
    "dDurationMs": 4071,
    "segs": [ {
      "utf8": "And it’s no wonder we have these\npersistent work from home stigmas"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 334733,
    "dDurationMs": 4437,
    "segs": [ {
      "utf8": "when these negative ideas\nabout remote workers are seen among"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 339204,
    "dDurationMs": 4037,
    "segs": [ {
      "utf8": "even the highest levels\nof leadershi. For example,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 343375,
    "dDurationMs": 4671,
    "segs": [ {
      "utf8": "when the CEO of Frontier Airlines\ncalls remote workers lazy."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 348964,
    "dDurationMs": 5488,
    "segs": [ {
      "utf8": "But research that was recently\npublished finds that well-designed"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 354486,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "hybrid work schedules,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 356121,
    "dDurationMs": 1918,
    "segs": [ {
      "utf8": "where folks are working both at home"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 358039,
    "dDurationMs": 5556,
    "segs": [ {
      "utf8": "and in the office are just as productive\nas fully in-office employment."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 364045,
    "dDurationMs": 4872,
    "segs": [ {
      "utf8": "while also boosting employee retention,\nespecially among women."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 369951,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "If you truly want to support\ncaregivers in your workplace,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 373805,
    "dDurationMs": 2953,
    "segs": [ {
      "utf8": "align your rewards with your policies."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 377559,
    "dDurationMs": 3153,
    "segs": [ {
      "utf8": "Caregivers shouldn't feel\nthe need to overcompensate"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 380879,
    "dDurationMs": 4638,
    "segs": [ {
      "utf8": "when they're working from home if\nthey're already delivering quality work."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 386234,
    "dDurationMs": 5122,
    "segs": [ {
      "utf8": "Judge performance by results,\nnot by hours or location."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 393275,
    "dDurationMs": 4688,
    "segs": [ {
      "utf8": "The second: foster openness\nabout life outside of work."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 398680,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "Here's a simple test."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 401232,
    "dDurationMs": 4922,
    "segs": [ {
      "utf8": "Do you feel like you can openly talk\nabout your caregiving experience at work,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 406154,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "and with your colleagues,\nand with your managers?"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 408957,
    "dDurationMs": 4321,
    "segs": [ {
      "utf8": "Or do you feel the need\nto hide what’s going on in your life?"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 414112,
    "dDurationMs": 4154,
    "segs": [ {
      "utf8": "when employees are making\nmysterious doctor's appointments"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 418700,
    "dDurationMs": 3637,
    "segs": [ {
      "utf8": "and not being honest about\ntheir true caregiving needs,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 422737,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "your workplace is not\ntruly flexibility friendly."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 427142,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "Offering workplace supports\nlike employee resource groups,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 431379,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "or caregiving specific benefits,\nlike paid family leave,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 435900,
    "dDurationMs": 4638,
    "segs": [ {
      "utf8": "can help normalize and destigmatize\ncaregiving conversations."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 441256,
    "dDurationMs": 1718,
    "segs": [ {
      "utf8": "When Chelley is able to say,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 443341,
    "dDurationMs": 4838,
    "segs": [ {
      "utf8": "“I need to leave early today to help\nmy mother” without fear of judgment,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 448580,
    "dDurationMs": 2352,
    "segs": [ {
      "utf8": "that’s how you build trust and loyalty."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 451666,
    "dDurationMs": 3637,
    "segs": [ {
      "utf8": "And the third: standardized\nwork from home days"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 455303,
    "dDurationMs": 3070,
    "segs": [ {
      "utf8": "and make work from home\navailable to everyone."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 459090,
    "dDurationMs": 2653,
    "segs": [ {
      "utf8": "Now, this one is probably\nthe most crucial."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 462894,
    "dDurationMs": 4638,
    "segs": [ {
      "utf8": "The structure of work from\nhome policies matters just as much"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 467532,
    "dDurationMs": 2686,
    "segs": [ {
      "utf8": "as offering work from home options."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 471536,
    "dDurationMs": 5105,
    "segs": [ {
      "utf8": "Have you ever gone into the office,\nonly to find that no one else is there."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 476641,
    "dDurationMs": 2302,
    "segs": [ {
      "utf8": "And all of your meetings are on zoom."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 479728,
    "dDurationMs": 6406,
    "segs": [ {
      "utf8": "You probably feel lonely, unproductive,\nprobably a little bit frustrated."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 486685,
    "dDurationMs": 2519,
    "segs": [ {
      "utf8": "And that's especially true for caregivers"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 489454,
    "dDurationMs": 4471,
    "segs": [ {
      "utf8": "who may be anxiously thinking about\ntheir family member at home all day"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 493925,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "while they're at the office."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 496294,
    "dDurationMs": 5189,
    "segs": [ {
      "utf8": "But having clear and consistent work\nfrom home days that apply to everyone,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 501816,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "regardless of need, can fix this."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 505403,
    "dDurationMs": 3721,
    "segs": [ {
      "utf8": "When everyone knows that Monday\nand Wednesday are work from home days"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 509124,
    "dDurationMs": 2602,
    "segs": [ {
      "utf8": "and Tuesday and Thursday\nare in-office days,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 512127,
    "dDurationMs": 2402,
    "segs": [ {
      "utf8": "caregivers can plan\naround medical appointments"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 514529,
    "dDurationMs": 3887,
    "segs": [ {
      "utf8": "and caregiving needs without\nmissing out on team dynamics"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 518883,
    "dDurationMs": 2570,
    "segs": [ {
      "utf8": "or feeling like they're falling behind."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 522370,
    "dDurationMs": 4204,
    "segs": [ {
      "utf8": "Standardized work from home\nschedules can help boost productivity"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 526975,
    "dDurationMs": 4371,
    "segs": [ {
      "utf8": "and help caregivers feel\ntruly valued by their employers."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 532013,
    "dDurationMs": 3454,
    "segs": [ {
      "utf8": "So that untapped workforce I\ntalked about at the beginning"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 536034,
    "dDurationMs": 2886,
    "segs": [ {
      "utf8": "will be your employees\nand your colleagues."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 539421,
    "dDurationMs": 4287,
    "segs": [ {
      "utf8": "They're the women that you work\nwith every day who are also caregivers."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 544592,
    "dDurationMs": 4522,
    "segs": [ {
      "utf8": "Making their work work\nisn’t just the right thing to do."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 549581,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "It's the smart thing to do."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 552434,
    "dDurationMs": 3987,
    "segs": [ {
      "utf8": "Workplace flexibility isn't\njust a nice benefit or perk."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 557072,
    "dDurationMs": 2152,
    "segs": [ {
      "utf8": "It’s a strategic investment"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 559224,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "in retaining the quality\ntalent that's already there."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 563795,
    "dDurationMs": 4638,
    "segs": [ {
      "utf8": "It’s the difference between\nlosing Chelley’s 20 years of experience"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 568666,
    "dDurationMs": 2520,
    "segs": [ {
      "utf8": "or unlocking her full potential."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 571953,
    "dDurationMs": 5122,
    "segs": [ {
      "utf8": "And with 50% of employees looking\nto leave their jobs this year."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 577792,
    "dDurationMs": 2703,
    "segs": [ {
      "utf8": "Ask yourself, how long can we afford"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 580495,
    "dDurationMs": 3820,
    "segs": [ {
      "utf8": "to ignore the benefits\nof workplace flexibility?"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 584699,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "Thank you."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  } ]
}
