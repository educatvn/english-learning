  "events": [ {
    "tStartMs": 90,
    "dDurationMs": 1130,
    "segs": [ {
      "utf8": "- Phoebe Buffay."
    } ]
  }, {
    "tStartMs": 1220,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "- How do you spell that\nso we can get it right?"
    } ]
  }, {
    "tStartMs": 2820,
    "dDurationMs": 4050,
    "segs": [ {
      "utf8": "Oh okay, it's P as in\nPhoebe, H as in Hoebe,"
    } ]
  }, {
    "tStartMs": 6870,
    "dDurationMs": 3460,
    "segs": [ {
      "utf8": "O as in Oebe, E as in Ebe, B as in Be"
    } ]
  }, {
    "tStartMs": 10330,
    "dDurationMs": 2254,
    "segs": [ {
      "utf8": "and E as in 'ello there, mate."
    } ]
  }, {
    "tStartMs": 12584,
    "dDurationMs": 2667,
    "segs": [ {
      "utf8": "(upbeat music)"
    } ]
  }, {
    "tStartMs": 18040,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "I remember when I first\ncame to this city, I was 14."
    } ]
  }, {
    "tStartMs": 20800,
    "dDurationMs": 1810,
    "segs": [ {
      "utf8": "My mom had just killed\nherself and my stepdad"
    } ]
  }, {
    "tStartMs": 22610,
    "dDurationMs": 3126,
    "segs": [ {
      "utf8": "was back in prison and I got\nhere and I didn't know anybody."
    } ]
  }, {
    "tStartMs": 25736,
    "dDurationMs": 2444,
    "segs": [ {
      "utf8": "And I ended up living with this albino guy"
    } ]
  }, {
    "tStartMs": 28180,
    "dDurationMs": 2650,
    "segs": [ {
      "utf8": "who was like cleaning windshields\noutside Port Authority,"
    } ]
  }, {
    "tStartMs": 30830,
    "dDurationMs": 1909,
    "segs": [ {
      "utf8": "and then he killed himself."
    } ]
  }, {
    "tStartMs": 32739,
    "dDurationMs": 1521,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 34260,
    "dDurationMs": 1600,
    "segs": [ {
      "utf8": "And then I found aromatherapy."
    } ]
  }, {
    "tStartMs": 35860,
    "dDurationMs": 2356,
    "segs": [ {
      "utf8": "So believe me, I know\nexactly how you feel."
    } ]
  }, {
    "tStartMs": 38216,
    "dDurationMs": 3004,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 41220,
    "dDurationMs": 1416,
    "segs": [ {
      "utf8": "Hey!"
    } ]
  }, {
    "tStartMs": 42636,
    "dDurationMs": 1164,
    "segs": [ {
      "utf8": "- Hey.\n- Hey Phoebes."
    } ]
  }, {
    "tStartMs": 43800,
    "dDurationMs": 1696,
    "segs": [ {
      "utf8": "- Happy Christmas Eve, Eve."
    } ]
  }, {
    "tStartMs": 45496,
    "dDurationMs": 1074,
    "segs": [ {
      "utf8": "- You, too."
    } ]
  }, {
    "tStartMs": 46570,
    "dDurationMs": 2750,
    "segs": [ {
      "utf8": "- Oh my God, where did you get this?"
    } ]
  }, {
    "tStartMs": 49320,
    "dDurationMs": 2830,
    "segs": [ {
      "utf8": "- Macy's, third floor home furnishings."
    } ]
  }, {
    "tStartMs": 52150,
    "dDurationMs": 3709,
    "segs": [ {
      "utf8": "- This is my father, this\nis a picture of my dad."
    } ]
  }, {
    "tStartMs": 55859,
    "dDurationMs": 2341,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 58200,
    "dDurationMs": 3450,
    "segs": [ {
      "utf8": "- Phoebes, that's the guy\nthat comes in the frame."
    } ]
  }, {
    "tStartMs": 61650,
    "dDurationMs": 1430,
    "segs": [ {
      "utf8": "- No, it isn't, this is my dad."
    } ]
  }, {
    "tStartMs": 63080,
    "dDurationMs": 1110,
    "segs": [ {
      "utf8": "All right, I'll show you."
    } ]
  }, {
    "tStartMs": 64190,
    "dDurationMs": 2240,
    "segs": [ {
      "utf8": "- Phoebe, I thought\nyour dad was in prison."
    } ]
  }, {
    "tStartMs": 66430,
    "dDurationMs": 1840,
    "segs": [ {
      "utf8": "- No, no, that's my stepdad."
    } ]
  }, {
    "tStartMs": 68270,
    "dDurationMs": 2410,
    "segs": [ {
      "utf8": "My real dad's the one that ran\nout on us before I was born."
    } ]
  }, {
    "tStartMs": 70680,
    "dDurationMs": 2290,
    "segs": [ {
      "utf8": "Okay, look see, this is him."
    } ]
  }, {
    "tStartMs": 72970,
    "dDurationMs": 3147,
    "segs": [ {
      "utf8": "My mother gave me this picture\nbefore she died, same guy."
    } ]
  }, {
    "tStartMs": 76117,
    "dDurationMs": 3059,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 79176,
    "dDurationMs": 3654,
    "segs": [ {
      "utf8": "- Honey, this is a picture\nof the frame guy posing"
    } ]
  }, {
    "tStartMs": 82830,
    "dDurationMs": 2870,
    "segs": [ {
      "utf8": "in front of a bright blue\nscreen with a collie."
    } ]
  }, {
    "tStartMs": 85700,
    "dDurationMs": 2207,
    "segs": [ {
      "utf8": "- What, it's not a blue\nscreen, it's just--"
    } ]
  }, {
    "tStartMs": 89040,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "Maybe it was just really clear that day."
    } ]
  }, {
    "tStartMs": 94100,
    "dDurationMs": 2676,
    "segs": [ {
      "utf8": "Okay, I have to talk to my grandmother."
    } ]
  }, {
    "tStartMs": 96776,
    "dDurationMs": 1232,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 98008,
    "dDurationMs": 1292,
    "segs": [ {
      "utf8": "- Wait a minute honey.\n- Phoebe!"
    } ]
  }, {
    "tStartMs": 99300,
    "dDurationMs": 1750,
    "segs": [ {
      "utf8": "- I never had a bike of my own one."
    } ]
  }, {
    "tStartMs": 101050,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- What?"
    } ]
  }, {
    "tStartMs": 101883,
    "dDurationMs": 2007,
    "segs": [ {
      "utf8": "- Well, we didn't have a lot of money,"
    } ]
  }, {
    "tStartMs": 103890,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "but the girl across the\nstreet had the best bike."
    } ]
  }, {
    "tStartMs": 107010,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "It was pink and it had\nrainbow color tassels"
    } ]
  }, {
    "tStartMs": 110490,
    "dDurationMs": 2530,
    "segs": [ {
      "utf8": "hanging off the handle grips and a bell"
    } ]
  }, {
    "tStartMs": 113020,
    "dDurationMs": 2732,
    "segs": [ {
      "utf8": "and this big white wicker basket"
    } ]
  }, {
    "tStartMs": 115752,
    "dDurationMs": 2200,
    "segs": [ {
      "utf8": "with those plastic daisies stuck on."
    } ]
  }, {
    "tStartMs": 117952,
    "dDurationMs": 2677,
    "segs": [ {
      "utf8": "- That sounds like my first bike."
    } ]
  }, {
    "tStartMs": 120629,
    "dDurationMs": 1551,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 122180,
    "dDurationMs": 1473,
    "segs": [ {
      "utf8": "My dad gave me his old one."
    } ]
  }, {
    "tStartMs": 125320,
    "dDurationMs": 1340,
    "segs": [ {
      "utf8": "- Did the girl ever let you ride it?"
    } ]
  }, {
    "tStartMs": 126660,
    "dDurationMs": 2748,
    "segs": [ {
      "utf8": "- No, but she gave me\nthe box that it came in."
    } ]
  }, {
    "tStartMs": 129408,
    "dDurationMs": 3349,
    "segs": [ {
      "utf8": "It had a picture of the bike on the front."
    } ]
  }, {
    "tStartMs": 132757,
    "dDurationMs": 3473,
    "segs": [ {
      "utf8": "So I would sit on it and\nmy stepdad would drag me"
    } ]
  }, {
    "tStartMs": 136230,
    "dDurationMs": 1375,
    "segs": [ {
      "utf8": "around the backyard."
    } ]
  }, {
    "tStartMs": 137605,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 139190,
    "dDurationMs": 1650,
    "segs": [ {
      "utf8": "- That is so unfair."
    } ]
  }, {
    "tStartMs": 140840,
    "dDurationMs": 2387,
    "segs": [ {
      "utf8": "- Not really, I got to\ndrag him around, too."
    } ]
  }, {
    "tStartMs": 143227,
    "dDurationMs": 1173,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 144400,
    "dDurationMs": 1570,
    "segs": [ {
      "utf8": "- Ross was mugged as a kid."
    } ]
  }, {
    "tStartMs": 145970,
    "dDurationMs": 880,
    "segs": [ {
      "utf8": "- You were?"
    } ]
  }, {
    "tStartMs": 146850,
    "dDurationMs": 2115,
    "segs": [ {
      "utf8": "- Yeah, it was pretty traumatic."
    } ]
  }, {
    "tStartMs": 148965,
    "dDurationMs": 2665,
    "segs": [ {
      "utf8": "It was outside St. Mark's Comics."
    } ]
  }, {
    "tStartMs": 151630,
    "dDurationMs": 2310,
    "segs": [ {
      "utf8": "You know, I was just there\nminding my own business,"
    } ]
  }, {
    "tStartMs": 153940,
    "dDurationMs": 1850,
    "segs": [ {
      "utf8": "you know, seeing what\nkind of trouble Spiderman"
    } ]
  }, {
    "tStartMs": 155790,
    "dDurationMs": 1480,
    "segs": [ {
      "utf8": "got into that week."
    } ]
  }, {
    "tStartMs": 157270,
    "dDurationMs": 1437,
    "segs": [ {
      "utf8": "- Wonder Woman."
    } ]
  }, {
    "tStartMs": 158707,
    "dDurationMs": 1333,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 160040,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "- Anyway, I was heading\ntowards this bakery, you know,"
    } ]
  }, {
    "tStartMs": 162480,
    "dDurationMs": 3307,
    "segs": [ {
      "utf8": "to pick up a couple of dozen\nLinzer tortes for someone--"
    } ]
  }, {
    "tStartMs": 165787,
    "dDurationMs": 2813,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 168600,
    "dDurationMs": 2820,
    "segs": [ {
      "utf8": "When out of nowhere, this thug with a pipe"
    } ]
  }, {
    "tStartMs": 171420,
    "dDurationMs": 2630,
    "segs": [ {
      "utf8": "jumps out and says, \"Give\nme your money, punk.\""
    } ]
  }, {
    "tStartMs": 174050,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Oh my God."
    } ]
  }, {
    "tStartMs": 174883,
    "dDurationMs": 1438,
    "segs": [ {
      "utf8": "- I know."
    } ]
  }, {
    "tStartMs": 176321,
    "dDurationMs": 1649,
    "segs": [ {
      "utf8": "And the worst part was\nthey took my backpack,"
    } ]
  }, {
    "tStartMs": 177970,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "which had all the original artwork"
    } ]
  }, {
    "tStartMs": 179970,
    "dDurationMs": 3133,
    "segs": [ {
      "utf8": "I had done for my own\ncomic book, \"Science Boy.\""
    } ]
  }, {
    "tStartMs": 183103,
    "dDurationMs": 2000,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 185103,
    "dDurationMs": 2337,
    "segs": [ {
      "utf8": "- Oh yeah, what was his super power again?"
    } ]
  }, {
    "tStartMs": 187440,
    "dDurationMs": 2683,
    "segs": [ {
      "utf8": "- A super human thirst for knowledge."
    } ]
  }, {
    "tStartMs": 190123,
    "dDurationMs": 2377,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 192500,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "I better get to class."
    } ]
  }, {
    "tStartMs": 194210,
    "dDurationMs": 1150,
    "segs": [ {
      "utf8": "Are there any more of your friends"
    } ]
  }, {
    "tStartMs": 195360,
    "dDurationMs": 2180,
    "segs": [ {
      "utf8": "I should look out for on my way, Phoebe?"
    } ]
  }, {
    "tStartMs": 197540,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "- No, actually you might want\nto stay away from Jane Street."
    } ]
  }, {
    "tStartMs": 200860,
    "dDurationMs": 1987,
    "segs": [ {
      "utf8": "That's where stabby Joe works."
    } ]
  }, {
    "tStartMs": 202847,
    "dDurationMs": 3250,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 207680,
    "dDurationMs": 2210,
    "segs": [ {
      "utf8": "Okay, I think we have a problem here."
    } ]
  }, {
    "tStartMs": 209890,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- What?"
    } ]
  }, {
    "tStartMs": 210723,
    "dDurationMs": 2407,
    "segs": [ {
      "utf8": "- Well, back in my mugging days, you know,"
    } ]
  }, {
    "tStartMs": 213130,
    "dDurationMs": 2760,
    "segs": [ {
      "utf8": "I worked St Mark's Comics."
    } ]
  }, {
    "tStartMs": 215890,
    "dDurationMs": 980,
    "segs": [ {
      "utf8": "- Yeah?"
    } ]
  }, {
    "tStartMs": 216870,
    "dDurationMs": 2090,
    "segs": [ {
      "utf8": "- Well, a pipe was my weapon of choice"
    } ]
  }, {
    "tStartMs": 218960,
    "dDurationMs": 4487,
    "segs": [ {
      "utf8": "and pre-teen comic book\nnerds were my meat."
    } ]
  }, {
    "tStartMs": 223447,
    "dDurationMs": 2273,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 225720,
    "dDurationMs": 1150,
    "segs": [ {
      "utf8": "- So?"
    } ]
  }, {
    "tStartMs": 226870,
    "dDurationMs": 2090,
    "segs": [ {
      "utf8": "- Well, there was this\none kid who had a sticker"
    } ]
  }, {
    "tStartMs": 228960,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "on his backpack that said"
    } ]
  }, {
    "tStartMs": 230310,
    "dDurationMs": 2214,
    "segs": [ {
      "utf8": "geology rocks.\n- Geology rocks!"
    } ]
  }, {
    "tStartMs": 232524,
    "dDurationMs": 3699,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 236223,
    "dDurationMs": 1176,
    "segs": [ {
      "utf8": "Oh my God!"
    } ]
  }, {
    "tStartMs": 237399,
    "dDurationMs": 1661,
    "segs": [ {
      "utf8": "- I know, I mugged Ross!"
    } ]
  }, {
    "tStartMs": 239060,
    "dDurationMs": 3820,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 242880,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Hi Ursula."
    } ]
  }, {
    "tStartMs": 244240,
    "dDurationMs": 1105,
    "segs": [ {
      "utf8": "- Hey."
    } ]
  }, {
    "tStartMs": 245345,
    "dDurationMs": 3495,
    "segs": [ {
      "utf8": "- Okay, well I know that we\nhaven't talked in a long time,"
    } ]
  }, {
    "tStartMs": 248840,
    "dDurationMs": 3220,
    "segs": [ {
      "utf8": "but okay, our mom is not our birth mom."
    } ]
  }, {
    "tStartMs": 252060,
    "dDurationMs": 2590,
    "segs": [ {
      "utf8": "This other lady is our birth mom."
    } ]
  }, {
    "tStartMs": 254650,
    "dDurationMs": 2754,
    "segs": [ {
      "utf8": "- Right okay, the one\nthat lives in Montauk."
    } ]
  }, {
    "tStartMs": 257404,
    "dDurationMs": 1221,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 258625,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- You know her?"
    } ]
  }, {
    "tStartMs": 259458,
    "dDurationMs": 4005,
    "segs": [ {
      "utf8": "- No, I read about her\nin mom's suicide note."
    } ]
  }, {
    "tStartMs": 263463,
    "dDurationMs": 2059,
    "segs": [ {
      "utf8": "- There was a suicide note?"
    } ]
  }, {
    "tStartMs": 265522,
    "dDurationMs": 2121,
    "segs": [ {
      "utf8": "Do you still have it?"
    } ]
  }, {
    "tStartMs": 268890,
    "dDurationMs": 833,
    "segs": [ {
      "utf8": "- Hang on."
    } ]
  }, {
    "tStartMs": 270663,
    "dDurationMs": 1697,
    "segs": [ {
      "utf8": "(background laughter)\n(door shutting)"
    } ]
  }, {
    "tStartMs": 272360,
    "dDurationMs": 1820,
    "segs": [ {
      "utf8": "- I can't believe you didn't tell me"
    } ]
  }, {
    "tStartMs": 274180,
    "dDurationMs": 1690,
    "segs": [ {
      "utf8": "there was a suicide note!"
    } ]
  }, {
    "tStartMs": 275870,
    "dDurationMs": 2350,
    "segs": [ {
      "utf8": "- [Ursula] Yeah, so how\nhave you been doing?"
    } ]
  }, {
    "tStartMs": 278220,
    "dDurationMs": 2828,
    "segs": [ {
      "utf8": "- I've, shut up!"
    } ]
  }, {
    "tStartMs": 281048,
    "dDurationMs": 3250,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 285200,
    "dDurationMs": 2540,
    "segs": [ {
      "utf8": "Goodbye Phoebe and Ursula, I'll miss you."
    } ]
  }, {
    "tStartMs": 287740,
    "dDurationMs": 2923,
    "segs": [ {
      "utf8": "P.S your mom lives in Montauk."
    } ]
  }, {
    "tStartMs": 290663,
    "dDurationMs": 1797,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 292460,
    "dDurationMs": 1963,
    "segs": [ {
      "utf8": "You just wrote this!"
    } ]
  }, {
    "tStartMs": 294423,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "- It's pretty much the gist."
    } ]
  }, {
    "tStartMs": 296842,
    "dDurationMs": 2045,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  }, {
    "tStartMs": 298887,
    "dDurationMs": 1123,
    "segs": [ {
      "utf8": "- Hey Joey, when you said the deal"
    } ]
  }, {
    "tStartMs": 300010,
    "dDurationMs": 1700,
    "segs": [ {
      "utf8": "with Santa Claus, you meant..."
    } ]
  }, {
    "tStartMs": 301710,
    "dDurationMs": 1235,
    "segs": [ {
      "utf8": "- That he doesn't exist."
    } ]
  }, {
    "tStartMs": 302945,
    "dDurationMs": 938,
    "segs": [ {
      "utf8": "- Right."
    } ]
  }, {
    "tStartMs": 305434,
    "dDurationMs": 3250,
    "segs": [ {
      "utf8": "(background laughter)"
    } ]
  } ]
}
