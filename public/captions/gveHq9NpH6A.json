  }, {
    "tStartMs": 133467,
    "dDurationMs": 1201,
    "segs": [ {
      "utf8": "-I've done three movies\nwith him, too."
    } ]
  }, {
    "tStartMs": 134668,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "-What's going on\nwith you guys?"
    } ]
  }, {
    "tStartMs": 136036,
    "dDurationMs": 1301,
    "segs": [ {
      "utf8": "-I met him --\n-He loves us."
    } ]
  }, {
    "tStartMs": 137337,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "-Yeah, he loved that."
    } ]
  }, {
    "tStartMs": 138839,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "-I just want to be involved."
    } ]
  }, {
    "tStartMs": 140274,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ]
  }, {
    "tStartMs": 142009,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "-Robert, where did you --"
    } ]
  }, {
    "tStartMs": 143177,
    "dDurationMs": 2435,
    "segs": [ {
      "utf8": "When did you first meet Zendaya?\nDo you remember?"
    } ]
  }, {
    "tStartMs": 145612,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "And was it a good\nfirst impression?"
    } ]
  }, {
    "tStartMs": 147481,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "-I mean, you have --\n-A different memory."
    } ]
  }, {
    "tStartMs": 149816,
    "dDurationMs": 2603,
    "segs": [ {
      "utf8": "-You think that something\nhappened that didn't happen."
    } ]
  }, {
    "tStartMs": 152419,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "-Oh!\n-No, no, no!"
    } ]
  }, {
    "tStartMs": 153921,
    "dDurationMs": 1268,
    "segs": [ {
      "utf8": "Just like she said\nwe had a phone call"
