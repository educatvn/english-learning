  }, {
    "tStartMs": 39540,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "We're back together.\n-Yeah."
    } ]
  }, {
    "tStartMs": 41375,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "-Oh, that's right, you're not\nallowed to say anything about\n\"The Odyssey.\""
