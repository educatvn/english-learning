  "events": [ {
    "tStartMs": 1235,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "-We love you.\nWelcome, welcome."
    } ]
  }, {
    "tStartMs": 2636,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "Welcome back to the show."
