  }, {
    "tStartMs": 566233,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "Take a look."
    } ]
  }, {
    "tStartMs": 567801,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "-I did, I said, if everyone\nknows he's a piece of (bleep)"
    } ]
  }, {
    "tStartMs": 569670,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "why are we doing a retrospective\nin the first place?"
