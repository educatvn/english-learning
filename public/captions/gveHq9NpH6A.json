  }, {
    "tStartMs": 222523,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "-This is great for our show."
    } ]
  }, {
    "tStartMs": 224258,
    "dDurationMs": 2068,
    "segs": [ {
      "utf8": "Trust me,\nno one's gonna clip that out."
    } ]
  }, {
    "tStartMs": 226326,
    "dDurationMs": 1769,
    "segs": [ {
      "utf8": "No!\n-Surprise!"
    } ]
  }, {
    "tStartMs": 228095,
    "dDurationMs": 2903,
    "segs": [ {
      "utf8": "-You put --\nYou put everything out there."
    } ]
  }, {
    "tStartMs": 230998,
    "dDurationMs": 1801,
    "segs": [ {
      "utf8": "You meant your feelings.\n-Yes."
    } ]
  }, {
    "tStartMs": 232799,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "Emotionally.\n-Emotionally."
    } ]
  }, {
    "tStartMs": 234601,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "We got what\nyou were trying to say."
    } ]
  }, {
    "tStartMs": 235769,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "-Yeah, yeah, and she was\nvery understanding."
    } ]
  }, {
    "tStartMs": 237638,
    "dDurationMs": 2536,
    "segs": [ {
      "utf8": "-Well, you're both pretty\nlikable human beings."
    } ]
  }, {
    "tStartMs": 240174,
    "dDurationMs": 2836,
    "segs": [ {
      "utf8": "But Zendaya, you were telling me\nthat you had to do a dance scene"
    } ]
  }, {
    "tStartMs": 243010,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "is where you thought\nthat you really bonded."
    } ]
  }, {
    "tStartMs": 244845,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "-I think so, because I think,\nwell, like I said,"
    } ]
  }, {
    "tStartMs": 247347,
    "dDurationMs": 1769,
    "segs": [ {
      "utf8": "I don't want to talk for you,"
    } ]
  }, {
    "tStartMs": 249116,
    "dDurationMs": 2035,
    "segs": [ {
      "utf8": "but Rob doesn't love\nthat he had to dance."
    } ]
  }, {
    "tStartMs": 251151,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "And I, you know,"
    } ]
  }, {
    "tStartMs": 252486,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "I'm a little more comfortable\nwith the dancing thing."
