  }, {
    "tStartMs": 187487,
    "dDurationMs": 1936,
    "segs": [ {
      "utf8": "I'd rather just do this\nover a regular phone call.\""
    } ]
  }, {
    "tStartMs": 189423,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "Yeah. Yeah.\n-He was in the zone,"
    } ]
  }, {
    "tStartMs": 191258,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "so fair enough.\n-Yeah."
    } ]
  }, {
    "tStartMs": 193093,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "When did you realize\nthat it was going to work,"
    } ]
  }, {
    "tStartMs": 194494,
    "dDurationMs": 2503,
    "segs": [ {
      "utf8": "when you guys had chemistry?"
    } ]
  }, {
    "tStartMs": 196997,
    "dDurationMs": 4404,
    "segs": [ {
      "utf8": "-Um, I mean, we had one phone\ncall before we started shooting,"
    } ]
  }, {
    "tStartMs": 201401,
    "dDurationMs": 2603,
    "segs": [ {
      "utf8": "and I kind of went --"
    } ]
  }, {
    "tStartMs": 204004,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "I put the pedal to the metal\nwith my anxiety"
    } ]
  }, {
    "tStartMs": 207174,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "and, like, every single day"
    } ]
  }, {
    "tStartMs": 208909,
    "dDurationMs": 1768,
    "segs": [ {
      "utf8": "I did the most extreme version\nof my personality,"
    } ]
  }, {
    "tStartMs": 210677,
    "dDurationMs": 2436,
    "segs": [ {
      "utf8": "just like full frontal\non her face--"
    } ]
  }, {
    "tStartMs": 213113,
    "dDurationMs": 2369,
    "segs": [ {
      "utf8": "Not full frontal.\n-[ Laughs ]"
