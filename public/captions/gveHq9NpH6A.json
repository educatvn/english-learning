  }, {
    "tStartMs": 29062,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "with \"The Odyssey,\""
    } ]
  }, {
    "tStartMs": 30664,
    "dDurationMs": 1768,
    "segs": [ {
      "utf8": "so we didn't really\ntell each other,"
