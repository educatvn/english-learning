  }, {
    "tStartMs": 538405,
    "dDurationMs": 1268,
    "segs": [ {
      "utf8": "There's no plan.\""
    } ]
  }, {
    "tStartMs": 539673,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "-But here's the thing,\nhere's the thing."
