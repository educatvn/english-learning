  }, {
    "tStartMs": 112379,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "We're gonna go, man.\nDon't stop, I love it."
    } ]
  }, {
    "tStartMs": 114481,
    "dDurationMs": 2302,
    "segs": [ {
      "utf8": "Robert, did you get to visit\nthe set of \"Spider-Man\"?"
    } ]
  }, {
    "tStartMs": 116783,
    "dDurationMs": 2970,
    "segs": [ {
      "utf8": "Is \"Batman\" allowed\nto visit the set of--"
    } ]
  }, {
    "tStartMs": 119753,
    "dDurationMs": 1101,
    "segs": [ {
      "utf8": "-I don't know."
    } ]
  }, {
    "tStartMs": 120854,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "I think I'd be allowed.\n-Is it legal?"
    } ]
  }, {
    "tStartMs": 121855,
    "dDurationMs": 1402,
    "segs": [ {
      "utf8": "-Yeah. Is it legal?"
    } ]
  }, {
    "tStartMs": 123257,
    "dDurationMs": 1801,
    "segs": [ {
      "utf8": "We keep getting asked like,\nwho would win in a fight?"
    } ]
  }, {
    "tStartMs": 125058,
    "dDurationMs": 1469,
    "segs": [ {
      "utf8": "Spider-Man or Batman?\n-No!"
    } ]
  }, {
    "tStartMs": 126527,
    "dDurationMs": 3203,
    "segs": [ {
      "utf8": "-I'm like, I'm like, legally not\nallowed to say it's Spider-Man."
    } ]
  }, {
    "tStartMs": 129730,
    "dDurationMs": 2202,
    "segs": [ {
      "utf8": "-Do you know Tom at all?\n-Yeah, I love Tom."
    } ]
  }, {
    "tStartMs": 131932,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "-Yeah, you've done\nstuff with him."
