  "events": [ {
    "tStartMs": 0,
    "dDurationMs": 7000,
    "segs": [ {
      "utf8": "Transcriber: Sama Sleam\nReviewer: NGUYEN TRUONG SINH� VPVX"
    } ],
    "wpWinPosId": 1,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 3579,
    "dDurationMs": 2250,
    "segs": [ {
      "utf8": "Imagine you're in a room negotiating"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 5829,
    "dDurationMs": 4084,
    "segs": [ {
      "utf8": "with government ministers\naround technology regulations."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 10288,
    "dDurationMs": 5208,
    "segs": [ {
      "utf8": "The stakes are high. Online access\nto entire country hangs in the balance."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 16454,
    "dDurationMs": 3209,
    "segs": [ {
      "utf8": "Well, I don't have to imagine,\nbecause I was there,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 20746,
    "dDurationMs": 3208,
    "segs": [ {
      "utf8": "and I remember thinking,\nthis has to be our red line."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 24496,
    "dDurationMs": 5667,
    "segs": [ {
      "utf8": "Throughout negotiations, I watched\nthat line move quietly, steadily,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 30163,
    "dDurationMs": 1708,
    "segs": [ {
      "utf8": "until it finally disappeared."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 32579,
    "dDurationMs": 3833,
    "segs": [ {
      "utf8": "What began as a negotiation\nslowly became a farce."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 37162,
    "dDurationMs": 2500,
    "segs": [ {
      "utf8": "We weren't engaging in good faith anymore,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 40204,
    "dDurationMs": 3417,
    "segs": [ {
      "utf8": "and that's when I began\nto wonder if we ever were."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 44621,
    "dDurationMs": 2666,
    "segs": [ {
      "utf8": "One unspoken truth hung in the air."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 47829,
    "dDurationMs": 4083,
    "segs": [ {
      "utf8": "We could shut down your entire country\nwith the flip of a switch."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 53079,
    "dDurationMs": 4500,
    "segs": [ {
      "utf8": "We had that power, but\nthankfully we chose not to use it."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 58496,
    "dDurationMs": 3666,
    "segs": [ {
      "utf8": "That was in late 2022.\nSomewhere between Europe and Asia,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 62537,
    "dDurationMs": 3626,
    "segs": [ {
      "utf8": "the country had survived an attempted"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 66163,
    "dDurationMs": 4333,
    "segs": [ {
      "utf8": "coup but was sliding towards repression. \nAnd there we were,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 70496,
    "dDurationMs": 4292,
    "segs": [ {
      "utf8": "A technology company ready to compromise \nfreedoms that journalists and activists"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 76954,
    "dDurationMs": 3417,
    "segs": [ {
      "utf8": "Just to stay online. Whenever I think \nabout the integrity"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 80371,
    "dDurationMs": 2167,
    "segs": [ {
      "utf8": "Of democracies,\nI think back to that moment,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 83704,
    "dDurationMs": 4167,
    "segs": [ {
      "utf8": "not to the months I spent leading\noperations on the US election in 2022"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 88288,
    "dDurationMs": 2625,
    "segs": [ {
      "utf8": "or the Myanmar coup in 2021,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 91121,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "or to the red teaming"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 92121,
    "dDurationMs": 5208,
    "segs": [ {
      "utf8": "and intelligence reports I created\nfor over 20 elections in 2024. No,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 97371,
    "dDurationMs": 4167,
    "segs": [ {
      "utf8": "I think back to that moment,\nto that negotiation,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 101538,
    "dDurationMs": 4125,
    "segs": [ {
      "utf8": "because that moment showed me something\ndeeper, something more egregious."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 106079,
    "dDurationMs": 2042,
    "segs": [ {
      "utf8": "That power had shifted."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 109079,
    "dDurationMs": 5667,
    "segs": [ {
      "utf8": "That technology companies, the ones\nwe rely on for communication, for truth,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 114746,
    "dDurationMs": 5167,
    "segs": [ {
      "utf8": "for community, now hold the balance\nof democracy in their hands."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 121746,
    "dDurationMs": 3708,
    "segs": [ {
      "utf8": "I've been in the situation rooms\nfor pivotal American elections,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 125538,
    "dDurationMs": 5208,
    "segs": [ {
      "utf8": "and I've watched recently in horror as\ndisinformation took elections in Brazil,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 130746,
    "dDurationMs": 1833,
    "segs": [ {
      "utf8": "India, Pakistan and Moldova,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 134288,
    "dDurationMs": 3125,
    "segs": [ {
      "utf8": "and recently here\nearlier this year in Germany,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 138788,
    "dDurationMs": 3791,
    "segs": [ {
      "utf8": "where misinformation spread faster\nthan truth could reach parliament."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 143538,
    "dDurationMs": 5958,
    "segs": [ {
      "utf8": "I learned that democracy doesn't die\nin one dramatic moment."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 150038,
    "dDurationMs": 4166,
    "segs": [ {
      "utf8": "In this new age, it erodes\nthrough a thousand digital cuts."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 154954,
    "dDurationMs": 2375,
    "segs": [ {
      "utf8": "You see, it starts with small compromises."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 157746,
    "dDurationMs": 1667,
    "segs": [ {
      "utf8": "A policy adjusts it there,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 161413,
    "dDurationMs": 6750,
    "segs": [ {
      "utf8": "an exemption granted here, a request\nquietly honored in the name of stability."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 168954,
    "dDurationMs": 5042,
    "segs": [ {
      "utf8": "Before long, principled negotiation\nbecomes complicity in repression,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 175204,
    "dDurationMs": 3542,
    "segs": [ {
      "utf8": "according to The Economist\n2024 Democracy Index,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 178746,
    "dDurationMs": 4042,
    "segs": [ {
      "utf8": "representative democracy is no longer\nworking for large numbers of people."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 183329,
    "dDurationMs": 3417,
    "segs": [ {
      "utf8": "Governments have grown\nestranged from the people."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 187204,
    "dDurationMs": 3459,
    "segs": [ {
      "utf8": "Anocracy is part democracy,\npart dictatorships."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 190663,
    "dDurationMs": 1416,
    "segs": [ {
      "utf8": "They are on the rise."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 192621,
    "dDurationMs": 3500,
    "segs": [ {
      "utf8": "Power is being outsourced\nto unelected bodies."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 197996,
    "dDurationMs": 2542,
    "segs": [ {
      "utf8": "German American\nhistorian Hannah Arendt wrote,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 200538,
    "dDurationMs": 4416,
    "segs": [ {
      "utf8": "A people that can no longer believe\nanything cannot make up its own mind."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 205871,
    "dDurationMs": 3167,
    "segs": [ {
      "utf8": "And when such people you can then do\nwith what you please."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 210163,
    "dDurationMs": 4416,
    "segs": [ {
      "utf8": "That's when I came to the realization\nthis isn't chaos, it's coordination."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 215371,
    "dDurationMs": 5292,
    "segs": [ {
      "utf8": "I call this conflict that's\nunfolding all around us the invisible war."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 221454,
    "dDurationMs": 3917,
    "segs": [ {
      "utf8": "And this war isn't fought with weapons,\nbut it's fought with information,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 225371,
    "dDurationMs": 3542,
    "segs": [ {
      "utf8": "with algorithms,\ntrade policy and AI development."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 229454,
    "dDurationMs": 3209,
    "segs": [ {
      "utf8": "It's frontline shift\nwith every feed we scroll through,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 232663,
    "dDurationMs": 2083,
    "segs": [ {
      "utf8": "every time you pick up our phones."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 235288,
    "dDurationMs": 2958,
    "segs": [ {
      "utf8": "The new weapons are disinformation,\nsurveillance,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 238246,
    "dDurationMs": 3667,
    "segs": [ {
      "utf8": "and the concentrated power\nof a few technology companies."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 242913,
    "dDurationMs": 2666,
    "segs": [ {
      "utf8": "The battleground isn't land."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 245788,
    "dDurationMs": 4916,
    "segs": [ {
      "utf8": "It's our minds. It's our attention,\nour sense of shared reality."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 252038,
    "dDurationMs": 3541,
    "segs": [ {
      "utf8": "Only 7% of people today live\nin democracies."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 256788,
    "dDurationMs": 4791,
    "segs": [ {
      "utf8": "70% of people live in flawed\nor authoritarian nation states."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 261871,
    "dDurationMs": 2917,
    "segs": [ {
      "utf8": "It's what The Economist\ncalls a democracy recession."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 264996,
    "dDurationMs": 2083,
    "segs": [ {
      "utf8": "And it's not driven by tanks."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 267079,
    "dDurationMs": 3167,
    "segs": [ {
      "utf8": "It's driven by data, by manipulation,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 270704,
    "dDurationMs": 3375,
    "segs": [ {
      "utf8": "by strategic use\nof information and technology."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 275329,
    "dDurationMs": 5667,
    "segs": [ {
      "utf8": "I say that this is warfare without\ndeclaration, propaganda without borders,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 281621,
    "dDurationMs": 3458,
    "segs": [ {
      "utf8": "a conflict waged in the invisible\nrealm of algorithms"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 285079,
    "dDurationMs": 3625,
    "segs": [ {
      "utf8": "and attention led by new types\nof nation states,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 288746,
    "dDurationMs": 2375,
    "segs": [ {
      "utf8": "ones that we unknowingly opted into."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 292954,
    "dDurationMs": 4459,
    "segs": [ {
      "utf8": "And I've seen how this plays out\nat home in the United States."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 297413,
    "dDurationMs": 3875,
    "segs": [ {
      "utf8": "Disinformation and surveillance\nhave formed a dangerous feedback loop."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 302371,
    "dDurationMs": 4125,
    "segs": [ {
      "utf8": "Falsehoods justified new forms\nof monitoring and censorship."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 307329,
    "dDurationMs": 3334,
    "segs": [ {
      "utf8": "Federal agencies expanded\ndomestic surveillance in the name"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 310663,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "of fighting fake news and extremism,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 314204,
    "dDurationMs": 2750,
    "segs": [ {
      "utf8": "outsourcing monitoring\nto private AI companies"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 317621,
    "dDurationMs": 2917,
    "segs": [ {
      "utf8": "and AI contractors\nwith very little oversight."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 321621,
    "dDurationMs": 2917,
    "segs": [ {
      "utf8": "In 2020, during the George Floyd protests,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 324538,
    "dDurationMs": 1750,
    "segs": [ {
      "utf8": "agents infiltrated Facebook groups"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 326288,
    "dDurationMs": 5791,
    "segs": [ {
      "utf8": "and scraped public posts for indictments\nusing memes and comments on posts."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 332496,
    "dDurationMs": 3292,
    "segs": [ {
      "utf8": "These are the same tactics\nthat we use to fight violent extremists"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 335788,
    "dDurationMs": 3625,
    "segs": [ {
      "utf8": "and terrorists. And now I see\nthese same tactics being used"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 339413,
    "dDurationMs": 5958,
    "segs": [ {
      "utf8": "at home against journalists,\nstudents, activists, everyday people."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 345788,
    "dDurationMs": 4375,
    "segs": [ {
      "utf8": "It's a modern day McCarthyism\nwhere fear replaces evidence"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 350163,
    "dDurationMs": 2708,
    "segs": [ {
      "utf8": "and surveillance becomes a loyalty test."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 353579,
    "dDurationMs": 4709,
    "segs": [ {
      "utf8": "This isn't partisan hysteria,\nbut I am afraid of this new normal."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 360079,
    "dDurationMs": 5375,
    "segs": [ {
      "utf8": "What makes me the most afraid as I\nstand out here looking at everyone"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 365454,
    "dDurationMs": 3542,
    "segs": [ {
      "utf8": "in this room, is that this is a systemic\ndismantling of oversight,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 368996,
    "dDurationMs": 5292,
    "segs": [ {
      "utf8": "accountability and trust in a country\nthat used to export democratic values."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 374454,
    "dDurationMs": 3792,
    "segs": [ {
      "utf8": "It is now a case study\nin erosion of those values,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 378913,
    "dDurationMs": 1708,
    "segs": [ {
      "utf8": "and they're using social media"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 380621,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "and technology companies\nto amplify that erosion."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 384746,
    "dDurationMs": 1917,
    "segs": [ {
      "utf8": "And it's not just in the United States."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 386663,
    "dDurationMs": 4166,
    "segs": [ {
      "utf8": "It's happening in Venezuela\nand Romania and Pakistan and Kenya."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 392829,
    "dDurationMs": 1917,
    "segs": [ {
      "utf8": "This cannot be our new normal."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
