  }, {
    "tStartMs": 96230,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "You know you nailed\nthe prime-time address"
    } ]
  }, {
    "tStartMs": 97965,
    "dDurationMs": 1201,
    "segs": [ {
      "utf8": "when everyone's reaction is,"
    } ]
  }, {
    "tStartMs": 99166,
    "dDurationMs": 3136,
    "segs": [ {
      "utf8": "\"You interrupted\n'The Masked Singer' for this?\""
