  }, {
    "tStartMs": 47114,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "he was like, \"Oh, crap!"
    } ]
  }, {
    "tStartMs": 48582,
    "dDurationMs": 4104,
    "segs": [ {
      "utf8": "Uh, Pam, you're not fired.\nYou're redacted.\""
