    "tStartMs": 759726,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "-Unbelievable. Good timing."
    } ]
  }, {
    "tStartMs": 761161,
    "dDurationMs": 1969,
    "segs": [ {
      "utf8": "-Good timing.\n-\"I also licked it.\""
