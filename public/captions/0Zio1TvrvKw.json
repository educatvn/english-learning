  }, {
    "tStartMs": 247314,
    "dDurationMs": 2703,
    "segs": [ {
      "utf8": "Yep, the Artemis II crew is\non their way to the moon now."
    } ]
  }, {
    "tStartMs": 250017,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "I wanted to learn more\nabout this,"
