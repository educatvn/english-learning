    "segs": [ {
      "utf8": "[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 30564,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "The hardest thing\nabout getting fired by Trump"
