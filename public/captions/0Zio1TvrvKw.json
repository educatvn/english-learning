  }, {
    "tStartMs": 14281,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "Before we get to the show,\nlet's get to some news first."
    } ]
  }, {
    "tStartMs": 16450,
    "dDurationMs": 1601,
    "segs": [ {
      "utf8": "Everybody's talking about this."
