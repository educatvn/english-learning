  }, {
    "tStartMs": 747414,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "-[ Laughs ]\n-I don't deserve this at all."
    } ]
  }, {
    "tStartMs": 749249,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "-I also licked it."
