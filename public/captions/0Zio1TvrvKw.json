  }, {
    "tStartMs": 287754,
    "dDurationMs": 1569,
    "segs": [ {
      "utf8": "And now they're on their way,\nyou know,"
    } ]
  }, {
    "tStartMs": 289323,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "all the way to the moon like..."
    } ]
  }, {
    "tStartMs": 291024,
    "dDurationMs": 2570,
    "segs": [ {
      "utf8": "[ Imitating rockets firing ]"
    } ]
  }, {
    "tStartMs": 293594,
    "dDurationMs": 2535,
    "segs": [ {
      "utf8": "-Awesome!\nThen what's gonna happen?"
    } ]
  }, {
    "tStartMs": 296129,
    "dDurationMs": 4238,
    "segs": [ {
      "utf8": "-Oh, well, maybe asteroids,\nyou know, will fly by them,"
