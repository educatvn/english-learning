  }, {
    "tStartMs": 305272,
    "dDurationMs": 2536,
    "segs": [ {
      "utf8": "-Yeah. Oh!\nYeah, yeah, yeah, yeah, yeah."
    } ]
  }, {
    "tStartMs": 307808,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "-Ha! And they'll have to,\nlike, go to a different--"
