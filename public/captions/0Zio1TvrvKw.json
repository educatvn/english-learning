    "segs": [ {
      "utf8": "[ Laughter ]"
    } ]
  }, {
    "tStartMs": 676543,
    "dDurationMs": 3037,
    "segs": [ {
      "utf8": "Whatever.\nSo I go, I got cleaned off."
