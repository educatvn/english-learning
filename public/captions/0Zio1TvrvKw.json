  }, {
    "tStartMs": 719920,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "And I go, \"Oh, gosh.\"\nSo I go, \"All right.\""
    } ]
  }, {
    "tStartMs": 722022,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "I already know\nI'm gonna get pied,"
