  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 280,
    "dDurationMs": 3920,
    "segs": [ {
      "utf8": "Hello and welcome\nto Real Easy English."
    } ]
  }, {
    "tStartMs": 4200,
    "dDurationMs": 4360,
    "segs": [ {
      "utf8": "In this podcast, we have\nreal conversations in easy English"
    } ]
  }, {
    "tStartMs": 8560,
    "dDurationMs": 1240,
    "segs": [ {
      "utf8": "to help you learn."
    } ]
  }, {
    "tStartMs": 9800,
    "dDurationMs": 829,
    "segs": [ {
      "utf8": "I'm Beth."
    } ]
  }, {
    "tStartMs": 10629,
    "dDurationMs": 1531,
    "segs": [ {
      "utf8": "And I'm Georgie."
    } ]
  }, {
    "tStartMs": 12160,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "You can find a video version\nof this podcast"
    } ]
  }, {
    "tStartMs": 15080,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "and a worksheet to help you learn"
    } ]
  }, {
    "tStartMs": 17560,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "on our website, bbclearningenglish.com."
    } ]
  }, {
    "tStartMs": 27920,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "So how is your week going, Georgie?"
    } ]
  }, {
    "tStartMs": 30560,
    "dDurationMs": 1720,
    "segs": [ {
      "utf8": "It's going well. It's only Monday."
    } ]
  }, {
    "tStartMs": 32280,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "I'm already quite tired."
    } ]
  }, {
    "tStartMs": 34960,
    "dDurationMs": 1224,
    "segs": [ {
      "utf8": "How about you, Beth?"
    } ]
  }, {
    "tStartMs": 36184,
    "dDurationMs": 2228,
    "segs": [ {
      "utf8": "I'm OK. I'm not tired yet,"
    } ]
  }, {
    "tStartMs": 38412,
    "dDurationMs": 3148,
    "segs": [ {
      "utf8": "but give me till this afternoon. "
    } ]
  }, {
    "tStartMs": 41560,
    "dDurationMs": 2640,
    "segs": [ {
      "utf8": "So, Beth, what are we talking\nabout today?"
    } ]
  }, {
    "tStartMs": 44200,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "Today we're going to talk\nabout games."
    } ]
  }, {
    "tStartMs": 46560,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "The kind of games we like playing."
    } ]
  }, {
    "tStartMs": 49040,
    "dDurationMs": 2840,
    "segs": [ {
      "utf8": "Maybe games we don't like as much."
    } ]
  }, {
    "tStartMs": 51880,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "So shall we start the conversation?"
    } ]
  }, {
    "tStartMs": 53800,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "Yes, let's get started!"
    } ]
  }, {
    "tStartMs": 55280,
    "dDurationMs": 3320,
    "segs": [ {
      "utf8": "So, Beth, do you enjoy games?"
    } ]
  }, {
    "tStartMs": 58640,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "It depends on the kind of games."
    } ]
  }, {
    "tStartMs": 62360,
    "dDurationMs": 4240,
    "segs": [ {
      "utf8": "I think if it's something physical where\nyou're, I don't know,"
    } ]
  }, {
    "tStartMs": 66680,
    "dDurationMs": 4000,
    "segs": [ {
      "utf8": "running around a park or\nbeing silly – sporty things."
    } ]
  }, {
    "tStartMs": 70760,
    "dDurationMs": 2120,
    "segs": [ {
      "utf8": "Those kind of fun games I enjoy."
    } ]
  }, {
    "tStartMs": 72880,
    "dDurationMs": 4400,
    "segs": [ {
      "utf8": "But if it's like board games\nor card games,"
    } ]
  }, {
    "tStartMs": 77280,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "honestly, I don't really like them."
    } ]
  }, {
    "tStartMs": 80080,
    "dDurationMs": 920,
    "segs": [ {
      "utf8": "What about you?"
    } ]
  }, {
    "tStartMs": 81000,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "I do like games.\nI also like sporty games."
    } ]
  }, {
    "tStartMs": 84640,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "We did that in the park, didn't we,\nwith our team?"
    } ]
  }, {
    "tStartMs": 87080,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "We did, we did. Which was really fun\nand it's a good bonding experience."
    } ]
  }, {
    "tStartMs": 91880,
    "dDurationMs": 3480,
    "segs": [ {
      "utf8": "But I, unlike you,\ndo like card games."
    } ]
  }, {
    "tStartMs": 95360,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "And I enjoy playing them\nwith friends in the pub."
    } ]
  }, {
    "tStartMs": 99640,
    "dDurationMs": 1760,
    "segs": [ {
      "utf8": "I can be quite awkward"
    } ]
  }, {
    "tStartMs": 101400,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "so sometimes if I feel like I don't want\nto talk anymore, I suggest a game."
    } ]
  }, {
    "tStartMs": 106200,
    "dDurationMs": 3640,
    "segs": [ {
      "utf8": "And then we don't have to talk\nto people anymore."
    } ]
  }, {
    "tStartMs": 109840,
    "dDurationMs": 5280,
    "segs": [ {
      "utf8": "I feel like if it's a card game\nwhere you have, like, a question"
    } ]
  }, {
    "tStartMs": 115120,
    "dDurationMs": 3040,
    "segs": [ {
      "utf8": "and it's like, I don't know,\nyou've got five seconds,"
    } ]
  }, {
    "tStartMs": 118160,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "like, name three modes of transport."
    } ]
  }, {
    "tStartMs": 120760,
    "dDurationMs": 4560,
    "segs": [ {
      "utf8": "Those kind of like talking, fun,\nlaughing games with cards I enjoy."
    } ]
  }, {
    "tStartMs": 125320,
    "dDurationMs": 5760,
    "segs": [ {
      "utf8": "But if it's something to do with\nthe hearts and the diamonds... urgh no."
    } ]
  }, {
    "tStartMs": 131080,
    "dDurationMs": 2680,
    "segs": [ {
      "utf8": "I just think\nI'd rather have a conversation"
    } ]
  }, {
    "tStartMs": 133760,
    "dDurationMs": 3960,
    "segs": [ {
      "utf8": "and just talk to my friends\nor whoever I'm with."
    } ]
  }, {
    "tStartMs": 137720,
    "dDurationMs": 1880,
    "segs": [ {
      "utf8": "OK. So you don't like slow games,"
    } ]
  }, {
    "tStartMs": 139600,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "so probably you wouldn't like things\nlike Monopoly, which go on"
    } ]
  }, {
    "tStartMs": 143320,
    "dDurationMs": 2480,
    "segs": [ {
      "utf8": "for hours – your whole evening."
    } ]
  }, {
    "tStartMs": 145800,
    "dDurationMs": 5320,
    "segs": [ {
      "utf8": "Honestly, I think I had a bad experience\nas a child with Monopoly. This game..."
    } ]
  }, {
    "tStartMs": 151120,
    "dDurationMs": 3360,
    "segs": [ {
      "utf8": "We went away\nwith all of our neighbours."
    } ]
  }, {
    "tStartMs": 154480,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "There were lots of people,\nand we played a game of Monopoly"
    } ]
  }, {
    "tStartMs": 157880,
    "dDurationMs": 3440,
    "segs": [ {
      "utf8": "and it lasted about,\nI don't know, five hours."
    } ]
  }, {
    "tStartMs": 161320,
    "dDurationMs": 1320,
    "segs": [ {
      "utf8": "Probably not that long."
    } ]
  }, {
    "tStartMs": 162640,
    "dDurationMs": 1120,
    "segs": [ {
      "utf8": "Yeah. No, probably."
    } ]
  }, {
    "tStartMs": 163760,
    "dDurationMs": 1629,
    "segs": [ {
      "utf8": "Monopoly lasts for so long."
    } ]
  }, {
    "tStartMs": 165389,
    "dDurationMs": 1051,
    "segs": [ {
      "utf8": "It's so long."
    } ]
  }, {
    "tStartMs": 166440,
    "dDurationMs": 3069,
    "segs": [ {
      "utf8": "But also people get really aggressive\nand competitive with Monopoly,"
    } ]
  }, {
    "tStartMs": 169509,
    "dDurationMs": 1011,
    "segs": [ {
      "utf8": "don't they?"
    } ]
  }, {
    "tStartMs": 170520,
    "dDurationMs": 3023,
    "segs": [ {
      "utf8": "Is that because people cheat?"
    } ]
  }, {
    "tStartMs": 173543,
    "dDurationMs": 2777,
    "segs": [ {
      "utf8": "Yeah. Well, people can cheat.\nYeah, for sure."
    } ]
  }, {
    "tStartMs": 176320,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "But people get... It's like they\nthink the game is their real life"
    } ]
  }, {
    "tStartMs": 180480,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "and they get so angry\nand people lose friendships."
    } ]
  }, {
    "tStartMs": 184200,
    "dDurationMs": 2600,
    "segs": [ {
      "utf8": "That is my house!"
    } ]
  }, {
    "tStartMs": 186800,
    "dDurationMs": 1360,
    "segs": [ {
      "utf8": "Now, you said 'cheat'."
    } ]
  }, {
    "tStartMs": 188160,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "What does that mean?"
    } ]
  }, {
    "tStartMs": 189960,
    "dDurationMs": 7600,
    "segs": [ {
      "utf8": "Well, 'cheat' is to, kind of, lie\nor say something that isn't true."
    } ]
  }, {
    "tStartMs": 197560,
    "dDurationMs": 4800,
    "segs": [ {
      "utf8": "For example, you might pretend that you\nhave something and actually you don't."
    } ]
  }, {
    "tStartMs": 202360,
    "dDurationMs": 2160,
    "segs": [ {
      "utf8": "Cheating is seen as negative. "
    } ]
  }, {
    "tStartMs": 204520,
    "dDurationMs": 1000,
    "segs": [ {
      "utf8": "Yes."
    } ]
  }, {
    "tStartMs": 205520,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "It's like you're not following\nthe rules as well."
    } ]
  }, {
    "tStartMs": 208240,
    "dDurationMs": 1280,
    "segs": [ {
      "utf8": "That's it, yeah."
    } ]
  }, {
    "tStartMs": 209520,
    "dDurationMs": 2800,
    "segs": [ {
      "utf8": "Do you like cheating?"
    } ]
  }, {
    "tStartMs": 212320,
    "dDurationMs": 1800,
    "segs": [ {
      "utf8": "When I was a child,"
    } ]
  }, {
    "tStartMs": 214120,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "I liked to cheat."
    } ]
  }, {
    "tStartMs": 215560,
    "dDurationMs": 4280,
    "segs": [ {
      "utf8": "But no, because\nnow it just feels dishonest."
    } ]
  }, {
    "tStartMs": 219840,
    "dDurationMs": 5520,
    "segs": [ {
      "utf8": "If I... if I win a game, I want to win\nbecause I actually was good enough"
    } ]
  }, {
    "tStartMs": 225360,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "or did well enough to win."
    } ]
  }, {
    "tStartMs": 226800,
    "dDurationMs": 760,
    "segs": [ {
      "utf8": "Yes."
    } ]
  }, {
    "tStartMs": 227560,
    "dDurationMs": 1520,
    "segs": [ {
      "utf8": "Are you a cheat?"
    } ]
  }, {
    "tStartMs": 229080,
    "dDurationMs": 1200,
    "segs": [ {
      "utf8": "I'm not a cheat."
    } ]
  }, {
    "tStartMs": 230280,
    "dDurationMs": 2440,
    "segs": [ {
      "utf8": "Because I think I'm...\nI'm too much of a..."
    } ]
  }, {
    "tStartMs": 232720,
    "dDurationMs": 4320,
    "segs": [ {
      "utf8": "what we call a 'goody-goody', or someone\nwho likes to follow the rules."
    } ]
  }, {
    "tStartMs": 237040,
    "dDurationMs": 4160,
    "segs": [ {
      "utf8": "So, Georgie,\na quiz is a type of game, I guess."
    } ]
  }, {
    "tStartMs": 241200,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Do you like quizzes?"
    } ]
  }, {
    "tStartMs": 243280,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "Yes, I also like quizzes."
    } ]
  }, {
    "tStartMs": 245560,
    "dDurationMs": 2560,
    "segs": [ {
      "utf8": "I used to go quite a lot\nto something"
    } ]
  }, {
    "tStartMs": 248120,
    "dDurationMs": 3680,
    "segs": [ {
      "utf8": "we have a lot in the UK called\na pub quiz, where you go to a pub,"
    } ]
  }, {
    "tStartMs": 251800,
    "dDurationMs": 4840,
    "segs": [ {
      "utf8": "there are lots of teams and\nyou answer questions with your team."
    } ]
  }, {
    "tStartMs": 256640,
    "dDurationMs": 2280,
    "segs": [ {
      "utf8": "And I used to really enjoy that\nbecause"
    } ]
  }, {
    "tStartMs": 258920,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "a) you're socialising\nwith your friends in the pub,"
    } ]
  }, {
    "tStartMs": 262000,
    "dDurationMs": 3880,
    "segs": [ {
      "utf8": "but I find it really satisfying\nwhen you get the questions right."
    } ]
  }, {
    "tStartMs": 265880,
    "dDurationMs": 2451,
    "segs": [ {
      "utf8": "I've actually won a couple\nof pub quizzes."
    } ]
  }, {
    "tStartMs": 268331,
    "dDurationMs": 669,
    "segs": [ {
      "utf8": "Have you?"
    } ]
  }, {
    "tStartMs": 269000,
    "dDurationMs": 680,
    "segs": [ {
      "utf8": "Yeah."
    } ]
  }, {
    "tStartMs": 269680,
    "dDurationMs": 760,
    "segs": [ {
      "utf8": "Well done."
    } ]
  }, {
    "tStartMs": 270440,
    "dDurationMs": 4960,
    "segs": [ {
      "utf8": "It's really hard sometimes when all\nof the questions are general knowledge"
    } ]
  }, {
    "tStartMs": 275400,
    "dDurationMs": 2360,
    "segs": [ {
      "utf8": "that you don't know anything about."
    } ]
  }, {
    "tStartMs": 277760,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "That's really boring."
    } ]
  }, {
    "tStartMs": 279200,
    "dDurationMs": 2720,
    "segs": [ {
      "utf8": "But when you know\nthe questions, it's fun."
    } ]
  }, {
    "tStartMs": 288120,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "Let's recap the vocabulary we had\nduring the conversation."
    } ]
  }, {
    "tStartMs": 292200,
    "dDurationMs": 1560,
    "segs": [ {
      "utf8": "We had 'board games'."
    } ]
  }, {
    "tStartMs": 293760,
    "dDurationMs": 3400,
    "segs": [ {
      "utf8": "These are games\nwhere players usually move pieces"
    } ]
  }, {
    "tStartMs": 297160,
    "dDurationMs": 3720,
    "segs": [ {
      "utf8": "around a flat board like chess."
    } ]
  }, {
    "tStartMs": 300880,
    "dDurationMs": 4200,
    "segs": [ {
      "utf8": "We had 'quiz', which is a game\nwhere you answer questions."
    } ]
  }, {
    "tStartMs": 305080,
    "dDurationMs": 4120,
    "segs": [ {
      "utf8": "'Cheat' means to be dishonest\nwhen playing a game,"
    } ]
  }, {
    "tStartMs": 309200,
    "dDurationMs": 5400,
    "segs": [ {
      "utf8": "and you can also call a person a 'cheat'\nif they are dishonest in a game."
    } ]
  }, {
    "tStartMs": 314600,
    "dDurationMs": 5040,
    "segs": [ {
      "utf8": "We had 'goody-goody', which is someone\nwho likes following rules, like me."
    } ]
  }, {
    "tStartMs": 321520,
    "dDurationMs": 3000,
    "segs": [ {
      "utf8": "And you can do a 'quiz' on our website."
    } ]
  }, {
    "tStartMs": 324520,
    "dDurationMs": 5080,
    "segs": [ {
      "utf8": "Go to bbclearningenglish.com and\nyou'll also find a worksheet there"
    } ]
  }, {
    "tStartMs": 329600,
    "dDurationMs": 1653,
    "segs": [ {
      "utf8": "so you can test what you've learnt."
    } ]
  }, {
    "tStartMs": 331253,
    "dDurationMs": 864,
    "segs": [ {
      "utf8": "See you then."
    } ]
  }, {
    "tStartMs": 332117,
    "dDurationMs": 796,
    "segs": [ {
      "utf8": "Bye."
    } ]
  } ]
}
