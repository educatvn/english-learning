  "events": [ {
    "tStartMs": 1735,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "-Last night, or yesterday,\nwas April Fool's Day, right?"
    } ]
  }, {
    "tStartMs": 3237,
    "dDurationMs": 2235,
    "segs": [ {
      "utf8": "-Yep.\n-So, last year,"
    } ]
  }, {
    "tStartMs": 5472,
    "dDurationMs": 2870,
    "segs": [ {
      "utf8": "April Fool's Day --\nthis is true --"
    } ]
  }, {
    "tStartMs": 8342,
    "dDurationMs": 3436,
    "segs": [ {
      "utf8": "I went home, and my --\nmy kids were excited to see me,"
    } ]
  }, {
    "tStartMs": 11778,
    "dDurationMs": 2069,
    "segs": [ {
      "utf8": "and they go,\n\"Dad -- Dad's here! Dad's here!\""
    } ]
  }, {
    "tStartMs": 13847,
    "dDurationMs": 3537,
    "segs": [ {
      "utf8": "And my youngest, Franny, goes,\n\"Dad, can you put on something"
    } ]
  }, {
    "tStartMs": 17384,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "that you don't care\nif it gets messy?\""
    } ]
  }, {
    "tStartMs": 18986,
    "dDurationMs": 1234,
    "segs": [ {
      "utf8": "-Oh.\n[ Laughter ]"
    } ]
  }, {
    "tStartMs": 20220,
    "dDurationMs": 2136,
    "segs": [ {
      "utf8": "-And I go, \"Uh, yeah, okay.\nI just got home.\""
    } ]
  }, {
    "tStartMs": 22356,
    "dDurationMs": 2769,
    "segs": [ {
      "utf8": "I go, \"Sure, sure, sure.\"\nSo I put on a T-shirt,"
    } ]
  }, {
    "tStartMs": 25125,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "I go, she's probably\ngonna put makeup on me."
    } ]
  }, {
    "tStartMs": 26560,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "I don't know what.\nWhatever."
    } ]
  }, {
    "tStartMs": 27995,
    "dDurationMs": 1167,
    "segs": [ {
      "utf8": "So I go --\nI don't know what's happening."
    } ]
  }, {
    "tStartMs": 29162,
    "dDurationMs": 2236,
    "segs": [ {
      "utf8": "So I go, \"Yeah.\"\nAnd I come around the corner,"
    } ]
  }, {
    "tStartMs": 31398,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "and she hits me in the face\nwith a whipped-cream pie."
    } ]
  }, {
    "tStartMs": 34401,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ]
  }, {
    "tStartMs": 36003,
    "dDurationMs": 3136,
    "segs": [ {
      "utf8": "Whipped cream goes everywhere,\ngoes all over the walls."
    } ]
  }, {
    "tStartMs": 39139,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "Nothing on my shirt, nothing,\njust all over my face."
    } ]
  }, {
    "tStartMs": 41475,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "I go, \"What are you doing?\nWhy would you do that?\","
    } ]
  }, {
    "tStartMs": 45312,
    "dDurationMs": 2569,
    "segs": [ {
      "utf8": "and she goes, \"April Fool's.\"\n[ Laughter ]"
    } ]
  }, {
    "tStartMs": 47881,
    "dDurationMs": 4505,
    "segs": [ {
      "utf8": "No. No, that's -- that's not\nhow April Fool's works."
    } ]
  }, {
    "tStartMs": 52386,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "That's not April Fool's at all."
    } ]
  }, {
    "tStartMs": 54087,
    "dDurationMs": 2203,
    "segs": [ {
      "utf8": "So I go, \"That's bad.\"\nI go, \"I'm gonna get you --"
    } ]
  }, {
    "tStartMs": 56290,
    "dDurationMs": 1701,
    "segs": [ {
      "utf8": "I'm gonna get you back.\""
    } ]
  }, {
    "tStartMs": 57991,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "You know, \"I will.\nI'll think of something,\""
    } ]
  }, {
    "tStartMs": 59426,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "and she goes,\n\"Do you think I care?\""
    } ]
  }, {
    "tStartMs": 61161,
    "dDurationMs": 1368,
    "segs": [ {
      "utf8": "[ Audience exclaims ]"
    } ]
  }, {
    "tStartMs": 62529,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "\"Really?\nWhere are you getting sassy?"
    } ]
  }, {
    "tStartMs": 64164,
    "dDurationMs": 1201,
    "segs": [ {
      "utf8": "Where are you learning\nthat stuff from?\""
    } ]
  }, {
    "tStartMs": 65365,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "I go, \"Seriously,\nI'll do something."
    } ]
  }, {
    "tStartMs": 67234,
    "dDurationMs": 2202,
    "segs": [ {
      "utf8": "I'll put snakes in your bed\nor something,\" you know?"
    } ]
  }, {
    "tStartMs": 69436,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "She goes, \"I like snakes.\""
    } ]
  }, {
    "tStartMs": 70604,
    "dDurationMs": 1235,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ]
  }, {
    "tStartMs": 71839,
    "dDurationMs": 3036,
    "segs": [ {
      "utf8": "Whatever.\nSo I go, I got cleaned off,"
    } ]
  }, {
    "tStartMs": 74875,
    "dDurationMs": 3070,
    "segs": [ {
      "utf8": "I go, and I was putting her\nto bed, and I gave her a kiss."
    } ]
  }, {
    "tStartMs": 77945,
    "dDurationMs": 1601,
    "segs": [ {
      "utf8": "Said to her, \"I love you.\"\nI turn the lights out,"
    } ]
  }, {
    "tStartMs": 79546,
    "dDurationMs": 1702,
    "segs": [ {
      "utf8": "I go,\n\"Good night. I love you.\""
    } ]
  }, {
    "tStartMs": 81248,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "And I was leaving the room,\nshe goes, \"Dad?\""
    } ]
  }, {
    "tStartMs": 83083,
    "dDurationMs": 2236,
    "segs": [ {
      "utf8": "She goes,\n\"I don't really like snakes.\""
    } ]
  }, {
    "tStartMs": 85319,
    "dDurationMs": 1101,
    "segs": [ {
      "utf8": "[ Audience \"Awws\" ]"
    } ]
  }, {
    "tStartMs": 86420,
    "dDurationMs": 2502,
    "segs": [ {
      "utf8": "And I said,\n\"Do you think I care?\""
    } ]
  }, {
    "tStartMs": 88922,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "and shut the door.\n[ Laughter ]"
    } ]
  }, {
    "tStartMs": 90924,
    "dDurationMs": 4438,
    "segs": [ {
      "utf8": "'Cause they have to learn\neventually what real life is."
    } ]
  }, {
    "tStartMs": 95362,
    "dDurationMs": 2536,
    "segs": [ {
      "utf8": "-300 snakes.\n-So, anyways, last night,"
    } ]
  }, {
    "tStartMs": 97898,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "finished the show, a great show."
    } ]
  }, {
    "tStartMs": 99466,
    "dDurationMs": 2136,
    "segs": [ {
      "utf8": "We had so much fun.\nI'm on my way home."
    } ]
  }, {
    "tStartMs": 101602,
    "dDurationMs": 2569,
    "segs": [ {
      "utf8": "I got a text.\n'Cause now they're texting now."
    } ]
  }, {
    "tStartMs": 104171,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "And they go, \"Dad,\nwhen are you coming home?\""
    } ]
  }, {
    "tStartMs": 105973,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "I go, \"Soon. You'll see.\nI'll see you.\""
    } ]
  }, {
    "tStartMs": 107875,
    "dDurationMs": 2068,
    "segs": [ {
      "utf8": "She goes, \"Okay. Make\nsure you're wearing something"
    } ]
  }, {
    "tStartMs": 109943,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "you don't care\nif it gets messy.\""
    } ]
  }, {
    "tStartMs": 111778,
    "dDurationMs": 3437,
    "segs": [ {
      "utf8": "And then a picture\nof her looking, like, evil."
    } ]
  }, {
    "tStartMs": 115215,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "And I go, \"Oh, gosh.\"\nSo I go, \"All right.\""
    } ]
  }, {
    "tStartMs": 117317,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "I already know\nI'm gonna get pied,"
    } ]
  }, {
    "tStartMs": 118919,
    "dDurationMs": 1134,
    "segs": [ {
      "utf8": "or something's going to happen."
    } ]
  }, {
    "tStartMs": 120053,
    "dDurationMs": 1869,
    "segs": [ {
      "utf8": "So I went home,\nI put a T-shirt on,"
    } ]
  }, {
    "tStartMs": 121922,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "and I stood in the shower..."
    } ]
  }, {
    "tStartMs": 123423,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ]
  }, {
    "tStartMs": 124958,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "...and this happened."
    } ]
  }, {
    "tStartMs": 126393,
    "dDurationMs": 1535,
    "segs": [ {
      "utf8": "-[ Chuckling ]"
    } ]
  }, {
    "tStartMs": 131064,
    "dDurationMs": 1168,
    "segs": [ {
      "utf8": "-Dad?"
    } ]
  }, {
    "tStartMs": 134401,
    "dDurationMs": 1335,
    "segs": [ {
      "utf8": "-I'm so mad."
    } ]
  }, {
    "tStartMs": 135736,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "-Are you ready?\n-No."
    } ]
  }, {
    "tStartMs": 137471,
    "dDurationMs": 2669,
    "segs": [ {
      "utf8": "-[ Giggling ]\n-I'm gonna be so mad."
    } ]
  }, {
    "tStartMs": 140140,
    "dDurationMs": 2569,
    "segs": [ {
      "utf8": "I'm just standing here\n'cause I already know."
    } ]
  }, {
    "tStartMs": 142709,
    "dDurationMs": 1836,
    "segs": [ {
      "utf8": "-[ Laughs ]\n-I don't deserve this at all."
    } ]
  }, {
    "tStartMs": 144545,
    "dDurationMs": 2168,
    "segs": [ {
      "utf8": "-I also licked it."
    } ]
  }, {
    "tStartMs": 146713,
    "dDurationMs": 1435,
    "segs": [ {
      "utf8": "[ Laughter ]"
    } ]
  }, {
    "tStartMs": 148148,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "[ Cheers and applause ]"
    } ]
  }, {
    "tStartMs": 150884,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "-Oh, my God."
    } ]
  }, {
    "tStartMs": 155022,
    "dDurationMs": 1434,
    "segs": [ {
      "utf8": "-Unbelievable.\nGood timing."
    } ]
  }, {
    "tStartMs": 156456,
    "dDurationMs": 1969,
    "segs": [ {
      "utf8": "-Good timing.\n-\"I also licked it.\""
    } ]
  }, {
    "tStartMs": 158425,
    "dDurationMs": 2402,
    "segs": [ {
      "utf8": "\"'Cause I also liked it.\"\n-Whap!"
    } ]
  }, {
    "tStartMs": 160827,
    "dDurationMs": 1836,
    "segs": [ {
      "utf8": "-And her sister was\nvideoing it the whole time."
    } ]
  }, {
    "tStartMs": 162663,
    "dDurationMs": 2235,
    "segs": [ {
      "utf8": "Yeah. So, anyways,\nhappy April Fool's Day"
    } ]
  }, {
    "tStartMs": 164898,
    "dDurationMs": 2603,
    "segs": [ {
      "utf8": "to Winnie and Franny.\nYou guys got me good."
    } ]
  }, {
    "tStartMs": 167501,
    "dDurationMs": 1568,
    "segs": [ {
      "utf8": "Started a new tradition."
    } ]
  }, {
    "tStartMs": 169069,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "Stick around.\nWhen we come back,"
    } ]
  }, {
    "tStartMs": 170737,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "we've got puppies making\ntheir Final Four predictions."
    } ]
  }, {
    "tStartMs": 173540,
    "dDurationMs": 1135,
    "segs": [ {
      "utf8": "Come on back."
    } ]
  } ]
}
