      ]
    },
    {
      "tStartMs": 431000,
      "dDurationMs": 3560,
      "segs": [
        {
          "utf8": "or to beauty.\nTo beauty standards, you know?"
        }
      ]
    },
    {
      "tStartMs": 434560,
      "dDurationMs": 3320,
      "segs": [
        {
          "utf8": "People think that when\nyou are light skinned, you have money,"
        }
