    },
    {
      "tStartMs": 741320,
      "dDurationMs": 4360,
      "segs": [
        {
          "utf8": "to tell them the risks and\nto tell them why they should not go"
        }
      ]
    },
    {
      "tStartMs": 745680,
      "dDurationMs": 4320,
      "segs": [
        {
          "utf8": "into bleaching their children and the\nkind of complications they can develop"
        }
      ]
    },
    {
      "tStartMs": 750000,
      "dDurationMs": 3400,
      "segs": [
        {
          "utf8": "from bleaching their children\nand also from bleaching themselves."
        }
      ]
    },
    {
      "tStartMs": 753400,
