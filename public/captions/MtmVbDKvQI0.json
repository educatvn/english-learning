      "tStartMs": 779920,
      "dDurationMs": 2000,
      "segs": [
        {
          "utf8": "we shared it a little bit\nat the beginning,"
        }
      ]
    },
    {
      "tStartMs": 781920,
      "dDurationMs": 2400,
      "segs": [
        {
          "utf8": "but how is she doing now?"
        }
      ]
    },
    {
      "tStartMs": 784320,
      "dDurationMs": 2920,
      "segs": [
        {
          "utf8": "And what about the impact\non her family"
        }
      ]
    },
    {
      "tStartMs": 787240,
      "dDurationMs": 2680,
      "segs": [
        {
          "utf8": "from the effects\nof these creams as well?"
        }
      ]
    },
    {
      "tStartMs": 789920,
      "dDurationMs": 2160,
      "segs": [
        {
          "utf8": "So Fatima is presently doing okay."
        }
      ]
    },
    {
      "tStartMs": 792080,
      "dDurationMs": 4560,
      "segs": [
        {
          "utf8": "She's part of a group of women\nthat goes to different rural areas"
        }
      ]
    },
    {
      "tStartMs": 796640,
      "dDurationMs": 5080,
      "segs": [
        {
          "utf8": "to educate mothers and fathers to\non the dangers of skin bleaching."
        }
      ]
    },
    {
      "tStartMs": 801720,
      "dDurationMs": 2840,
      "segs": [
