    },
    {
      "tStartMs": 726320,
      "dDurationMs": 4800,
      "segs": [
        {
          "utf8": "as they call themselves,\nabout the risks and the danger of the"
        }
      ]
    },
    {
      "tStartMs": 731120,
      "dDurationMs": 2720,
      "segs": [
        {
          "utf8": "what they are doing, of the practice\nthey are actually doing."
        }
      ]
    },
    {
      "tStartMs": 733840,
      "dDurationMs": 4560,
      "segs": [
        {
          "utf8": "And they also\norganise workshops in various parts"
