    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 292289,
    "dDurationMs": 1868,
    "segs": [ {
      "utf8": "in the south to the Arctic."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 294825,
    "dDurationMs": 3136,
    "segs": [ {
      "utf8": "It also hitches a ride\nin the muscles of migratory geese,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 297961,
    "dDurationMs": 3904,
    "segs": [ {
      "utf8": "which fly in their millions each spring\nto the Arctic to nest,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 301865,
    "dDurationMs": 4504,
    "segs": [ {
      "utf8": "an event that's eagerly awaited by Arctic\ncarnivores and Arctic peoples alike."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 307270,
    "dDurationMs": 4171,
    "segs": [ {
      "utf8": "And finally, DNA of this parasite has been\nfound in the brains of Arctic char,"
