    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 271368,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "to Toxoplasma in North America,\nwhich is really confusing."
