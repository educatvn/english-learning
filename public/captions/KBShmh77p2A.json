    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 137267,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "In later life,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 139369,
    "dDurationMs": 4238,
    "segs": [ {
      "utf8": "as the host develops immunity,\nthe parasite goes into stealth mode."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 143607,
    "dDurationMs": 4271,
    "segs": [ {
      "utf8": "It hides in the nervous system\nquietly encysts in the muscles,"
