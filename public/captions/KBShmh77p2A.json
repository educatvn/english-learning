    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 156887,
    "dDurationMs": 4337,
    "segs": [ {
      "utf8": "who will unwillingly and unwittingly\nharbor the parasite in its muscles"
