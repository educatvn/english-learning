    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 244307,
    "dDurationMs": 5506,
    "segs": [ {
      "utf8": "For example, toxoplasmosis is responsible\nfor 10% of deaths due to HIV Aids,"
