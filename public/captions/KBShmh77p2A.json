    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 207604,
    "dDurationMs": 4938,
    "segs": [ {
      "utf8": "in uncooked or undercooked meat,\nor unwashed produce, unpasteurized milk,"
