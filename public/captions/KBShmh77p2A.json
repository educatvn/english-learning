    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 168865,
    "dDurationMs": 4638,
    "segs": [ {
      "utf8": "making rodents lose their fear of cats,\nwolves more likely to lead packs,"
