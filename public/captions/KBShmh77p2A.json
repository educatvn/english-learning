    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 266396,
    "dDurationMs": 1268,
    "segs": [ {
      "utf8": "Because, paradoxically,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 267731,
    "dDurationMs": 3637,
    "segs": [ {
      "utf8": "Canada's northern residents have some\nof the highest levels of human exposure"
