    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 285649,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "and freshwater currents,"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 287584,
    "dDurationMs": 4705,
    "segs": [ {
      "utf8": "making Toxoplasma a parasite pollutant\nflowing from cat friendly regions"
