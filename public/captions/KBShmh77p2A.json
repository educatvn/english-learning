    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 190587,
    "dDurationMs": 4238,
    "segs": [ {
      "utf8": "Because Does having many cats really\nincreases your risk of being exposed"
