    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 200363,
    "dDurationMs": 3738,
    "segs": [ {
      "utf8": "Toxoplasma is the most\nsuccessful parasite on Earth,"
