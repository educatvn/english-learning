    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 147878,
    "dDurationMs": 2602,
    "segs": [ {
      "utf8": "slowly dividing to increase its numbers."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 150781,
    "dDurationMs": 2969,
    "segs": [ {
      "utf8": "Toxoplasma also plays the long game,"
