    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 275305,
    "dDurationMs": 3537,
    "segs": [ {
      "utf8": "And I've spent 15 years trying\nto figure out why."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 278842,
    "dDurationMs": 2769,
    "segs": [ {
      "utf8": "Based on work by myself and many others,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 281711,
    "dDurationMs": 3938,
    "segs": [ {
      "utf8": "it now seems that this parasite\nenters the Arctic as oocysts in marine"
