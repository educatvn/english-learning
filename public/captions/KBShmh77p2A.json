    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 311608,
    "dDurationMs": 3036,
    "segs": [ {
      "utf8": "which is really strange since\ncold water fish are not supposed"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 314644,
    "dDurationMs": 1802,
    "segs": [ {
      "utf8": "to be good hosts for this parasite."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 317781,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "This elevated risk\nof exposure to Toxoplasma"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 323386,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "residents, who rely on harvested\nfish and wildlife for nutritional"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 326890,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "and cultural reasons."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 328825,
    "dDurationMs": 1935,
    "segs": [ {
      "utf8": "Many people still prepare their foods"
