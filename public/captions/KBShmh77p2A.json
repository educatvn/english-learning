    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 216913,
    "dDurationMs": 4438,
    "segs": [ {
      "utf8": "as many as three out of ten of you are\nunknowingly positive for this parasite,"
