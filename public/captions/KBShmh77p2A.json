    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 173770,
    "dDurationMs": 4271,
    "segs": [ {
      "utf8": "and people more likely to take\nrisks either as brilliant entrepreneurs"
