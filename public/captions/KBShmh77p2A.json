  "events": [ {
    "tStartMs": 0,
    "dDurationMs": 7000,
    "segs": [ {
      "utf8": "Transcriber: TRAN HOANG NHAN� DCVX\nReviewer: Pham Thien Trang"
    } ],
    "wpWinPosId": 1,
    "wsWinStyleId": 1
  }, {
    "tStartMs": 1565,
    "dDurationMs": 4204,
    "segs": [ {
      "utf8": "When I was a little girl, I always\nknew I wanted to be a veterinarian."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 6670,
    "dDurationMs": 4638,
    "segs": [ {
      "utf8": "When I played with Barbies, I viewed them\nas accessories for the Barbie horses."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 12042,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "I acquired every pet that I could,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 14211,
    "dDurationMs": 2336,
    "segs": [ {
      "utf8": "gradually sneaking a tough black"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 16547,
    "dDurationMs": 4371,
    "segs": [ {
      "utf8": "and white alley cat into the house\ndespite my sister's severe allergies."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 22286,
    "dDurationMs": 4337,
    "segs": [ {
      "utf8": "We dubbed him Pansy since his coloring\nreminded us of the flower,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 27190,
    "dDurationMs": 3571,
    "segs": [ {
      "utf8": "unaware that his name\nprobably gave him no street cred."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 37434,
    "dDurationMs": 6240,
    "segs": [ {
      "utf8": "of becoming a veterinarian.\nBut I am proud to stand before you today,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 43707,
    "dDurationMs": 3203,
    "segs": [ {
      "utf8": "a veterinarian and a scientist."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 46944,
    "dDurationMs": 2302,
    "segs": [ {
      "utf8": "And what a wild ride it has been."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 49546,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "During my final year\nof veterinary school here,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 52716,
    "dDurationMs": 4071,
    "segs": [ {
      "utf8": "I saw an advertisement\nto work on a weird parasite in wildlife"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 56787,
    "dDurationMs": 4971,
    "segs": [ {
      "utf8": "in Canada's north. And suddenly\nmy plans to be a pet vet shifted."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 62225,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "Parasites were fascinating."
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 64227,
    "dDurationMs": 3604,
    "segs": [ {
      "utf8": "complicated life cycles,\nthe ability to jump species,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 68031,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "even altering the behavior"
    } ],
    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 69533,
    "dDurationMs": 3737,
    "segs": [ {
      "utf8": "of their unwitting hosts like\nthe cat parasite Toxoplasma gondii."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 74304,
    "dDurationMs": 4104,
    "segs": [ {
      "utf8": "This microscopic parasite is pooped\nout by cats for only a few weeks"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 78408,
    "dDurationMs": 5239,
    "segs": [ {
      "utf8": "in their lifetime before the parasite\nloses its race against the immune system."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 83880,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "But it makes really good use\nof those few weeks,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 86683,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "putting out millions\nof oocysts into the environment."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 90387,
    "dDurationMs": 4204,
    "segs": [ {
      "utf8": "These are the egg stage of the parasite,\nwhich can survive for months to years."
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 95225,
    "dDurationMs": 4705,
    "segs": [ {
      "utf8": "And the best outcome from the parasite's\nviewpoint is to get back into a mouse"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 99930,
    "dDurationMs": 1902,
    "segs": [ {
      "utf8": "or some other prey species of a cat,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 101865,
    "dDurationMs": 2736,
    "segs": [ {
      "utf8": "where it can fully\ncomplete its life cycle."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 104601,
    "dDurationMs": 2803,
    "segs": [ {
      "utf8": "But Toxoplasma likes to stack the deck."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 108038,
    "dDurationMs": 3236,
    "segs": [ {
      "utf8": "If its unwilling host fails\nto become kitty food,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 111541,
    "dDurationMs": 4105,
    "segs": [ {
      "utf8": "it will settle for any other warm body,\nincluding hundreds of birds,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 115646,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "mammals and people. So when a host"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 119483,
    "dDurationMs": 4137,
    "segs": [ {
      "utf8": "with no previous immunity accidentally\ningests these invisible oocysts,"
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 123687,
    "dDurationMs": 1935,
    "segs": [ {
      "utf8": "the parasite goes into attack mode,"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 126089,
    "dDurationMs": 2870,
    "segs": [ {
      "utf8": "dividing rapidly and spreading\nthroughout the body."
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 129359,
    "dDurationMs": 4772,
    "segs": [ {
      "utf8": "They can cross the placenta and infect\nthe fetus, resulting in miscarriage,"
    } ],
    "wpWinPosId": 2,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 134164,
    "dDurationMs": 3103,
    "segs": [ {
      "utf8": "fetal abnormalities,\nand brain and eye issues."
