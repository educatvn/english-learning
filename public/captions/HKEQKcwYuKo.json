{
  "wireMagic": "pb3",
  "pens": [ {
  
  } ],
  "wsWinStyles": [ {
  
  } ],
  "wpWinPositions": [ {
  
  } ],
  "events": [ {
    "tStartMs": 0,
    "dDurationMs": 7000,
    "segs": [ {
      "utf8": "Transcriber: T K\nReviewer: Chan Ruo Xian"
    } ]
  }, {
    "tStartMs": 9714,
    "dDurationMs": 6506,
    "segs": [ {
      "utf8": "I wanted to tell you all about\nthe most important people in my life."
    } ]
  }, {
    "tStartMs": 17013,
    "dDurationMs": 6006,
    "segs": [ {
      "utf8": "They aren’t the ones that \nbring me flowers when I’m sick."
    } ]
  }, {
    "tStartMs": 24270,
    "dDurationMs": 2127,
    "segs": [ {
      "utf8": "That would be a lot of flowers."
    } ]
  }, {
    "tStartMs": 26981,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 29567,
    "dDurationMs": 4171,
    "segs": [ {
      "utf8": "They aren’t the ones that \ntilt their head and say,"
    } ]
  }, {
    "tStartMs": 33738,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "“How are you? Really?”"
    } ]
  }, {
    "tStartMs": 38117,
    "dDurationMs": 3337,
    "segs": [ {
      "utf8": "They're the ones that roast me in public."
    } ]
  }, {
    "tStartMs": 45124,
    "dDurationMs": 6590,
    "segs": [ {
      "utf8": "The ones that see me in my wheelchair\nand still make DUI jokes."
    } ]
  }, {
    "tStartMs": 51714,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 52715,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "Yes."
    } ]
  }, {
    "tStartMs": 55676,
    "dDurationMs": 6465,
    "segs": [ {
      "utf8": "The ones that don’t think I might shatter \nif they breathe on me too hard."
    } ]
  }, {
    "tStartMs": 63601,
    "dDurationMs": 2211,
    "segs": [ {
      "utf8": "I called them good jerks."
    } ]
  }, {
    "tStartMs": 66229,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 68648,
    "dDurationMs": 3962,
    "segs": [ {
      "utf8": "And I think we all need them."
    } ]
  }, {
    "tStartMs": 73319,
    "dDurationMs": 3045,
    "segs": [ {
      "utf8": "And I didn't always feel this way."
    } ]
  }, {
    "tStartMs": 77448,
    "dDurationMs": 4380,
    "segs": [ {
      "utf8": "When my body first\nstarted betraying me,"
    } ]
  }, {
    "tStartMs": 82620,
    "dDurationMs": 3295,
    "segs": [ {
      "utf8": "I just wanted someone to believe me."
    } ]
  }, {
    "tStartMs": 89460,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "See, I used to play sports."
    } ]
  }, {
    "tStartMs": 92755,
    "dDurationMs": 4421,
    "segs": [ {
      "utf8": "Soccer, cross country,\nbasketball, volleyball."
    } ]
  }, {
    "tStartMs": 98219,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "I’m competitive. It’s in my DNA."
    } ]
  }, {
    "tStartMs": 102932,
    "dDurationMs": 3670,
    "segs": [ {
      "utf8": "Amongst other things, apparently."
    } ]
  }, {
    "tStartMs": 107603,
    "dDurationMs": 1210,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 110356,
    "dDurationMs": 5506,
    "segs": [ {
      "utf8": "One day at a volleyball practice,\nI stumbled and"
    } ]
  }, {
    "tStartMs": 115862,
    "dDurationMs": 5922,
    "segs": [ {
      "utf8": "eventually, my coach benched me\nbecause he thought I was being lazy."
    } ]
  }, {
    "tStartMs": 122326,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "So I pivoted."
    } ]
  }, {
    "tStartMs": 125997,
    "dDurationMs": 4963,
    "segs": [ {
      "utf8": "I went from athlete to artsy party kid."
    } ]
  }, {
    "tStartMs": 132170,
    "dDurationMs": 2711,
    "segs": [ {
      "utf8": "No coordination required."
    } ]
  }, {
    "tStartMs": 135590,
    "dDurationMs": 1084,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 137383,
    "dDurationMs": 4713,
    "segs": [ {
      "utf8": "And honestly, \nit fit my new persona perfectly."
    } ]
  }, {
    "tStartMs": 143598,
    "dDurationMs": 3753,
    "segs": [ {
      "utf8": "That was until sophomore year\nof high school,"
    } ]
  }, {
    "tStartMs": 148019,
    "dDurationMs": 3837,
    "segs": [ {
      "utf8": "where clumsy turned to concerning."
    } ]
  }, {
    "tStartMs": 152398,
    "dDurationMs": 4880,
    "segs": [ {
      "utf8": "I couldn’t carry drinks \nwithout spilling them,"
    } ]
  }, {
    "tStartMs": 157278,
    "dDurationMs": 4338,
    "segs": [ {
      "utf8": "or walk up a staircase without a railing."
    } ]
  }, {
    "tStartMs": 162575,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "I mean, to make it worse,"
    } ]
  }, {
    "tStartMs": 164243,
    "dDurationMs": 5506,
    "segs": [ {
      "utf8": "my principal started\ncalling me into her office"
    } ]
  }, {
    "tStartMs": 170458,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "to smell my breath for alcohol."
    } ]
  }, {
    "tStartMs": 174754,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "I knew something was definitely wrong."
    } ]
  }, {
    "tStartMs": 179300,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "So I told my mom."
    } ]
  }, {
    "tStartMs": 182303,
    "dDurationMs": 3128,
    "segs": [ {
      "utf8": "And she wrote it off as"
    } ]
  }, {
    "tStartMs": 185431,
    "dDurationMs": 4213,
    "segs": [ {
      "utf8": "“attention-seeking middle child.”"
    } ]
  }, {
    "tStartMs": 192355,
    "dDurationMs": 5130,
    "segs": [ {
      "utf8": "My older sister had some\nserious health issues,"
    } ]
  }, {
    "tStartMs": 197485,
    "dDurationMs": 4588,
    "segs": [ {
      "utf8": "so my concerns were quickly dismissed."
    } ]
  }, {
    "tStartMs": 202657,
    "dDurationMs": 1376,
    "segs": [ {
      "utf8": "And that hurt."
    } ]
  }, {
    "tStartMs": 205952,
    "dDurationMs": 5880,
    "segs": [ {
      "utf8": "I started to believe that \nI might be making it up."
    } ]
  }, {
    "tStartMs": 214794,
    "dDurationMs": 5797,
    "segs": [ {
      "utf8": "When I was 18, I took myself to an ENT."
    } ]
  }, {
    "tStartMs": 221550,
    "dDurationMs": 3129,
    "segs": [ {
      "utf8": "And they sent me to a neurologist."
    } ]
  }, {
    "tStartMs": 224679,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "And between appointments,"
    } ]
  }, {
    "tStartMs": 228766,
    "dDurationMs": 5422,
    "segs": [ {
      "utf8": "I actually got fired from my job\nfor falling down a flight of stairs."
    } ]
  }, {
    "tStartMs": 235564,
    "dDurationMs": 2712,
    "segs": [ {
      "utf8": "They told me I was a liability."
    } ]
  }, {
    "tStartMs": 239735,
    "dDurationMs": 5339,
    "segs": [ {
      "utf8": "Things got real fast at the neurologist."
    } ]
  }, {
    "tStartMs": 246284,
    "dDurationMs": 4963,
    "segs": [ {
      "utf8": "They told me I either had \na tumor on my cerebellum,"
    } ]
  }, {
    "tStartMs": 251956,
    "dDurationMs": 2419,
    "segs": [ {
      "utf8": "or a genetic disease."
    } ]
  }, {
    "tStartMs": 254667,
    "dDurationMs": 5005,
    "segs": [ {
      "utf8": "And between us,\nI was rooting for the tumor."
    } ]
  }, {
    "tStartMs": 261465,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "Dark."
    } ]
  }, {
    "tStartMs": 265094,
    "dDurationMs": 4922,
    "segs": [ {
      "utf8": "It took about three months \nfor the genetic testing to come back,"
    } ]
  }, {
    "tStartMs": 271017,
    "dDurationMs": 4337,
    "segs": [ {
      "utf8": "and I finally had a diagnosis."
    } ]
  }, {
    "tStartMs": 276397,
    "dDurationMs": 1919,
    "segs": [ {
      "utf8": "Friedreich’s ataxia."
    } ]
  }, {
    "tStartMs": 279608,
    "dDurationMs": 6048,
    "segs": [ {
      "utf8": "A rare, progressive neurological disease."
    } ]
  }, {
    "tStartMs": 286615,
    "dDurationMs": 6966,
    "segs": [ {
      "utf8": "My mom burst into tears, and I celebrated."
    } ]
  }, {
    "tStartMs": 295458,
    "dDurationMs": 3461,
    "segs": [ {
      "utf8": "I was finally validated."
    } ]
  }, {
    "tStartMs": 300755,
    "dDurationMs": 5297,
    "segs": [ {
      "utf8": "I wasn’t crazy, but life keeps going."
    } ]
  }, {
    "tStartMs": 307428,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "I started college,"
    } ]
  }, {
    "tStartMs": 308929,
    "dDurationMs": 6340,
    "segs": [ {
      "utf8": "and people that I knew \nprior to my diagnosis"
    } ]
  }, {
    "tStartMs": 315269,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "started to pity me."
    } ]
  }, {
    "tStartMs": 319315,
    "dDurationMs": 1752,
    "segs": [ {
      "utf8": "Which confused me"
    } ]
  }, {
    "tStartMs": 321067,
    "dDurationMs": 5964,
    "segs": [ {
      "utf8": "because I didn’t feel any different\nthan I had the day prior."
    } ]
  }, {
    "tStartMs": 329658,
    "dDurationMs": 6757,
    "segs": [ {
      "utf8": "Their sympathies started disabling me \nmore than my body ever could."
    } ]
  }, {
    "tStartMs": 340378,
    "dDurationMs": 5255,
    "segs": [ {
      "utf8": "I started seeing myself \nthrough their lens."
    } ]
  }, {
    "tStartMs": 346384,
    "dDurationMs": 4045,
    "segs": [ {
      "utf8": "Useless. Fragile. Worthless."
    } ]
  }, {
    "tStartMs": 353015,
    "dDurationMs": 4254,
    "segs": [ {
      "utf8": "I started to feel like \nmy art degree was pointless."
    } ]
  }, {
    "tStartMs": 357895,
    "dDurationMs": 4004,
    "segs": [ {
      "utf8": "How was I going to use it\nif my body kept failing me?"
    } ]
  }, {
    "tStartMs": 363192,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "So I shifted my focus"
    } ]
  }, {
    "tStartMs": 366654,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "to boys and partying."
    } ]
  }, {
    "tStartMs": 371617,
    "dDurationMs": 4421,
    "segs": [ {
      "utf8": "And when you don't value yourself,"
    } ]
  }, {
    "tStartMs": 376080,
    "dDurationMs": 5672,
    "segs": [ {
      "utf8": "you will only attract\npeople who also do not value you."
    } ]
  }, {
    "tStartMs": 383546,
    "dDurationMs": 4421,
    "segs": [ {
      "utf8": "(Applause)"
    } ]
  }, {
    "tStartMs": 389844,
    "dDurationMs": 3795,
    "segs": [ {
      "utf8": "But then a blessing in disguise."
    } ]
  }, {
    "tStartMs": 394598,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "My boyfriend dumped me"
    } ]
  }, {
    "tStartMs": 397059,
    "dDurationMs": 4421,
    "segs": [ {
      "utf8": "right before Valentine’s Day."
    } ]
  }, {
    "tStartMs": 402731,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "Classic."
    } ]
  }, {
    "tStartMs": 407194,
    "dDurationMs": 6215,
    "segs": [ {
      "utf8": "I use self-deprecating humor to cope."
    } ]
  }, {
    "tStartMs": 414285,
    "dDurationMs": 5881,
    "segs": [ {
      "utf8": "And my friends started \nsuggesting I try stand up comedy."
    } ]
  }, {
    "tStartMs": 423377,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 426130,
    "dDurationMs": 2544,
    "segs": [ {
      "utf8": "Okay."
    } ]
  }, {
    "tStartMs": 430009,
    "dDurationMs": 1460,
    "segs": [ {
      "utf8": "Cute."
    } ]
  }, {
    "tStartMs": 434388,
    "dDurationMs": 1710,
    "segs": [ {
      "utf8": "I refused."
    } ]
  }, {
    "tStartMs": 436098,
    "dDurationMs": 5839,
    "segs": [ {
      "utf8": "I felt I was too dark\nand it was too personal."
    } ]
  }, {
    "tStartMs": 442605,
    "dDurationMs": 5755,
    "segs": [ {
      "utf8": "And then a friend invited me\nto an anti-valentine's day party."
    } ]
  }, {
    "tStartMs": 449487,
    "dDurationMs": 6840,
    "segs": [ {
      "utf8": "Local bands, loud music,\nand a flyer taped to the door"
    } ]
  }, {
    "tStartMs": 456911,
    "dDurationMs": 2919,
    "segs": [ {
      "utf8": "that read: “Comedian Fiona Cauley.”"
    } ]
  }, {
    "tStartMs": 460456,
    "dDurationMs": 3712,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 465044,
    "dDurationMs": 3795,
    "segs": [ {
      "utf8": "My name on the bill."
    } ]
  }, {
    "tStartMs": 469924,
    "dDurationMs": 2794,
    "segs": [ {
      "utf8": "I was horrified."
    } ]
  }, {
    "tStartMs": 474386,
    "dDurationMs": 1418,
    "segs": [ {
      "utf8": "And sober."
    } ]
  }, {
    "tStartMs": 476096,
    "dDurationMs": 1627,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 478766,
    "dDurationMs": 3253,
    "segs": [ {
      "utf8": "And with some liquid courage,"
    } ]
  }, {
    "tStartMs": 482645,
    "dDurationMs": 5881,
    "segs": [ {
      "utf8": "I sat in a La-Z-Boy chair\nwith my cane next to me"
    } ]
  }, {
    "tStartMs": 489109,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "and talked for ten minutes"
    } ]
  }, {
    "tStartMs": 491278,
    "dDurationMs": 6799,
    "segs": [ {
      "utf8": "about my breakup, my disability, \nand my depression."
    } ]
  }, {
    "tStartMs": 499495,
    "dDurationMs": 2294,
    "segs": [ {
      "utf8": "And for a few minutes,"
    } ]
  }, {
    "tStartMs": 502831,
    "dDurationMs": 4255,
    "segs": [ {
      "utf8": "I wasn't pitied. I wasn't fragile."
    } ]
  }, {
    "tStartMs": 508379,
    "dDurationMs": 1293,
    "segs": [ {
      "utf8": "I was funny."
    } ]
  }, {
    "tStartMs": 510089,
    "dDurationMs": 1334,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 512550,
    "dDurationMs": 4129,
    "segs": [ {
      "utf8": "And I wanted to feel more of that."
    } ]
  }, {
    "tStartMs": 518347,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "When I dove into comedy,"
    } ]
  }, {
    "tStartMs": 522601,
    "dDurationMs": 2586,
    "segs": [ {
      "utf8": "everything really changed."
    } ]
  }, {
    "tStartMs": 525187,
    "dDurationMs": 5005,
    "segs": [ {
      "utf8": "In green rooms,\nno one cared about my disability."
    } ]
  }, {
    "tStartMs": 531193,
    "dDurationMs": 1043,
    "segs": [ {
      "utf8": "If anything,"
    } ]
  }, {
    "tStartMs": 532236,
    "dDurationMs": 4588,
    "segs": [ {
      "utf8": "they were jealous of \nthe material I got from it."
    } ]
  }, {
    "tStartMs": 537283,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "(Laughter and applause)"
    } ]
  }, {
    "tStartMs": 541954,
    "dDurationMs": 1251,
    "segs": [ {
      "utf8": "Oh, man."
    } ]
  }, {
    "tStartMs": 545666,
    "dDurationMs": 5714,
    "segs": [ {
      "utf8": "I even remember a friend roasting me\nin a battle saying,"
    } ]
  }, {
    "tStartMs": 551755,
    "dDurationMs": 5840,
    "segs": [ {
      "utf8": "“Fiona is the only one that can get a DUI\non the way to her car.”"
    } ]
  }, {
    "tStartMs": 557595,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "(Laughter)"
    } ]
  }, {
    "tStartMs": 560639,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "I had found my people."
    } ]
  }, {
    "tStartMs": 566854,
    "dDurationMs": 4254,
    "segs": [ {
      "utf8": "Comedy made me feel capable again."
    } ]
  }, {
    "tStartMs": 571483,
    "dDurationMs": 1502,
    "segs": [ {
      "utf8": "Seen again."
    } ]
  }, {
    "tStartMs": 574361,
    "dDurationMs": 2920,
    "segs": [ {
      "utf8": "It wasn't wrapped in kindness."
    } ]
  }, {
    "tStartMs": 577906,
    "dDurationMs": 4714,
    "segs": [ {
      "utf8": "It was wrapped in honesty, wit,"
    } ]
  }, {
    "tStartMs": 582828,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "and the kind of humor that says,"
    } ]
  }, {
    "tStartMs": 586707,
    "dDurationMs": 3462,
    "segs": [ {
      "utf8": "“I see you, not your condition.”"
    } ]
  }, {
    "tStartMs": 591879,
    "dDurationMs": 3962,
    "segs": [ {
      "utf8": "Something my disability has shown me"
    } ]
  }, {
    "tStartMs": 595841,
    "dDurationMs": 5339,
    "segs": [ {
      "utf8": "is that society puts far too much value"
    } ]
  }, {
    "tStartMs": 601513,
    "dDurationMs": 3504,
    "segs": [ {
      "utf8": "on looks and physical ability."
    } ]
  }, {
    "tStartMs": 606226,
    "dDurationMs": 3170,
    "segs": [ {
      "utf8": "Especially on social media."
    } ]
  }, {
    "tStartMs": 609396,
    "dDurationMs": 6590,
    "segs": [ {
      "utf8": "Where everyone is flawless,\ntraveling, living a highlight reel."
    } ]
  }, {
    "tStartMs": 617363,
    "dDurationMs": 3795,
    "segs": [ {
      "utf8": "That stuff is fleeting. \nFor everyone."
    } ]
  }, {
    "tStartMs": 630668,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "The things that truly lasts"
    } ]
  }, {
    "tStartMs": 634630,
    "dDurationMs": 4421,
    "segs": [ {
      "utf8": "are when people reflect you back to you,"
    } ]
  }, {
    "tStartMs": 639593,
    "dDurationMs": 5839,
    "segs": [ {
      "utf8": "and they stop trying to protect you \nand start being real."
    } ]
  }, {
    "tStartMs": 646350,
    "dDurationMs": 4212,
    "segs": [ {
      "utf8": "I used to think kindness was the answer."
    } ]
  }, {
    "tStartMs": 652398,
    "dDurationMs": 3795,
    "segs": [ {
      "utf8": "I used to think the way \nyou should treat disabled people"
    } ]
  }, {
    "tStartMs": 656193,
    "dDurationMs": 3629,
    "segs": [ {
      "utf8": "is with sympathy, softness,"
    } ]
  }, {
    "tStartMs": 659822,
    "dDurationMs": 3628,
    "segs": [ {
      "utf8": "maybe even a little extra care."
    } ]
  }, {
    "tStartMs": 664785,
    "dDurationMs": 3003,
    "segs": [ {
      "utf8": "I don't believe that anymore."
    } ]
  }, {
    "tStartMs": 669832,
    "dDurationMs": 3169,
    "segs": [ {
      "utf8": "Sympathy didn't save me."
    } ]
  }, {
    "tStartMs": 674086,
    "dDurationMs": 3086,
    "segs": [ {
      "utf8": "Pity didn't rebuild me."
    } ]
  }, {
    "tStartMs": 679007,
    "dDurationMs": 1836,
    "segs": [ {
      "utf8": "Good jerks did."
    } ]
  }, {
    "tStartMs": 683554,
    "dDurationMs": 3962,
    "segs": [ {
      "utf8": "The people that refused to \ntiptoe around me"
    } ]
  }, {
    "tStartMs": 689101,
    "dDurationMs": 4838,
    "segs": [ {
      "utf8": "and saw me as still capable, still funny,"
    } ]
  }, {
    "tStartMs": 695149,
    "dDurationMs": 4212,
    "segs": [ {
      "utf8": "still worthy of being teased."
    } ]
  }, {
    "tStartMs": 702823,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "So, my challenge to you."
    } ]
  }, {
    "tStartMs": 706702,
    "dDurationMs": 5005,
    "segs": [ {
      "utf8": "Next time someone in your life\n is going through hell,"
    } ]
  }, {
    "tStartMs": 714501,
    "dDurationMs": 2461,
    "segs": [ {
      "utf8": "don’t just be good."
    } ]
  }, {
    "tStartMs": 717546,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "Be real."
    } ]
  }, {
    "tStartMs": 719590,
    "dDurationMs": 2460,
    "segs": [ {
      "utf8": "See them for what they are,"
    } ]
  }, {
    "tStartMs": 722384,
    "dDurationMs": 4421,
    "segs": [ {
      "utf8": "and not what you fear they might be."
    } ]
  }, {
    "tStartMs": 728474,
    "dDurationMs": 2168,
    "segs": [ {
      "utf8": "Risk the roast,"
    } ]
  }, {
    "tStartMs": 730642,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "share the laugh,"
    } ]
  }, {
    "tStartMs": 734480,
    "dDurationMs": 4421,
    "segs": [ {
      "utf8": "and remind them that they’re still here."
    } ]
  }, {
    "tStartMs": 740736,
    "dDurationMs": 2169,
    "segs": [ {
      "utf8": "And if they roast you back,"
    } ]
  }, {
    "tStartMs": 744198,
    "dDurationMs": 1668,
    "segs": [ {
      "utf8": "congratulations."
    } ]
  }, {
    "tStartMs": 747451,
    "dDurationMs": 1585,
    "segs": [ {
      "utf8": "You’ve found your people."
    } ]
  }, {
    "tStartMs": 750078,
    "dDurationMs": 1001,
    "segs": [ {
      "utf8": "Thank y'all."
    } ]
  }, {
    "tStartMs": 751622,
    "dDurationMs": 3253,
    "segs": [ {
      "utf8": "(Applause)"
    } ]
  } ]
}
