  }, {
    "tStartMs": 353557,
    "dDurationMs": 5631,
    "segs": [ {
      "utf8": "So I have five pieces of advice\nfor you before you open this Pandora's box"
    } ],
    "wpWinPosId": 3,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 359188,
    "dDurationMs": 2002,
    "segs": [ {
      "utf8": "of consumer DNA testing."
