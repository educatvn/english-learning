    "wpWinPosId": 4,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 361649,
    "dDurationMs": 5589,
    "segs": [ {
      "utf8": "One. Know that you may become a genetic\ninformant on your entire bloodline."
    } ],
    "wpWinPosId": 5,
    "wsWinStyleId": 2
  }, {
    "tStartMs": 368030,
    "dDurationMs": 3879,
    "segs": [ {
      "utf8": "My DNA is now in the system,\nand it may be subpoenaed."
