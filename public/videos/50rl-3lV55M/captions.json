  }, {
    "tStartMs": 372545,
    "dDurationMs": 3436,
    "segs": [ {
      "utf8": "Oh yes, he often mentions\nhis friend Paul."
    } ]
  }, {
    "tStartMs": 376448,
    "dDurationMs": 1991,
    "segs": [ {
      "utf8": "Paul? A friend?"
    } ]
  }, {
    "tStartMs": 378951,
    "dDurationMs": 2434,
    "segs": [ {
      "utf8": "l've never met anyone called Paul."
    } ]
  }, {
    "tStartMs": 381853,
    "dDurationMs": 1500,
    "segs": [ {
      "utf8": "They go to the gym together."
    } ]
  }, {
    "tStartMs": 383823,
    "dDurationMs": 2366,
    "segs": [ {
      "utf8": "To the gym? What for?"
    } ]
  }, {
    "tStartMs": 386858,
    "dDurationMs": 2400,
    "segs": [ {
      "utf8": "Exercise, swimming, you know. . ."
    } ]
  }, {
    "tStartMs": 389829,
    "dDurationMs": 2373,
    "segs": [ {
      "utf8": "Working out on the exercise machines."
    } ]
  }, {
    "tStartMs": 393565,
    "dDurationMs": 1468,
    "segs": [ {
      "utf8": "l wonder who Paul is. . ."
    } ]
  }, {
    "tStartMs": 397136,
    "dDurationMs": 1797,
    "segs": [ {
      "utf8": "Thanks for making the tea."
    } ]
  }, {
    "tStartMs": 399438,
    "dDurationMs": 1262,
    "segs": [ {
      "utf8": "Give me a hug, dear."
    } ]
  }, {
    "tStartMs": 400738,
    "dDurationMs": 1058,
    "segs": [ {
      "utf8": "lt's Ok."
    } ]
  }, {
    "tStartMs": 406744,
    "dDurationMs": 1331,
    "segs": [ {
      "utf8": "Hi, Elena, hi Agatha!"
    } ]
  }, {
    "tStartMs": 408647,
    "dDurationMs": 1607,
    "segs": [ {
      "utf8": "How was your day at the beauty centre?"
    } ]
  }, {
    "tStartMs": 410254,
    "dDurationMs": 1725,
    "segs": [ {
      "utf8": "Oh, fine, fine!"
    } ]
  }, {
    "tStartMs": 412584,
    "dDurationMs": 1470,
    "segs": [ {
      "utf8": "Have you just been to the gym?"
    } ]
  }, {
    "tStartMs": 414686,
    "dDurationMs": 1516,
    "segs": [ {
      "utf8": "Yes, how did you guess?"
    } ]
  }, {
    "tStartMs": 416721,
    "dDurationMs": 1080,
    "segs": [ {
      "utf8": "With Paul?"
