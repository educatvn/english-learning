  }, {
    "tStartMs": 130472,
    "dDurationMs": 2712,
    "segs": [ {
      "utf8": "A few days away at a beauty farm."
    } ]
  }, {
    "tStartMs": 133975,
    "dDurationMs": 3366,
    "segs": [ {
      "utf8": "That's a good idea, Victor.\nAre you doing anything tomorrow?"
