  }, {
    "tStartMs": 166442,
    "dDurationMs": 2300,
    "segs": [ {
      "utf8": "Come on Agatha, l know!\nl live here, remember?"
    } ]
  }, {
    "tStartMs": 168945,
    "dDurationMs": 3272,
    "segs": [ {
      "utf8": "lt's decided! Pack your bags, you're\ngoing to a beauty farm!"
