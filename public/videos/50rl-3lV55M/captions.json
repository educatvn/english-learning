  }, {
    "tStartMs": 172682,
    "dDurationMs": 1991,
    "segs": [ {
      "utf8": "Well, Ok!"
    } ]
  }, {
    "tStartMs": 175183,
    "dDurationMs": 3458,
    "segs": [ {
      "utf8": "Thank you. l'm going to call Betty\nnow and see if she wants to come."
    } ]
  }, {
    "tStartMs": 179388,
    "dDurationMs": 1991,
    "segs": [ {
      "utf8": "l'm so excited!"
    } ]
  }, {
    "tStartMs": 185628,
    "dDurationMs": 1440,
    "segs": [ {
      "utf8": "lt's nice being alone."
    } ]
  }, {
    "tStartMs": 188197,
    "dDurationMs": 2020,
    "segs": [ {
      "utf8": "Yes, just the 2 of us."
    } ]
  }, {
    "tStartMs": 190932,
    "dDurationMs": 1086,
    "segs": [ {
      "utf8": "What shall we do?"
    } ]
  }, {
    "tStartMs": 193269,
    "dDurationMs": 1197,
    "segs": [ {
      "utf8": "l can move a little closer..."
    } ]
  }, {
    "tStartMs": 195104,
    "dDurationMs": 2385,
    "segs": [ {
      "utf8": "But we promised Agatha\nwe would clean the house."
    } ]
  }, {
    "tStartMs": 198573,
    "dDurationMs": 1791,
    "segs": [ {
      "utf8": "Well, we can do it very quickly. . ."
