  }, {
    "tStartMs": 115424,
    "dDurationMs": 1493,
    "segs": [ {
      "utf8": "You seem a little sad."
    } ]
  }, {
    "tStartMs": 118161,
    "dDurationMs": 5004,
    "segs": [ {
      "utf8": "Well, l rearrange the furniture, but l\nalways feel sad when l leave Harold."
    } ]
  }, {
    "tStartMs": 124166,
    "dDurationMs": 1370,
    "segs": [ {
      "utf8": "l know what you need. . ."
    } ]
  }, {
    "tStartMs": 126535,
    "dDurationMs": 1101,
    "segs": [ {
      "utf8": "To have a shower?"
    } ]
  }, {
    "tStartMs": 128471,
    "dDurationMs": 1712,
    "segs": [ {
      "utf8": "No, you need to have a break."
