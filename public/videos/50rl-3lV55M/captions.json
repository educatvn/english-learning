  }, {
    "tStartMs": 109167,
    "dDurationMs": 2126,
    "segs": [ {
      "utf8": "l see. . ."
    } ]
  }, {
    "tStartMs": 113456,
    "dDurationMs": 1558,
    "segs": [ {
      "utf8": "Agatha are you, Ok?"
