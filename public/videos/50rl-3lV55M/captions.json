  }, {
    "tStartMs": 341313,
    "dDurationMs": 3662,
    "segs": [ {
      "utf8": "Do you think he's handsome,"
    } ]
  }, {
    "tStartMs": 345551,
    "dDurationMs": 2067,
    "segs": [ {
      "utf8": "well, physically attractive?"
    } ]
  }, {
    "tStartMs": 349621,
    "dDurationMs": 4080,
    "segs": [ {
      "utf8": "Well. . . yes... he's a handsome man."
    } ]
  }, {
    "tStartMs": 354459,
    "dDurationMs": 2434,
    "segs": [ {
      "utf8": "Are you attracted to him?"
    } ]
  }, {
    "tStartMs": 358496,
    "dDurationMs": 5199,
    "segs": [ {
      "utf8": "Er, l... Yes, he... he's attractive."
    } ]
  }, {
    "tStartMs": 363736,
    "dDurationMs": 1270,
    "segs": [ {
      "utf8": "l... l like him."
    } ]
  }, {
    "tStartMs": 365671,
    "dDurationMs": 1490,
    "segs": [ {
      "utf8": "l'm a bit worried. . ."
    } ]
  }, {
    "tStartMs": 368941,
    "dDurationMs": 3260,
    "segs": [ {
      "utf8": "Does he ever talk about his friends?"
