  }, {
    "tStartMs": 262104,
    "dDurationMs": 830,
    "segs": [ {
      "utf8": "Ok."
    } ]
  }, {
    "tStartMs": 262971,
    "dDurationMs": 1172,
    "segs": [ {
      "utf8": "- Bye.\n- Bye, see you!"
