  }, {
    "tStartMs": 259735,
    "dDurationMs": 830,
    "segs": [ {
      "utf8": "Ok."
    } ]
  }, {
    "tStartMs": 261102,
    "dDurationMs": 1002,
    "segs": [ {
      "utf8": "Good. l'll...\nl'll see you later."
