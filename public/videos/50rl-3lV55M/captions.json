    "tStartMs": 302307,
    "dDurationMs": 1024,
    "segs": [ {
      "utf8": "That's a good idea."
    } ]
  }, {
    "tStartMs": 303709,
    "dDurationMs": 2195,
    "segs": [ {
      "utf8": "So it's not only for women."
