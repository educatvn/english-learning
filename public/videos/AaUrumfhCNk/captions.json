  }, {
    "tStartMs": 505245,
    "dDurationMs": 3163,
    "segs": [ {
      "utf8": "There's this enormous market there. . ."
    } ]
  }, {
    "tStartMs": 508816,
    "dDurationMs": 2616,
    "segs": [ {
      "utf8": "Of course. Anything else?"
    } ]
  }, {
    "tStartMs": 511653,
    "dDurationMs": 1501,
    "segs": [ {
      "utf8": "Well, actually. . ."
    } ]
  }, {
    "tStartMs": 513154,
    "dDurationMs": 2853,
    "segs": [ {
      "utf8": "No, no, no, l won't have much time\nfor shopping."
    } ]
  }, {
    "tStartMs": 516556,
    "dDurationMs": 2054,
    "segs": [ {
      "utf8": "What else are you going to do there?"
