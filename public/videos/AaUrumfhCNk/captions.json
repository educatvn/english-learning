  }, {
    "tStartMs": 483682,
    "dDurationMs": 537,
    "segs": [ {
      "utf8": "lt's Ok."
    } ]
  }, {
    "tStartMs": 484391,
    "dDurationMs": 2080,
    "segs": [ {
      "utf8": "Well, maybe next time."
    } ]
  }, {
    "tStartMs": 488061,
    "dDurationMs": 5710,
    "segs": [ {
      "utf8": "You are going to look\nspectacular on Saturday!"
