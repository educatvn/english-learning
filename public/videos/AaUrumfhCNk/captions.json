    "tStartMs": 554796,
    "dDurationMs": 1667,
    "segs": [ {
      "utf8": "Don't you say anything. . ."
    } ]
  }, {
    "tStartMs": 556463,
    "dDurationMs": 978,
    "segs": [ {
      "utf8": "l can't believe. . ."
    } ]
  }, {
    "tStartMs": 557441,
    "dDurationMs": 7402,
    "segs": [ {
      "utf8": "Hello? Hello Harry! lt's Harry.\nHello sweetheart!"
