  }, {
    "tStartMs": 494969,
    "dDurationMs": 1949,
    "segs": [ {
      "utf8": "Just spectacular!"
    } ]
  }, {
    "tStartMs": 497437,
    "dDurationMs": 1515,
    "segs": [ {
      "utf8": "Thank you."
    } ]
  }, {
    "tStartMs": 500040,
    "dDurationMs": 4965,
    "segs": [ {
      "utf8": "Oh, Victor, can you buy me some\nof that lovely Brie in Boulogne?"
