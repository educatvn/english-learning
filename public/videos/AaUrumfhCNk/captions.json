  }, {
    "tStartMs": 618700,
    "dDurationMs": 2727,
    "segs": [ {
      "utf8": "You're pretending to be. . ."
    } ]
  }, {
    "tStartMs": 621577,
    "dDurationMs": 2873,
    "segs": [ {
      "utf8": ". . . l'm pretending to be on an airplane."
