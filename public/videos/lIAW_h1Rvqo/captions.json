    "dDurationMs": 6395,
    "segs": [ {
      "utf8": "Well, l think that we are\ngoing to have a wonderful\ntime with Elena staying here."
    } ]
  }, {
    "tStartMs": 467726,
    "dDurationMs": 2095,
    "segs": [ {
      "utf8": "Yes, a wonderful time."
    } ]
  }, {
    "tStartMs": 469997,
    "dDurationMs": 799,
    "segs": [ {
      "utf8": "Thank you."
    } ]
  }, {
    "tStartMs": 472765,
    "dDurationMs": 1806,
    "segs": [ {
      "utf8": "How long are you going to be in London?"
    } ]
  }, {
    "tStartMs": 475469,
    "dDurationMs": 5678,
    "segs": [ {
      "utf8": "That's right: get to know each other\nand. . . l'll go start dinner."
    } ]
  }, {
    "tStartMs": 481408,
    "dDurationMs": 1096,
    "segs": [ {
      "utf8": "Can l help you, Agatha?"
    } ]
  }, {
    "tStartMs": 482504,
    "dDurationMs": 1624,
    "segs": [ {
      "utf8": "No! Sweet girl."
    } ]
  }, {
    "tStartMs": 484544,
    "dDurationMs": 1355,
    "segs": [ {
      "utf8": "You stay right where you are!"
    } ]
  }, {
    "tStartMs": 486512,
    "dDurationMs": 933,
    "segs": [ {
      "utf8": "All right."
    } ]
  }, {
    "tStartMs": 488247,
    "dDurationMs": 787,
    "segs": [ {
      "utf8": "When did you arrive?"
    } ]
  }, {
    "tStartMs": 490449,
    "dDurationMs": 60,
    "segs": [ {
      "utf8": "Today."
    } ]
  }, {
    "tStartMs": 492283,
    "dDurationMs": 3885,
    "segs": [ {
      "utf8": "And you'll be staying with us\n. . . until you go back to Spain?"
    } ]
  }, {
    "tStartMs": 496168,
    "dDurationMs": 1427,
    "segs": [ {
      "utf8": "When?"
    } ]
  }, {
    "tStartMs": 498724,
    "dDurationMs": 4208,
    "segs": [ {
      "utf8": "l go back to Madrid after my English course."
    } ]
  }, {
    "tStartMs": 503297,
    "dDurationMs": 2861,
    "segs": [ {
      "utf8": "And my language course is 8 weeks."
    } ]
  }, {
    "tStartMs": 511638,
    "dDurationMs": 3520,
    "segs": [ {
      "utf8": "l'm sorry. My sister is a little. . .eccentric."
    } ]
  }, {
    "tStartMs": 515208,
    "dDurationMs": 2050,
    "segs": [ {
      "utf8": "Your sister is very nice."
    } ]
  }, {
    "tStartMs": 519044,
    "dDurationMs": 2038,
    "segs": [ {
      "utf8": "Tell me. . . tell me about your family, Elena."
    } ]
  }, {
    "tStartMs": 522281,
    "dDurationMs": 3852,
    "segs": [ {
      "utf8": "l have many... sisters and brothers."
    } ]
  }, {
    "tStartMs": 526719,
    "dDurationMs": 1098,
    "segs": [ {
      "utf8": "Are you the oldest?"
    } ]
  }, {
    "tStartMs": 528355,
    "dDurationMs": 5405,
    "segs": [ {
      "utf8": "No. l have 2 brothers and 1\nsister, who are older. . ."
    } ]
  }, {
    "tStartMs": 534594,
    "dDurationMs": 1117,
    "segs": [ {
      "utf8": ". . . older? Older than you."
    } ]
  }, {
    "tStartMs": 536061,
    "dDurationMs": 699,
    "segs": [ {
      "utf8": "Yes."
    } ]
  }, {
    "tStartMs": 536929,
    "dDurationMs": 6280,
    "segs": [ {
      "utf8": "And. . . my mother is Carmen\nand my father is Fernando."
    } ]
  }, {
    "tStartMs": 544671,
    "dDurationMs": 3238,
    "segs": [ {
      "utf8": "And this is your first time\naway from Madrid?"
    } ]
  }, {
    "tStartMs": 548275,
    "dDurationMs": 5386,
    "segs": [ {
      "utf8": "Yes. l am happy to be in London but\nalso l am a little sad."
    } ]
  }, {
    "tStartMs": 554314,
    "dDurationMs": 2321,
    "segs": [ {
      "utf8": "You miss. . . you miss your big family?"
    } ]
  }, {
    "tStartMs": 557584,
    "dDurationMs": 4176,
    "segs": [ {
      "utf8": "Yes, but you are very kind\nand you are very nice."
    } ]
  }, {
    "tStartMs": 563590,
    "dDurationMs": 569,
    "segs": [ {
      "utf8": "Thank you."
    } ]
  }, {
    "tStartMs": 564159,
    "dDurationMs": 1831,
    "segs": [ {
      "utf8": "And what does your. . ."
    } ]
  }, {
    "tStartMs": 565990,
    "dDurationMs": 3753,
    "segs": [ {
      "utf8": "What does your father do back in Madrid?\nWhat's his job?"
    } ]
  }, {
    "tStartMs": 570791,
    "dDurationMs": 4705,
    "segs": [ {
      "utf8": "He makes. . . this. . . and this. . ."
    } ]
  }, {
    "tStartMs": 579739,
    "dDurationMs": 1208,
    "segs": [ {
      "utf8": "Oh! He makes. . . he makes furniture!"
    } ]
  }, {
    "tStartMs": 581608,
    "dDurationMs": 913,
    "segs": [ {
      "utf8": "Yes, yes."
    } ]
  }, {
    "tStartMs": 583310,
    "dDurationMs": 1809,
    "segs": [ {
      "utf8": "And your mother? Does she work?"
    } ]
  }, {
    "tStartMs": 585770,
    "dDurationMs": 6475,
    "segs": [ {
      "utf8": "My mother works very hard in the\nhouse. . . cooking, washing, cleaning."
    } ]
  }, {
    "tStartMs": 592669,
    "dDurationMs": 2321,
    "segs": [ {
      "utf8": "Your mother is a housewife."
    } ]
  }, {
    "tStartMs": 595822,
    "dDurationMs": 1167,
    "segs": [ {
      "utf8": "- A housewife.\n- Housewife."
    } ]
  }, {
    "tStartMs": 598090,
    "dDurationMs": 2104,
    "segs": [ {
      "utf8": "So. . . how are you getting along?"
    } ]
  }, {
    "tStartMs": 601094,
    "dDurationMs": 2401,
    "segs": [ {
      "utf8": "Just fine thanks, Agatha."
    } ]
  }, {
    "tStartMs": 604631,
    "dDurationMs": 1188,
    "segs": [ {
      "utf8": "Very fine. Thank you."
    } ]
  }, {
    "tStartMs": 606198,
    "dDurationMs": 3809,
    "segs": [ {
      "utf8": "Wonderful! Now come\nand help me set the table."
    } ]
  }, {
    "tStartMs": 611705,
    "dDurationMs": 526,
    "segs": [ {
      "utf8": "Ok."
    } ]
  }, {
    "tStartMs": 612947,
    "dDurationMs": 786,
    "segs": [ {
      "utf8": "Can l help?"
    } ]
  }, {
    "tStartMs": 615232,
    "dDurationMs": 2050,
    "segs": [ {
      "utf8": "Yes, please. Set the table, dear."
    } ]
  }, {
    "tStartMs": 617282,
    "dDurationMs": 1652,
    "segs": [ {
      "utf8": "Set the table?"
    } ]
  }, {
    "tStartMs": 619583,
    "dDurationMs": 771,
    "segs": [ {
      "utf8": "l'll help you."
    } ]
  }, {
    "tStartMs": 622005,
    "dDurationMs": 1638,
    "segs": [ {
      "utf8": "That's a good boy."
    } ]
  }, {
    "tStartMs": 625342,
    "dDurationMs": 1467,
    "segs": [ {
      "utf8": "The plates."
    } ]
  }, {
    "tStartMs": 628478,
    "dDurationMs": 2864,
    "segs": [ {
      "utf8": "ls your boyfriend Harold\neating with us?"
    } ]
  }, {
    "tStartMs": 631882,
    "dDurationMs": 2659,
    "segs": [ {
      "utf8": "No, Harold is in Oxford."
    } ]
  }, {
    "tStartMs": 634919,
    "dDurationMs": 2948,
    "segs": [ {
      "utf8": "Harold's bank has an office in Oxford."
    } ]
  }, {
    "tStartMs": 640224,
    "dDurationMs": 1317,
    "segs": [ {
      "utf8": "The knives and forks."
    } ]
  }, {
    "tStartMs": 646764,
    "dDurationMs": 6629,
    "segs": [ {
      "utf8": "Knife. . . fork and. . . spoon!"
    } ]
  }, {
    "tStartMs": 656307,
    "dDurationMs": 785,
    "segs": [ {
      "utf8": "ls the table set?"
    } ]
  }, {
    "tStartMs": 658375,
    "dDurationMs": 825,
    "segs": [ {
      "utf8": "Yes, Agatha."
    } ]
  }, {
    "tStartMs": 659200,
    "dDurationMs": 2824,
    "segs": [ {
      "utf8": "Good. Sit down, please.\nDinner is ready."
    } ]
  }, {
    "tStartMs": 663447,
    "dDurationMs": 1153,
    "segs": [ {
      "utf8": "Are we having dinner now?"
    } ]
  }, {
    "tStartMs": 665316,
    "dDurationMs": 835,
    "segs": [ {
      "utf8": "Why of course, dear."
    } ]
  }, {
    "tStartMs": 667250,
    "dDurationMs": 875,
    "segs": [ {
      "utf8": "What are we having?"
    } ]
  }, {
    "tStartMs": 668552,
    "dDurationMs": 4947,
    "segs": [ {
      "utf8": "We are having soup and a salad.\nDo you like chicken soup, Elena?"
    } ]
  }, {
    "tStartMs": 674024,
    "dDurationMs": 1592,
    "segs": [ {
      "utf8": "Yes. Thank you."
    } ]
  }, {
    "tStartMs": 676594,
    "dDurationMs": 2606,
    "segs": [ {
      "utf8": "Please, put the napkins\non the table, Victor!"
    } ]
  }, {
    "tStartMs": 679396,
    "dDurationMs": 3437,
    "segs": [ {
      "utf8": "Sorry. Here they are."
    } ]
  }, {
    "tStartMs": 683734,
    "dDurationMs": 2916,
    "segs": [ {
      "utf8": "My silly Victor he forgets everything!"
    } ]
  }, {
    "tStartMs": 687470,
    "dDurationMs": 1695,
    "segs": [ {
      "utf8": "Everything!"
    } ]
  }, {
    "tStartMs": 691642,
    "dDurationMs": 3437,
    "segs": [ {
      "utf8": "Here's your soup. . .\nhelp yourself to the bread."
    } ]
  }, {
    "tStartMs": 695079,
    "dDurationMs": 781,
    "segs": [ {
      "utf8": "Thank you, Agatha."
    } ]
  }, {
    "tStartMs": 696513,
    "dDurationMs": 3298,
    "segs": [ {
      "utf8": "You're welcome, my dear!\nlt's so nice to have you here."
    } ]
  }, {
    "tStartMs": 699951,
    "dDurationMs": 2010,
    "segs": [ {
      "utf8": "Yes. lt's. . . it's nice to have you here."
    } ]
  }, {
    "tStartMs": 702419,
    "dDurationMs": 1392,
    "segs": [ {
      "utf8": "Thank you. That is very kind."
    } ]
  }, {
    "tStartMs": 704222,
    "dDurationMs": 2188,
    "segs": [ {
      "utf8": "Nonsense. Now, let's eat!"
    } ]
  }, {
    "tStartMs": 711529,
    "dDurationMs": 756,
    "segs": [ {
      "utf8": "How's your soup?"
    } ]
  }, {
    "tStartMs": 713063,
    "dDurationMs": 774,
    "segs": [ {
      "utf8": "lt's delicious."
    } ]
  }, {
    "tStartMs": 717958,
    "dDurationMs": 2424,
    "segs": [ {
      "utf8": "What's wrong, dear?\nDon't you like it?"
    } ]
  }, {
    "tStartMs": 722709,
    "dDurationMs": 1034,
    "segs": [ {
      "utf8": "Well. . ."
    } ]
  }, {
    "tStartMs": 723743,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "You don't feel well?"
    } ]
  }, {
    "tStartMs": 725478,
    "dDurationMs": 5874,
    "segs": [ {
      "utf8": "No, l'm sorry. lt is a bit early for\nme. l am not really hungry."
    } ]
  }, {
    "tStartMs": 731352,
    "dDurationMs": 1301,
    "segs": [ {
      "utf8": "Not hungry?"
    } ]
  }, {
    "tStartMs": 732653,
    "dDurationMs": 3120,
    "segs": [ {
      "utf8": "What time does your family eat\ndinner back in Spain?"
    } ]
  }, {
    "tStartMs": 736323,
    "dDurationMs": 2727,
    "segs": [ {
      "utf8": "We eat dinner at 10 o'clock at home."
    } ]
  }, {
    "tStartMs": 739160,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "Well, imagine that!"
    } ]
  }, {
    "tStartMs": 741262,
    "dDurationMs": 1635,
    "segs": [ {
      "utf8": "We're usually in bed before midnight!"
    } ]
  }, {
    "tStartMs": 744131,
    "dDurationMs": 4766,
    "segs": [ {
      "utf8": "Elena, darling, you must forgive our\nstrange English habits."
    } ]
  }, {
    "tStartMs": 749536,
    "dDurationMs": 2112,
    "segs": [ {
      "utf8": "No, it is all a bit strange for me now."
    } ]
  }, {
    "tStartMs": 752906,
    "dDurationMs": 3642,
    "segs": [ {
      "utf8": "My poor dear! You must be exhausted!"
    } ]
  }, {
    "tStartMs": 757611,
    "dDurationMs": 2136,
    "segs": [ {
      "utf8": "Maybe you should go to bed soon, Elena."
    } ]
  }, {
    "tStartMs": 761148,
    "dDurationMs": 2049,
    "segs": [ {
      "utf8": "Yes, please. l'm sorry."
    } ]
  }, {
    "tStartMs": 763784,
    "dDurationMs": 2832,
    "segs": [ {
      "utf8": "No! Don't worry. You go and sleep."
    } ]
  }, {
    "tStartMs": 766620,
    "dDurationMs": 1296,
    "segs": [ {
      "utf8": "Thank you both."
    } ]
  }, {
    "tStartMs": 769724,
    "dDurationMs": 492,
    "segs": [ {
      "utf8": "Good night, Elena."
    } ]
  }, {
    "tStartMs": 770630,
    "dDurationMs": 535,
    "segs": [ {
      "utf8": "Night."
    } ]
  }, {
    "tStartMs": 772125,
    "dDurationMs": 1039,
    "segs": [ {
      "utf8": "Sleep well dear!"
    } ]
  }, {
    "tStartMs": 776750,
    "dDurationMs": 2783,
    "segs": [ {
      "utf8": "Not again, Agatha. Don't do this to me again!"
    } ]
  }, {
    "tStartMs": 780283,
    "dDurationMs": 3417,
    "segs": [ {
      "utf8": "Why, my darling brother.\nWhat are you talking about?"
    } ]
  }, {
    "tStartMs": 798410,
    "dDurationMs": 525,
    "segs": [ {
      "utf8": "Oh!"
    } ]
  }, {
    "tStartMs": 799309,
    "dDurationMs": 2477,
    "segs": [ {
      "utf8": "Good morning! You're up early!"
    } ]
  }, {
    "tStartMs": 802547,
    "dDurationMs": 2930,
    "segs": [ {
      "utf8": "Yes, l'm looking for. . . for my. . ."
    } ]
  }, {
    "tStartMs": 806617,
    "dDurationMs": 1118,
    "segs": [ {
      "utf8": "For your keys?"
    } ]
  }, {
    "tStartMs": 807919,
    "dDurationMs": 1300,
    "segs": [ {
      "utf8": "- Yes.\n- They're here."
    } ]
  }, {
    "tStartMs": 809219,
    "dDurationMs": 1900,
    "segs": [ {
      "utf8": "Thank you. Thank you Victor."
    } ]
  }, {
    "tStartMs": 811622,
    "dDurationMs": 2369,
    "segs": [ {
      "utf8": "Do your classes start today?"
    } ]
  }, {
    "tStartMs": 813991,
    "dDurationMs": 2462,
    "segs": [ {
      "utf8": "No, l start classes on Wednesday."
    } ]
  }, {
    "tStartMs": 816661,
    "dDurationMs": 1616,
    "segs": [ {
      "utf8": "l'm looking for a job today."
    } ]
  }, {
    "tStartMs": 818461,
    "dDurationMs": 4267,
    "segs": [ {
      "utf8": "Oh. lt's a good idea to get the paper early."
    } ]
  }, {
    "tStartMs": 823967,
    "dDurationMs": 1185,
    "segs": [ {
      "utf8": "Can l. . . can l make you some tea?"
    } ]
  }, {
    "tStartMs": 825769,
    "dDurationMs": 757,
    "segs": [ {
      "utf8": "Do you have coffee?"
    } ]
  }, {
    "tStartMs": 827671,
    "dDurationMs": 2557,
    "segs": [ {
      "utf8": "Sorry, l'm not sure if we have any coffee."
    } ]
  }, {
    "tStartMs": 830241,
    "dDurationMs": 912,
    "segs": [ {
      "utf8": "Let me have a look."
    } ]
  }, {
    "tStartMs": 839783,
    "dDurationMs": 2299,
    "segs": [ {
      "utf8": "Darling! Good morning!"
    } ]
  }, {
    "tStartMs": 842386,
    "dDurationMs": 1991,
    "segs": [ {
      "utf8": "Good morning, Agatha!"
    } ]
  }, {
    "tStartMs": 845256,
    "dDurationMs": 2818,
    "segs": [ {
      "utf8": "What a clever girl!\nYou're doing morning exercises!"
    } ]
  }, {
    "tStartMs": 848426,
    "dDurationMs": 2366,
    "segs": [ {
      "utf8": "Oh, yes, yes."
    } ]
  }, {
    "tStartMs": 851162,
    "dDurationMs": 788,
    "segs": [ {
      "utf8": "Did you sleep well?"
    } ]
  }, {
    "tStartMs": 852162,
    "dDurationMs": 1228,
    "segs": [ {
      "utf8": "Very well."
    } ]
  }, {
    "tStartMs": 853864,
    "dDurationMs": 1534,
    "segs": [ {
      "utf8": "Sorry, no coffee."
    } ]
  }, {
    "tStartMs": 855700,
    "dDurationMs": 1705,
    "segs": [ {
      "utf8": "Maybe we should add it to the\nshopping list."
    } ]
  }, {
    "tStartMs": 857701,
    "dDurationMs": 2248,
    "segs": [ {
      "utf8": "Yes, yes. Tell me what you need."
    } ]
  }, {
    "tStartMs": 860070,
    "dDurationMs": 2230,
    "segs": [ {
      "utf8": "l'm going shopping with my sister, Betty."
    } ]
  }, {
    "tStartMs": 862506,
    "dDurationMs": 1594,
    "segs": [ {
      "utf8": "Coffee would be nice."
    } ]
  }, {
    "tStartMs": 865610,
    "dDurationMs": 2564,
    "segs": [ {
      "utf8": "Well, what are your\nplans for today, sweetheart?"
    } ]
  }, {
    "tStartMs": 868445,
    "dDurationMs": 3355,
    "segs": [ {
      "utf8": "She's job hunting.\nShe's looking fora part-time job."
    } ]
  }, {
    "tStartMs": 872983,
    "dDurationMs": 1176,
    "segs": [ {
      "utf8": "How industrious!"
    } ]
  }, {
    "tStartMs": 874986,
    "dDurationMs": 3614,
    "segs": [ {
      "utf8": "Well, a pretty girl like you will have no\ntrouble finding a job!"
    } ]
  }, {
    "tStartMs": 880491,
    "dDurationMs": 1602,
    "segs": [ {
      "utf8": "- Here's the paper.\n- Thanks."
    } ]
  }, {
    "tStartMs": 882093,
    "dDurationMs": 3158,
    "segs": [ {
      "utf8": "And look! There's one. lt's here in Kensington."
    } ]
  }, {
    "tStartMs": 886831,
    "dDurationMs": 2145,
    "segs": [ {
      "utf8": "'Video Store on the High Street. . .'"
    } ]
  }, {
    "tStartMs": 892903,
    "dDurationMs": 3922,
    "segs": [ {
      "utf8": "'Young person with excellent\ncommunication skills'"
    } ]
  }, {
    "tStartMs": 897241,
    "dDurationMs": 862,
    "segs": [ {
      "utf8": "That's perfect!"
    } ]
  }, {
    "tStartMs": 898709,
    "dDurationMs": 3990,
    "segs": [ {
      "utf8": "And. . . 'Afternoon shifts Thursdays,\nSaturdays and Sundays.'"
    } ]
  }, {
    "tStartMs": 903680,
    "dDurationMs": 1342,
    "segs": [ {
      "utf8": "Where is the High Street?"
    } ]
  }, {
    "tStartMs": 906082,
    "dDurationMs": 3517,
    "segs": [ {
      "utf8": "Just make a left at the top\nof our road onto Hornton."
    } ]
  }, {
    "tStartMs": 910154,
    "dDurationMs": 2271,
    "segs": [ {
      "utf8": "And then make another\nleft onto the High Street."
    } ]
  }, {
    "tStartMs": 912890,
    "dDurationMs": 2634,
    "segs": [ {
      "utf8": "The store is on your right, next to the Tube Station."
    } ]
  }, {
    "tStartMs": 916626,
    "dDurationMs": 1175,
    "segs": [ {
      "utf8": "The Tube?"
    } ]
  }, {
    "tStartMs": 919730,
    "dDurationMs": 1527,
    "segs": [ {
      "utf8": "l'll walk you up there. Ok?"
    } ]
  }, {
    "tStartMs": 921565,
    "dDurationMs": 1542,
    "segs": [ {
      "utf8": "Thank you! That is very kind of you."
    } ]
  }, {
    "tStartMs": 923566,
    "dDurationMs": 2041,
    "segs": [ {
      "utf8": "Nonsense! My brother is a gentleman."
    } ]
  }, {
    "tStartMs": 927904,
    "dDurationMs": 4405,
    "segs": [ {
      "utf8": "Go get ready and l'll meet you\ndownstairs in 15 minutes. Ok?"
    } ]
  }, {
