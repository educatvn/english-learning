  }, {
    "tStartMs": 844420,
    "dDurationMs": 2521,
    "segs": [ {
      "utf8": "Oh, my poor darling. You feel hot."
    } ]
  }, {
    "tStartMs": 847658,
    "dDurationMs": 1657,
    "segs": [ {
      "utf8": "She has a slight temperature."
