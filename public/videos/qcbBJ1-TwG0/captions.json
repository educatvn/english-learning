  }, {
    "tStartMs": 1012197,
    "dDurationMs": 2190,
    "segs": [ {
      "utf8": "Well, it would be nice!"
    } ]
  }, {
    "tStartMs": 1016167,
    "dDurationMs": 3345,
    "segs": [ {
      "utf8": "Don't worry Elena, l promise you\nthey're all still living!"
    } ]
  }, {
    "tStartMs": 1020037,
    "dDurationMs": 1103,
    "segs": [ {
      "utf8": "Of course!"
    } ]
  }, {
    "tStartMs": 1021140,
    "dDurationMs": 1087,
    "segs": [ {
      "utf8": "Of course they are!"
    } ]
  }, {
    "tStartMs": 1025608,
    "dDurationMs": 1021,
    "segs": [ {
      "utf8": "Good morning!"
    } ]
  }, {
    "tStartMs": 1026676,
    "dDurationMs": 693,
    "segs": [ {
      "utf8": "Morning!"
    } ]
  }, {
    "tStartMs": 1027543,
    "dDurationMs": 967,
    "segs": [ {
      "utf8": "Morning!"
    } ]
  }, {
    "tStartMs": 1029846,
    "dDurationMs": 2384,
    "segs": [ {
      "utf8": "So, is it Ok to visit you at work?"
