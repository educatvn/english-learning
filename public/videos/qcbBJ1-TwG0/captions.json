  }, {
    "tStartMs": 953984,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "No, l don't think so."
    } ]
  }, {
    "tStartMs": 955573,
    "dDurationMs": 3460,
    "segs": [ {
      "utf8": "Lala stayed with us last\nyear for a couple of months."
    } ]
  }, {
    "tStartMs": 959343,
    "dDurationMs": 1816,
    "segs": [ {
      "utf8": "And where is Lala now?"
