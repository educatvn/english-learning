    "tStartMs": 861018,
    "dDurationMs": 3871,
    "segs": [ {
      "utf8": "Maybe l'll go to the chemist's and\nl get something for her headache."
    } ]
  }, {
    "tStartMs": 865057,
    "dDurationMs": 1401,
    "segs": [ {
      "utf8": "- Yes, good idea.\n- Ok. . ."
    } ]
  }, {
    "tStartMs": 866458,
    "dDurationMs": 2206,
    "segs": [ {
      "utf8": "And when you get back\nyou can fix the bathroom!"
    } ]
  }, {
    "tStartMs": 870262,
    "dDurationMs": 1318,
    "segs": [ {
      "utf8": "What's the matter with the bathroom?"
