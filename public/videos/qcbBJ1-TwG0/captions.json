  }, {
    "tStartMs": 1128523,
    "dDurationMs": 1601,
    "segs": [ {
      "utf8": "My niece, Mercedes."
    } ]
  }, {
    "tStartMs": 1130280,
    "dDurationMs": 818,
    "segs": [ {
      "utf8": "How old is she?"
