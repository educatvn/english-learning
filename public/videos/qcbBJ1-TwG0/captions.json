  }, {
    "tStartMs": 887978,
    "dDurationMs": 2102,
    "segs": [ {
      "utf8": "Betty's ugly teacup is back."
    } ]
  }, {
    "tStartMs": 890581,
    "dDurationMs": 3074,
    "segs": [ {
      "utf8": "l know. lt's strange, isn't it?"
    } ]
  }, {
    "tStartMs": 908894,
    "dDurationMs": 1634,
    "segs": [ {
      "utf8": "Victor and Elena. . ."
    } ]
  }, {
    "tStartMs": 913665,
    "dDurationMs": 1863,
    "segs": [ {
      "utf8": "Victor and Lala. . ."
