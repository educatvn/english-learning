  }, {
    "tStartMs": 932555,
    "dDurationMs": 1350,
    "segs": [ {
      "utf8": "l'm so glad!"
    } ]
  }, {
    "tStartMs": 935634,
    "dDurationMs": 1299,
    "segs": [ {
      "utf8": "Who are these girls?"
