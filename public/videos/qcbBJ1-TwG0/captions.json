  }, {
    "tStartMs": 874355,
    "dDurationMs": 1025,
    "segs": [ {
      "utf8": "Oh, no!"
    } ]
  }, {
    "tStartMs": 875380,
    "dDurationMs": 1424,
    "segs": [ {
      "utf8": "l turned off the water."
