  }, {
    "tStartMs": 1131180,
    "dDurationMs": 894,
    "segs": [ {
      "utf8": "She's 12."
    } ]
  }, {
    "tStartMs": 1132781,
    "dDurationMs": 2018,
    "segs": [ {
      "utf8": "And what size shoe does she take?"
