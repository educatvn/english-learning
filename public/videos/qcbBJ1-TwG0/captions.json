  }, {
    "tStartMs": 1139555,
    "dDurationMs": 2444,
    "segs": [ {
      "utf8": "That will be fun to choose shoes for her!"
    } ]
  }, {
    "tStartMs": 1142417,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "What colours does Maria like?"
