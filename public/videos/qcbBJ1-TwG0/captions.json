  }, {
    "tStartMs": 880905,
    "dDurationMs": 1299,
    "segs": [ {
      "utf8": "l'll make some tea."
    } ]
  }, {
    "tStartMs": 885977,
    "dDurationMs": 727,
    "segs": [ {
      "utf8": "Agatha?"
    } ]
  }, {
    "tStartMs": 886845,
    "dDurationMs": 1111,
    "segs": [ {
      "utf8": "Yes?"
