      "utf8": "That's interesting!"
    } ]
  }, {
    "tStartMs": 410102,
    "dDurationMs": 2550,
    "segs": [ {
      "utf8": "What about me?\nWhat about my day?"
    } ]
  }, {
    "tStartMs": 413567,
    "dDurationMs": 2335,
    "segs": [ {
      "utf8": "Oh, Aggie, dear!"
    } ]
  }, {
    "tStartMs": 415902,
    "dDurationMs": 1325,
    "segs": [ {
      "utf8": "How was your day?"
    } ]
  }, {
    "tStartMs": 417805,
    "dDurationMs": 1472,
    "segs": [ {
      "utf8": "Betty take you shopping?"
    } ]
  }, {
    "tStartMs": 419305,
    "dDurationMs": 1735,
    "segs": [ {
      "utf8": "No, actually."
    } ]
  }, {
    "tStartMs": 421040,
    "dDurationMs": 1469,
    "segs": [ {
      "utf8": "No shopping."
    } ]
  }, {
    "tStartMs": 422509,
    "dDurationMs": 3629,
    "segs": [ {
      "utf8": "No shopping! What on earth happened?"
    } ]
  }, {
    "tStartMs": 427580,
    "dDurationMs": 1011,
    "segs": [ {
      "utf8": "l got a job!"
    } ]
  }, {
    "tStartMs": 430283,
    "dDurationMs": 631,
    "segs": [ {
      "utf8": "Where?"
    } ]
  }, {
    "tStartMs": 431851,
    "dDurationMs": 1201,
    "segs": [ {
      "utf8": "When?"
    } ]
  }, {
    "tStartMs": 433052,
    "dDurationMs": 814,
    "segs": [ {
      "utf8": "Doing what?"
    } ]
  }, {
    "tStartMs": 434854,
    "dDurationMs": 983,
    "segs": [ {
      "utf8": "How?"
    } ]
  }, {
    "tStartMs": 437323,
    "dDurationMs": 967,
    "segs": [ {
      "utf8": "When do you start?"
    } ]
  }, {
    "tStartMs": 439025,
    "dDurationMs": 5004,
    "segs": [ {
      "utf8": "l start the day after tomorrow.\nl'm working ten till 5, Monday to Friday."
    } ]
  }, {
    "tStartMs": 444765,
    "dDurationMs": 1148,
    "segs": [ {
      "utf8": "Congratulations!"
    } ]
  }, {
    "tStartMs": 446366,
    "dDurationMs": 3964,
    "segs": [ {
      "utf8": "Mr James is my supervisor, very nice\nman, a real gentleman."
    } ]
  }, {
    "tStartMs": 450471,
    "dDurationMs": 1332,
    "segs": [ {
      "utf8": "Where are you working?"
    } ]
  }, {
    "tStartMs": 451838,
    "dDurationMs": 2595,
    "segs": [ {
      "utf8": "Churchill's, off St James' Park."
    } ]
  }, {
    "tStartMs": 454941,
    "dDurationMs": 3591,
    "segs": [ {
      "utf8": "l'm a sales assistant in the Ladies Department."
    } ]
  }, {
    "tStartMs": 458644,
    "dDurationMs": 2936,
    "segs": [ {
      "utf8": "Well, that's handy.\nYou can take the Circle Line."
    } ]
  }, {
    "tStartMs": 461982,
    "dDurationMs": 1349,
    "segs": [ {
      "utf8": "Does Harold know?"
    } ]
  }, {
    "tStartMs": 463331,
    "dDurationMs": 1174,
    "segs": [ {
      "utf8": "lt was his idea."
    } ]
  }, {
    "tStartMs": 465486,
    "dDurationMs": 1495,
    "segs": [ {
      "utf8": "ls this a permanent job?"
    } ]
  }, {
    "tStartMs": 467420,
    "dDurationMs": 2537,
    "segs": [ {
      "utf8": "l'm working over the Christmas period."
    } ]
  }, {
    "tStartMs": 470289,
    "dDurationMs": 1068,
    "segs": [ {
      "utf8": "They need more staff."
    } ]
  }, {
    "tStartMs": 472058,
    "dDurationMs": 4697,
    "segs": [ {
      "utf8": "Mr James says perhaps l can stay\non after the holidays."
    } ]
  }, {
    "tStartMs": 477197,
    "dDurationMs": 983,
    "segs": [ {
      "utf8": "Good!"
    } ]
  }, {
    "tStartMs": 479240,
    "dDurationMs": 2438,
    "segs": [ {
      "utf8": "What are your plans for the holidays, Elena?"
    } ]
  }, {
    "tStartMs": 482168,
    "dDurationMs": 1711,
    "segs": [ {
      "utf8": "Will you spend Christmas with us?"
    } ]
  }, {
    "tStartMs": 483903,
    "dDurationMs": 1774,
    "segs": [ {
      "utf8": "Yes, please Elena."
    } ]
  }, {
    "tStartMs": 486439,
    "dDurationMs": 3366,
    "segs": [ {
      "utf8": "l'd love to but my classes finish on the 21st."
    } ]
  }, {
    "tStartMs": 491111,
    "dDurationMs": 2917,
    "segs": [ {
      "utf8": "l have Christmas Day and Boxing day off."
    } ]
  }, {
    "tStartMs": 494046,
    "dDurationMs": 1160,
    "segs": [ {
      "utf8": "l'll cook a Turkey."
    } ]
  }, {
    "tStartMs": 496048,
    "dDurationMs": 3981,
    "segs": [ {
      "utf8": "That is very kind but my\nreturn ticket is for the 23rd."
    } ]
  }, {
    "tStartMs": 502188,
    "dDurationMs": 1165,
    "segs": [ {
      "utf8": "lt just seems so soon."
    } ]
  }, {
    "tStartMs": 505292,
    "dDurationMs": 4787,
    "segs": [ {
      "utf8": "Oh dear! Perhaps the weather will be bad."
    } ]
  }, {
    "tStartMs": 510364,
    "dDurationMs": 2389,
    "segs": [ {
      "utf8": "London is famous for its fog."
    } ]
  }, {
    "tStartMs": 513200,
    "dDurationMs": 4727,
    "segs": [ {
      "utf8": "Maybe your flight home will be\ndelayed or. . . or cancelled!"
    } ]
  }, {
    "tStartMs": 517927,
    "dDurationMs": 1979,
    "segs": [ {
      "utf8": "They could close the airport!"
    } ]
  }, {
    "tStartMs": 520173,
    "dDurationMs": 1708,
    "segs": [ {
      "utf8": "You simply can't go."
    } ]
  }, {
    "tStartMs": 522275,
    "dDurationMs": 2781,
    "segs": [ {
      "utf8": "Agatha, Elena's here for 8 weeks."
    } ]
  }, {
    "tStartMs": 525178,
    "dDurationMs": 1603,
    "segs": [ {
      "utf8": "l'm not going yet!"
    } ]
  }, {
    "tStartMs": 527380,
    "dDurationMs": 3148,
    "segs": [ {
      "utf8": "Well, we'll see.\nVictor, what about your classes?"
    } ]
  }, {
    "tStartMs": 531150,
    "dDurationMs": 5329,
    "segs": [ {
      "utf8": "We finish up this year on December\n21st after my final exams."
    } ]
  }, {
    "tStartMs": 536723,
    "dDurationMs": 1857,
    "segs": [ {
      "utf8": "What day of the week is New Year's Eve?"
    } ]
  }, {
    "tStartMs": 539458,
    "dDurationMs": 1099,
    "segs": [ {
      "utf8": "lt's Monday this year."
    } ]
  }, {
    "tStartMs": 543696,
    "dDurationMs": 1757,
    "segs": [ {
      "utf8": "Oh, it's so sad!"
    } ]
  }, {
    "tStartMs": 547301,
    "dDurationMs": 1980,
    "segs": [ {
      "utf8": "Everything ends. . ."
    } ]
  }, {
    "tStartMs": 553273,
    "dDurationMs": 1582,
    "segs": [ {
      "utf8": "Let's take a photo of Elena."
    } ]
  }, {
    "tStartMs": 556475,
    "dDurationMs": 1836,
    "segs": [ {
      "utf8": "Elena and Victor, together. . ."
    } ]
  }, {
    "tStartMs": 558311,
    "dDurationMs": 1193,
    "segs": [ {
      "utf8": "Oh, Agatha!"
    } ]
  }, {
    "tStartMs": 559946,
    "dDurationMs": 537,
    "segs": [ {
      "utf8": "Smile!"
    } ]
  }, {
    "tStartMs": 560483,
    "dDurationMs": 751,
    "segs": [ {
      "utf8": "Please no!"
    } ]
  }, {
    "tStartMs": 561234,
    "dDurationMs": 2278,
    "segs": [ {
      "utf8": "Smile! There!"
    } ]
  }, {
    "tStartMs": 564151,
    "dDurationMs": 1870,
    "segs": [ {
      "utf8": "Can l take a photo of you, Agatha?"
    } ]
  }, {
    "tStartMs": 566021,
    "dDurationMs": 1125,
    "segs": [ {
      "utf8": "Oh, dear, no!"
    } ]
  }, {
    "tStartMs": 567146,
    "dDurationMs": 603,
    "segs": [ {
      "utf8": "Please!"
    } ]
  }, {
    "tStartMs": 568600,
    "dDurationMs": 549,
    "segs": [ {
      "utf8": "Ok."
    } ]
  }, {
    "tStartMs": 569684,
    "dDurationMs": 715,
    "segs": [ {
      "utf8": "Thank you."
    } ]
  }, {
    "tStartMs": 578302,
    "dDurationMs": 2108,
    "segs": [ {
      "utf8": "What are your plans for today, Elena?"
    } ]
  }, {
    "tStartMs": 580971,
    "dDurationMs": 4164,
    "segs": [ {
      "utf8": "l only have two classes before lunch.\nThen l'm free all afternoon."
    } ]
  }, {
    "tStartMs": 585135,
    "dDurationMs": 1472,
    "segs": [ {
      "utf8": "You are lucky!"
    } ]
  }, {
    "tStartMs": 587744,
    "dDurationMs": 1291,
    "segs": [ {
      "utf8": "Don't you like your job?"
    } ]
  }, {
    "tStartMs": 589948,
    "dDurationMs": 3088,
    "segs": [ {
      "utf8": "Like it? l adore it!"
    } ]
  }, {
    "tStartMs": 594452,
    "dDurationMs": 3354,
    "segs": [ {
      "utf8": "Mr James says\nl'm his best sales assistant!"
    } ]
  }, {
    "tStartMs": 598722,
    "dDurationMs": 2086,
    "segs": [ {
      "utf8": "And what will you do\nwith your afternoon?"
    } ]
  }, {
    "tStartMs": 602359,
    "dDurationMs": 3153,
    "segs": [ {
      "utf8": "There's a fantastic Kubrick festival on:"
    } ]
  }, {
    "tStartMs": 605796,
    "dDurationMs": 3714,
    "segs": [ {
      "utf8": "'2001: A Space Odyssey' is playing\nat the Odeon Multiplex."
    } ]
  }, {
    "tStartMs": 610134,
    "dDurationMs": 1151,
    "segs": [ {
      "utf8": "Where is the Odeon?"
    } ]
  }, {
    "tStartMs": 611636,
    "dDurationMs": 1900,
    "segs": [ {
      "utf8": "lt's on Tottenham Court Road."
    } ]
  }, {
    "tStartMs": 614137,
    "dDurationMs": 4644,
    "segs": [ {
      "utf8": "That's a brilliant film!\nl adore Roddy McDowall!"
    } ]
  }, {
    "tStartMs": 619409,
    "dDurationMs": 2176,
    "segs": [ {
      "utf8": "You mean Malcolm McDowell!"
    } ]
  }, {
    "tStartMs": 621979,
    "dDurationMs": 1531,
    "segs": [ {
      "utf8": "And he is not in '2001'."
    } ]
  }, {
    "tStartMs": 624015,
    "dDurationMs": 1835,
    "segs": [ {
      "utf8": "The star is Keir Dullea."
    } ]
  }, {
    "tStartMs": 625850,
    "dDurationMs": 2532,
    "segs": [ {
      "utf8": "Exactly! He's such a doll!"
    } ]
  }, {
    "tStartMs": 628886,
    "dDurationMs": 1521,
    "segs": [ {
      "utf8": "What kind of movie is it?"
    } ]
  }, {
    "tStartMs": 630822,
    "dDurationMs": 1837,
    "segs": [ {
      "utf8": "lt's science fiction."
    } ]
  }, {
    "tStartMs": 632723,
    "dDurationMs": 1312,
    "segs": [ {
      "utf8": "You must see it!"
    } ]
  }, {
    "tStartMs": 634524,
    "dDurationMs": 1908,
    "segs": [ {
      "utf8": "Do you know\nwhat time the shows are?"
    } ]
  }, {
    "tStartMs": 637929,
    "dDurationMs": 1953,
    "segs": [ {
      "utf8": "No, but we can look in the paper."
    } ]
  }, {
    "tStartMs": 644802,
    "dDurationMs": 6483,
    "segs": [ {
      "utf8": "There are shows at 1:35,\n3:45 and 5:55."
    } ]
  }, {
    "tStartMs": 651709,
    "dDurationMs": 1199,
    "segs": [ {
      "utf8": "ls it a long film?"
    } ]
  }, {
    "tStartMs": 653677,
    "dDurationMs": 2929,
    "segs": [ {
      "utf8": "lt runs 160 minutes. . ."
    } ]
  }, {
    "tStartMs": 657281,
    "dDurationMs": 3325,
    "segs": [ {
      "utf8": "Yes, nearly 3 hours.\nWhat time do you finish class?"
    } ]
  }, {
    "tStartMs": 660985,
    "dDurationMs": 1273,
    "segs": [ {
      "utf8": "At 12:30."
    } ]
  }, {
    "tStartMs": 663221,
    "dDurationMs": 2165,
    "segs": [ {
      "utf8": "Well, you could make\nthe show at 1 :35."
    } ]
  }, {
    "tStartMs": 665790,
    "dDurationMs": 2196,
    "segs": [ {
      "utf8": "Yes, but l need to go\nto the bank today, too."
    } ]
  }, {
    "tStartMs": 668159,
    "dDurationMs": 2149,
    "segs": [ {
      "utf8": "l have my first pay cheque."
    } ]
  }, {
    "tStartMs": 670561,
    "dDurationMs": 2922,
    "segs": [ {
      "utf8": "You need to cash your cheque."
    } ]
  }, {
    "tStartMs": 673498,
    "dDurationMs": 2961,
    "segs": [ {
      "utf8": "Yes, and l want to send\nsome money home, too."
    } ]
  }, {
    "tStartMs": 676968,
    "dDurationMs": 2260,
    "segs": [ {
      "utf8": "lt's my little brother's birthday next week."
    } ]
  }, {
    "tStartMs": 679971,
    "dDurationMs": 3398,
    "segs": [ {
      "utf8": "Well, you should be able to make\nthe banks before they close at 5:00."
    } ]
  }, {
    "tStartMs": 683775,
    "dDurationMs": 2589,
    "segs": [ {
      "utf8": "Just go to the nearest bank to the cinema."
    } ]
  }, {
    "tStartMs": 687192,
    "dDurationMs": 548,
    "segs": [ {
      "utf8": "Ok!"
    } ]
  }, {
    "tStartMs": 688111,
    "dDurationMs": 3890,
    "segs": [ {
      "utf8": "And don't forget to bring your\npassport, you'll need it for identification."
    } ]
  }, {
    "tStartMs": 692301,
    "dDurationMs": 1697,
    "segs": [ {
      "utf8": "You'll need to fill in a money transfer."
    } ]
  }, {
    "tStartMs": 695286,
    "dDurationMs": 1741,
    "segs": [ {
      "utf8": "Are you taking Elena to the movies?"
    } ]
  }, {
    "tStartMs": 697621,
    "dDurationMs": 2818,
    "segs": [ {
      "utf8": "No, Agatha. l'm studying for my final exam."
    } ]
  }, {
    "tStartMs": 702126,
    "dDurationMs": 771,
    "segs": [ {
      "utf8": "Enjoy yourself."
    } ]
  }, {
    "tStartMs": 703360,
    "dDurationMs": 814,
    "segs": [ {
      "utf8": "Thank you, l will."
    } ]
  }, {
    "tStartMs": 704895,
    "dDurationMs": 1571,
    "segs": [ {
      "utf8": "Yes, enjoy your movie."
    } ]
  }, {
    "tStartMs": 707198,
    "dDurationMs": 1844,
    "segs": [ {
      "utf8": "l'm also going\nto send some money home."
    } ]
  }, {
    "tStartMs": 709667,
    "dDurationMs": 2248,
    "segs": [ {
      "utf8": "l got my first pay cheque yesterday."
    } ]
  }, {
    "tStartMs": 712036,
    "dDurationMs": 1048,
    "segs": [ {
      "utf8": "Oh, Wonderful!"
    } ]
  }, {
    "tStartMs": 713187,
    "dDurationMs": 5373,
    "segs": [ {
      "utf8": "What's the exchange\nrate for pounds to. . . pesos?"
    } ]
  }, {
    "tStartMs": 720211,
    "dDurationMs": 1834,
    "segs": [ {
      "utf8": "Spain has euro currency. . ."
    } ]
  }, {
    "tStartMs": 722513,
    "dDurationMs": 1234,
    "segs": [ {
      "utf8": "Of course you do!"
    } ]
  }, {
    "tStartMs": 723848,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "How silly of me!"
    } ]
  }, {
    "tStartMs": 725515,
    "dDurationMs": 805,
    "segs": [ {
      "utf8": "Have a good day."
    } ]
  }, {
    "tStartMs": 726451,
    "dDurationMs": 1044,
    "segs": [ {
      "utf8": "Thanks."
    } ]
  }, {
    "tStartMs": 743033,
    "dDurationMs": 2115,
    "segs": [ {
      "utf8": "Yes, Mr Charles?"
    } ]
  }, {
    "tStartMs": 745669,
    "dDurationMs": 1630,
    "segs": [ {
      "utf8": "This is Elena Fuentes."
    } ]
  }, {
    "tStartMs": 748639,
    "dDurationMs": 1059,
    "segs": [ {
      "utf8": "Yes, the teacup."
    } ]
  }, {
    "tStartMs": 751643,
    "dDurationMs": 811,
    "segs": [ {
      "utf8": "ls it ready?"
    } ]
  }, {
    "tStartMs": 754344,
    "dDurationMs": 3085,
    "segs": [ {
      "utf8": "Ok, l'll pick it up in the afternoon."
    } ]
  }, {
    "tStartMs": 759150,
    "dDurationMs": 2926,
    "segs": [ {
      "utf8": "Thanks. Bye. Bye bye."
    } ]
  }, {
    "tStartMs": 772449,
    "dDurationMs": 3080,
    "segs": [ {
      "utf8": "Elena! Help! There is a big problem!"
    } ]
  }, {
    "tStartMs": 775918,
    "dDurationMs": 1524,
    "segs": [ {
      "utf8": "What's wrong?"
    } ]
  }, {
    "tStartMs": 777753,
    "dDurationMs": 1662,
    "segs": [ {
      "utf8": "That teacup. . ."
    } ]
  }, {
    "tStartMs": 779789,
    "dDurationMs": 1202,
    "segs": [ {
      "utf8": "Yes?"
    } ]
  }, {
    "tStartMs": 780991,
    "dDurationMs": 3770,
    "segs": [ {
      "utf8": "That horrible, ugly tea set!"
    } ]
  }, {
    "tStartMs": 784761,
    "dDurationMs": 968,
    "segs": [ {
      "utf8": "But l. . ."
    } ]
  }, {
    "tStartMs": 785729,
    "dDurationMs": 2350,
    "segs": [ {
      "utf8": "Betty gave it to me as a birthday present."
    } ]
  }, {
    "tStartMs": 789532,
    "dDurationMs": 1097,
    "segs": [ {
      "utf8": "l hate that tea set!"
    } ]
  }, {
    "tStartMs": 791067,
    "dDurationMs": 835,
    "segs": [ {
      "utf8": "You do?"
    } ]
  }, {
    "tStartMs": 791902,
    "dDurationMs": 1826,
    "segs": [ {
      "utf8": "l hoped it was disappearing!"
    } ]
  }, {
    "tStartMs": 793869,
    "dDurationMs": 2060,
    "segs": [ {
      "utf8": "Yesterday, one of the cups was missing. . ."
    } ]
  }, {
    "tStartMs": 796238,
    "dDurationMs": 835,
    "segs": [ {
      "utf8": "Yes?"
    } ]
  }, {
    "tStartMs": 797073,
    "dDurationMs": 3155,
    "segs": [ {
      "utf8": ". . . and now today the teacup is back!"
    } ]
  }, {
    "tStartMs": 802946,
    "dDurationMs": 1708,
    "segs": [ {
      "utf8": "Elena, sweetie, are you Ok?"
    } ]
  }, {
    "tStartMs": 806183,
    "dDurationMs": 1309,
    "segs": [ {
      "utf8": "Oh, the bathroom!"
    } ]
  }, {
    "tStartMs": 807492,
    "dDurationMs": 1400,
    "segs": [ {
      "utf8": "What about the bathroom?"
    } ]
  }, {
    "tStartMs": 808892,
    "dDurationMs": 2150,
    "segs": [ {
      "utf8": "There's a lot of water on the floor!"
    } ]
  }, {
    "tStartMs": 820064,
    "dDurationMs": 862,
    "segs": [ {
      "utf8": "Hi!"
    } ]
  }, {
    "tStartMs": 821397,
    "dDurationMs": 830,
    "segs": [ {
      "utf8": "Hi."
    } ]
  }, {
    "tStartMs": 822866,
    "dDurationMs": 627,
    "segs": [ {
      "utf8": "Are you all right?"
    } ]
  }, {
    "tStartMs": 824567,
    "dDurationMs": 2299,
    "segs": [ {
      "utf8": "l have a headache and a stomachache."
    } ]
  }, {
    "tStartMs": 827304,
    "dDurationMs": 1213,
    "segs": [ {
      "utf8": "Oh, you poor girl!"
    } ]
  }, {
    "tStartMs": 829305,
    "dDurationMs": 1561,
    "segs": [ {
      "utf8": "Maybe you have the flu."
    } ]
  }, {
    "tStartMs": 831274,
    "dDurationMs": 2468,
    "segs": [ {
      "utf8": "Victor, what did you ask Elena?"
    } ]
  }, {
    "tStartMs": 834811,
    "dDurationMs": 1231,
    "segs": [ {
      "utf8": "Did she say no?"
    } ]
  }, {
    "tStartMs": 837179,
    "dDurationMs": 1964,
    "segs": [ {
      "utf8": "Stop it, Aggie! Elena isn't well."
    } ]
  }, {
    "tStartMs": 839950,
    "dDurationMs": 765,
    "segs": [ {
      "utf8": "What's wrong?"
