  }, {
    "tStartMs": 994780,
    "dDurationMs": 1058,
    "segs": [ {
      "utf8": "Oh."
    } ]
  }, {
    "tStartMs": 998182,
    "dDurationMs": 2876,
    "segs": [ {
      "utf8": "That's Agatha's 'Almost' album."
    } ]
  }, {
    "tStartMs": 1001352,
    "dDurationMs": 1002,
    "segs": [ {
      "utf8": "Sorry?"
    } ]
  }, {
    "tStartMs": 1002354,
    "dDurationMs": 4772,
    "segs": [ {
      "utf8": "Agatha invites foreign students to stay here\nand then tries to marry them off to me."
    } ]
  }, {
    "tStartMs": 1008462,
    "dDurationMs": 3550,
    "segs": [ {
      "utf8": "lt's her biggest project.\nRight, Aggie?"
