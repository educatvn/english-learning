  }, {
    "tStartMs": 936933,
    "dDurationMs": 1327,
    "segs": [ {
      "utf8": "Which girls, Elena?"
    } ]
  }, {
    "tStartMs": 938260,
    "dDurationMs": 1649,
    "segs": [ {
      "utf8": "The girls in the book."
    } ]
  }, {
    "tStartMs": 940391,
    "dDurationMs": 3467,
    "segs": [ {
      "utf8": "Oh, them! Girls we know."
